---
import Layout from '../layouts/Layout.astro';
import { payment, pricing, contact } from '../data/site.js';

const wa = contact.phoneRaw;              // 916387617678
const upiId = payment.upiId;              // canvapro@upi
const payee = payment.payeeName;          // Daily PosterHub
const cur = pricing.currency || '₹';
const plans = [
  { id: 'monthly', label: 'मासिक प्लान', amount: pricing.monthly, per: '/ माह' },
  { id: 'yearly', label: 'वार्षिक प्लान', amount: pricing.yearly, per: '/ साल', best: true },
];
---
<Layout title='पेमेंट — Daily PosterHub Pro'>
  <section class='pay-hero'>
    <div class='container'>
      <h1>Pro <span class='grad-text'>अपग्रेड</span></h1>
      <p>UPI से पेमेंट करें · जानकारी भेजें · 2 घंटे में Pro चालू</p>
    </div>
  </section>

  <section class='section' style='padding-top:26px'>
    <div class='container pay-wrap'
         data-upi={upiId} data-payee={payee} data-wa={wa} data-cur={cur}
         data-amt-monthly={String(plans[0].amount)} data-amt-yearly={String(plans[1].amount)}>

      <div class='pay-card card'>
        <div class='step-h'><span class='step-n'>1</span><h3>प्लान चुनें</h3></div>
        <div class='plan-row'>
          {plans.map((p) => (
            <label class={'plan ' + (p.best ? 'best' : '')} data-plan={p.id}>
              <input type='radio' name='plan' value={p.id} checked={p.id === 'yearly'} />
              <div class='plan-in'>
                {p.best ? <span class='tagbest'>बेस्ट वैल्यू</span> : null}
                <span class='plan-label'>{p.label}</span>
                <span class='plan-amt'>{cur}{p.amount}<small>{p.per}</small></span>
              </div>
            </label>
          ))}
        </div>
      </div>

      <div class='pay-card card'>
        <div class='step-h'><span class='step-n'>2</span><h3>UPI से पेमेंट करें</h3></div>
        <div class='pay-grid'>
          <div class='qr-box'>
            <div id='qr'></div>
            <span class='qr-cap'>QR स्कैन करें</span>
          </div>
          <div class='upi-box'>
            <div class='amt-line'>देय राशि: <b id='amtShow'>{cur}{plans[1].amount}</b></div>
            <div class='upi-id'>
              <span id='upiId'>{upiId}</span>
              <button type='button' id='copyUpi' class='btn btn-outline btn-sm'>
                <svg width='15' height='15' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><rect x='9' y='9' width='13' height='13' rx='2'/><path d='M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1'/></svg>
                कॉपी
              </button>
            </div>
            <a id='payNow' class='btn btn-primary btn-lg' href='#'>
              <svg width='18' height='18' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><rect x='5' y='2' width='14' height='20' rx='2'/><line x1='12' y1='18' x2='12.01' y2='18'/></svg>
              UPI ऐप में खोलें
            </a>
            <p class='hint'>GPay / PhonePe / Paytm किसी से भी भुगतान करें। भुगतान के बाद स्क्रीनशॉट लें।</p>
          </div>
        </div>
      </div>

      <div class='pay-card card'>
        <div class='step-h'><span class='step-n'>3</span><h3>अपनी जानकारी भरें</h3></div>
        <div class='fld'><label>आपका नाम *</label><input id='fName' type='text' placeholder='नाम' /></div>
        <div class='fld'><label>अकाउंट ईमेल/मोबाइल *</label><input id='fAcc' type='text' placeholder='जिससे लॉगिन करेंगे' /></div>
        <div class='fld'><label>UPI Ref / Txn ID (optional)</label><input id='fTxn' type='text' placeholder='जैसे 4012xxxx' /></div>
      </div>

      <div class='pay-card card send-card'>
        <div class='step-h'><span class='step-n'>4</span><h3>रिक्वेस्ट भेजें</h3></div>
        <p class='send-note'>नीचे बटन दबाते ही हमारा WhatsApp खुलेगा — अपनी payment की जानकारी वहाँ भेज दें। हम 2 घंटे के अंदर आपका Pro चालू कर देंगे। (चाहें तो screenshot भी WhatsApp पर भेज सकते हैं।)</p>
        <button type='button' id='sendReq' class='btn btn-gold btn-lg'>
          <svg width='18' height='18' viewBox='0 0 24 24' fill='currentColor'><path d='M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38c1.45.79 3.08 1.21 4.79 1.21h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2zm5.8 14.09c-.24.68-1.42 1.32-1.95 1.36-.5.04-.5.36-3.15-.66-2.66-1.02-4.35-3.74-4.48-3.91-.13-.17-1.08-1.44-1.08-2.75 0-1.31.69-1.95.93-2.22.24-.27.53-.34.71-.34.18 0 .36 0 .51.01.16.01.38-.06.6.46.24.56.79 1.94.86 2.08.07.14.12.3.02.48-.1.18-.15.29-.29.45-.14.16-.3.36-.43.48-.14.14-.29.29-.13.57.16.28.71 1.17 1.53 1.9 1.05.94 1.94 1.23 2.22 1.37.28.14.44.12.6-.07.16-.19.69-.8.87-1.08.18-.28.36-.23.6-.14.24.09 1.53.72 1.79.85.26.13.43.2.5.31.07.11.07.64-.17 1.32z'/></svg>
          रिक्वेस्ट भेजें (WhatsApp)
        </button>
        <p id='sendMsg' class='send-msg'></p>
      </div>

    </div>
  </section>
</Layout>

<style>
  .pay-hero { background: var(--grad-soft); padding: 40px 0; text-align: center; }
  .pay-hero h1 { font-size: 34px; font-weight: 800; }
  .pay-hero p { color: var(--muted); margin-top: 8px; font-size: 14.5px; }
  .pay-wrap { max-width: 720px; margin: 0 auto; display: flex; flex-direction: column; gap: 18px; }
  .pay-card { padding: 20px 22px; }
  .step-h { display: flex; align-items: center; gap: 10px; margin-bottom: 16px; }
  .step-n { width: 28px; height: 28px; border-radius: 50%; background: var(--purple); color: #fff; font-weight: 700; display: grid; place-items: center; font-size: 14px; }
  .step-h h3 { font-size: 17px; font-weight: 700; }

  .plan-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .plan { position: relative; cursor: pointer; }
  .plan input { position: absolute; opacity: 0; }
  .plan-in { border: 2px solid var(--line); border-radius: 14px; padding: 16px; text-align: center; transition: .15s; }
  .plan.sel .plan-in { border-color: var(--purple); background: var(--grad-soft); }
  .tagbest { position: absolute; top: -10px; left: 50%; transform: translateX(-50%); background: var(--gold); color: #3a2a00; font-size: 11px; font-weight: 800; padding: 3px 10px; border-radius: 999px; }
  .plan-label { display: block; font-weight: 700; font-size: 14px; margin-bottom: 4px; }
  .plan-amt { font-size: 24px; font-weight: 800; color: var(--purple); }
  .plan-amt small { font-size: 12px; color: var(--muted); font-weight: 600; }

  .pay-grid { display: grid; grid-template-columns: 240px 1fr; gap: 20px; align-items: center; }
  .qr-box { text-align: center; }
  #qr { width: 220px; height: 220px; margin: 0 auto; display: grid; place-items: center; background: #fff; border: 1px solid var(--line); border-radius: 14px; padding: 10px; }
  #qr img, #qr canvas { display: block; }
  .qr-cap { font-size: 12.5px; color: var(--muted); display: block; margin-top: 8px; }
  .qr-fallback { font-weight: 700; color: var(--purple); word-break: break-all; padding: 20px; }
  .amt-line { font-size: 15px; margin-bottom: 12px; }
  .amt-line b { color: var(--purple); font-size: 20px; }
  .upi-id { display: flex; align-items: center; gap: 10px; background: var(--bg); border: 1px solid var(--line); border-radius: 12px; padding: 10px 12px; margin-bottom: 14px; }
  .upi-id span { font-weight: 700; font-size: 15px; flex: 1; word-break: break-all; }
  #payNow { width: 100%; gap: 8px; }
  .hint { font-size: 12.5px; color: var(--muted); margin-top: 10px; }

  .fld { margin-bottom: 14px; }
  .fld label { display: block; font-size: 13px; font-weight: 600; margin-bottom: 6px; }
  .fld input[type=text] { width: 100%; padding: 11px 13px; border: 1px solid var(--line); border-radius: 10px; font-family: inherit; font-size: 14px; }
  .fld input[type=file] { font-size: 13px; }
  .shot-prev { margin-top: 12px; max-width: 220px; width: 100%; border-radius: 12px; border: 1px solid var(--line); }

  .send-note { font-size: 14px; color: var(--muted); margin-bottom: 16px; line-height: 1.6; }
  #sendReq { width: 100%; gap: 8px; }
  .send-msg { margin-top: 12px; font-size: 13.5px; text-align: center; color: var(--muted); }
  .send-msg.err { color: #d11; font-weight: 600; }

  @media (max-width: 560px) {
    .pay-grid { grid-template-columns: 1fr; }
    .qr-box { margin-bottom: 6px; }
  }
</style>

<script is:inline src='https://cdn.jsdelivr.net/gh/davidshimjs/qrcodejs@master/qrcode.min.js'></script>
<script is:inline>
  (function () {
    var wrap = document.querySelector('.pay-wrap');
    if (!wrap) return;
    var upiId = wrap.dataset.upi;
    var payee = wrap.dataset.payee;
    var wa = wrap.dataset.wa;
    var cur = wrap.dataset.cur || '₹';
    var amts = { monthly: Number(wrap.dataset.amtMonthly), yearly: Number(wrap.dataset.amtYearly) };
    var plan = 'yearly';
    var qrEl = document.getElementById('qr');
    var amtShow = document.getElementById('amtShow');
    var payNow = document.getElementById('payNow');

    function upiString() {
      var amt = amts[plan];
      var tn = 'DailyPosterHub Pro ' + plan;
      return 'upi://pay?pa=' + encodeURIComponent(upiId) + '&pn=' + encodeURIComponent(payee) + '&am=' + amt + '&cu=INR&tn=' + encodeURIComponent(tn);
    }
    function renderQR() {
      qrEl.innerHTML = '';
      try { new QRCode(qrEl, { text: upiString(), width: 220, height: 220, correctLevel: QRCode.CorrectLevel.M }); }
      catch (e) { qrEl.innerHTML = '<div class="qr-fallback">' + upiId + '</div>'; }
      amtShow.textContent = cur + amts[plan];
      payNow.href = upiString();
    }

    var radios = document.querySelectorAll('input[name=plan]');
    for (var i = 0; i < radios.length; i++) {
      radios[i].addEventListener('change', function () {
        plan = this.value;
        var labels = document.querySelectorAll('.plan');
        for (var j = 0; j < labels.length; j++) labels[j].classList.remove('sel');
        this.closest('.plan').classList.add('sel');
        renderQR();
      });
    }

    document.getElementById('copyUpi').addEventListener('click', function () {
      var b = this;
      navigator.clipboard && navigator.clipboard.writeText(upiId).then(function () {
        var t = b.innerHTML; b.textContent = 'कॉपी हुआ ✓';
        setTimeout(function () { b.innerHTML = t; }, 1500);
      });
    });

    document.getElementById('sendReq').addEventListener('click', function () {
      var name = document.getElementById('fName').value.trim();
      var acc = document.getElementById('fAcc').value.trim();
      var txn = document.getElementById('fTxn').value.trim();
      var msg = document.getElementById('sendMsg');
      if (!name || !acc) { msg.textContent = 'कृपया नाम और अकाउंट ईमेल/मोबाइल भरें।'; msg.className = 'send-msg err'; return; }
      var btn = this; btn.disabled = true; msg.className = 'send-msg'; msg.textContent = 'तैयार हो रहा है...';
      var lines = [
        'नमस्ते! मैंने Daily PosterHub Pro के लिए payment किया है।',
        'प्लान: ' + (plan === 'yearly' ? 'वार्षिक' : 'मासिक') + ' (' + cur + amts[plan] + ')',
        'नाम: ' + name,
        'अकाउंट: ' + acc,
        'UPI Ref/Txn: ' + (txn || '-'),
        'कृपया मेरा Pro चालू कर दें। धन्यवाद!'
      ];
      fetch('/api/payment-request',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify({name:name,account:acc,txn:txn,plan:plan,amount:amts[plan]})}).catch(function(){});
      var url = 'https://wa.me/' + wa + '?text=' + encodeURIComponent(lines.join('\n'));
      msg.textContent = 'WhatsApp खुल रहा है...';
      window.location.href = url;
      setTimeout(function () { btn.disabled = false; }, 3000);
    });

    renderQR();
    var yearlyLabel = document.querySelector('.plan[data-plan=yearly]');
    if (yearlyLabel) yearlyLabel.classList.add('sel');
  })();
</script>
