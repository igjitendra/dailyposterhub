---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
import {
  site, trustChips, heroPreviews, categories, proPerks,
  steps, templates, stats, proUpsell, pricing,
} from '../data/site.js';
---
<Layout>
  <script is:inline>
    // Logged-in users ko home par na aane do -> posters par bhej do.
    fetch('/api/auth/me').then(function (r) { return r.json(); }).then(function (d) { if (d && d.user) { window.location.replace('/posters/'); } }).catch(function () {});
  </script>
  <!-- ===================== HERO ===================== -->
  <section class='hero'>
    <div class='container hero-grid'>
      <div class='hero-copy'>
        <span class='eyebrow'><Icon name='star' size={15} /> भारत की #1 हिंदी पोस्टर वेबसाइट</span>
        <h1>
          अपना नाम, फोटो और संदेश के साथ
          <span class='grad-text'>सुंदर हिंदी पोस्टर बनाएं</span>
        </h1>
        <p class='hero-sub'>
          हजारों फ्री और प्रीमियम हिंदी पोस्टर टेम्पलेट्स —
          गुड मॉर्निंग, शुभकामनाएं, बर्थडे, फेस्टिवल, बिज़नेस और बहुत कुछ।
        </p>

        <ul class='trust'>
          {trustChips.map((c) => (
            <li><Icon name={c.icon} size={16} /> {c.text}</li>
          ))}
        </ul>

        <div class='hero-cta'>
          <a href='/posters' class='btn btn-primary btn-lg cta-stack'>
            <span class='cta-main'><Icon name='edit' size={18} /> पोस्टर बनाएं</span>
            <span class='cta-sub'>फ्री में शुरू करें</span>
          </a>
          <a href='/categories' class='btn btn-outline btn-lg cta-stack'>
            <span class='cta-main'>सभी पोस्टर देखें</span>
            <span class='cta-sub'>सभी कैटेगरी ब्राउज़ करें</span>
          </a>
        </div>

        <div class='social-proof'>
          <div class='avatars'>
            <img src='/img/avatar-1.webp' alt='यूज़र' />
            <img src='/img/avatar-2.webp' alt='यूज़र' />
            <img src='/img/avatar-3.webp' alt='यूज़र' />
          </div>
          <p><strong>50,000+</strong> खुश उपयोगकर्ता हमारे साथ</p>
        </div>
      </div>

      <!-- Poster preview cards -->
      <div class='hero-art'>
        <figure class='poster-preview p-main'>
          <img src={heroPreviews[0].img} alt={heroPreviews[0].title} loading='eager' />
          <figcaption>{heroPreviews[0].title}</figcaption>
        </figure>
        <figure class='poster-preview p-top'>
          <img src={heroPreviews[1].img} alt={heroPreviews[1].title} loading='eager' />
        </figure>
        <figure class='poster-preview p-bottom'>
          <img src={heroPreviews[2].img} alt={heroPreviews[2].title} loading='eager' />
        </figure>
        <span class='hd-badge'><Icon name='download' size={16} /> HD डाउनलोड बिना वाटरमार्क</span>
      </div>
    </div>
  </section>

  <!-- ===================== CATEGORIES ===================== -->
  <section class='section cat-section'>
    <div class='container'>
      <div class='section-head'>
        <h2 class='deco'>लोकप्रिय श्रेणियां</h2>
      </div>
      <div class='cat-grid'>
        {categories.map((c) => (
          <a href={'/categories/' + c.slug} class='cat-card'>
            <span class='cat-icon' style={'color:' + c.color + ';background:' + c.bg}>
              <Icon name={c.icon} size={26} />
            </span>
            <span class='cat-name'>{c.name}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== PRO STRIP ===================== -->
  <section class='container'>
    <div class='pro-strip'>
      <div class='pro-strip-title'>
        <Icon name='crown' size={22} />
        <strong>Pro प्लान के फायदे</strong>
      </div>
      <ul class='pro-perks'>
        {proPerks.map((p) => (
          <li><Icon name={p.icon} size={18} /> {p.text}</li>
        ))}
      </ul>
      <a href='/pricing' class='btn btn-primary btn-sm'>Pro प्लान देखें</a>
    </div>
  </section>

  <!-- ===================== HOW IT WORKS ===================== -->
  <section class='section'>
    <div class='container'>
      <div class='section-head'>
        <h2 class='deco'>पोस्टर बनाना अब हुआ बहुत आसान</h2>
      </div>
      <div class='steps-grid'>
        {steps.map((s, i) => (
          <div class='step-wrap'>
            <div class='step-card'>
              <span class='step-no'>{s.no}</span>
              <span class='step-icon'><Icon name={s.icon} size={22} /></span>
              <h4>{s.title}</h4>
              <p>{s.desc}</p>
            </div>
            {i < steps.length - 1 && <span class='step-arrow'><Icon name='arrow-right' size={20} /></span>}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== TEMPLATES ===================== -->
  <section class='section'>
    <div class='container'>
      <div class='row-head'>
        <h2>लोकप्रिय पोस्टर टेम्पलेट्स</h2>
        <a href='/posters' class='see-all'>सभी देखें <Icon name='arrow-right' size={16} /></a>
      </div>
      <div class='tpl-grid'>
        {templates.map((t) => (
          <article class='tpl-card card'>
            <div class='tpl-thumb'>
              <img src={t.img} alt={t.title} loading='lazy' />
              <span class={'badge ' + (t.type === 'pro' ? 'badge-pro' : 'badge-free')}>
                {t.type === 'pro' ? 'Pro' : 'फ्री'}
              </span>
            </div>
            <div class='tpl-body'>
              <h4>{t.title}</h4>
              <span class='tpl-cat'>{t.category}</span>
              <a href='/posters' class='btn btn-primary btn-sm tpl-btn'><Icon name='edit' size={15} /> एडिट करें</a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== STATS BAR ===================== -->
  <section class='container'>
    <div class='stats-bar'>
      {stats.map((s) => (
        <div class='stat'>
          <span class='stat-icon'><Icon name={s.icon} size={22} /></span>
          <div>
            <span class='stat-value'>{s.value}</span>
            <span class='stat-label'>{s.label}</span>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ===================== PRO UPSELL + NEWSLETTER ===================== -->
  <section class='section'>
    <div class='container upsell-grid'>
      <div class='upsell'>
        <div class='upsell-title'><Icon name='crown' size={26} /> <h3>Pro बनें और अनलिमिटेड सुविधाओं का आनंद लें</h3></div>
        <ul class='upsell-list'>
          {proUpsell.map((t) => (
            <li><Icon name='check' size={16} /> {t}</li>
          ))}
        </ul>
        <div class='upsell-cta'>
          <a href='/pricing' class='btn btn-gold btn-lg'>Pro प्लान देखें</a>
          <span class='upsell-price'>मात्र {pricing.currency}{pricing.yearly} / साल से शुरू</span>
        </div>
      </div>

      <div class='newsletter'>
        <h4>न्यूज़लेटर सब्सक्राइब करें</h4>
        <p>नए पोस्टर, ऑफर और अपडेट की जानकारी पाएं</p>
        <form class='newsletter-row' onsubmit='return false'>
          <input type='email' placeholder='अपना ईमेल डालें' required aria-label='ईमेल' />
          <button class='btn btn-primary'><Icon name='send' size={16} /> सब्सक्राइब</button>
        </form>
        <p class='newsletter-note'>हम आपका डेटा सुरक्षित रखते हैं। स्पैम नहीं भेजेंगे।</p>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ---------- HERO ---------- */
  .hero { padding: 48px 0 36px; background: radial-gradient(1100px 480px at 78% -8%, #EDE9FE 0%, transparent 62%); overflow: hidden; }
  .hero-grid { display: grid; grid-template-columns: 1.02fr .98fr; gap: 44px; align-items: center; }
  .hero-copy h1 { font-size: 42px; line-height: 1.2; font-weight: 800; letter-spacing: -.4px; }
  .hero-sub { margin-top: 16px; font-size: 16.5px; color: var(--muted); max-width: 520px; }
  .eyebrow { display: inline-flex; align-items: center; gap: 6px; }
  .eyebrow :global(.icon) { color: var(--gold); }

  .trust { display: flex; flex-wrap: wrap; gap: 10px; margin: 22px 0; }
  .trust li { display: inline-flex; align-items: center; gap: 7px; font-size: 13.5px; font-weight: 600; background: #fff; border: 1px solid var(--line); padding: 8px 14px; border-radius: 999px; box-shadow: var(--shadow-sm); }
  .trust :global(.icon) { color: var(--purple); }

  .hero-cta { display: flex; flex-wrap: wrap; gap: 14px; }
  .cta-stack { flex-direction: column; align-items: flex-start; gap: 1px; padding: 12px 26px; line-height: 1.25; }
  .cta-main { display: inline-flex; align-items: center; gap: 8px; font-size: 16px; }
  .cta-sub { font-size: 12px; font-weight: 500; opacity: .85; }

  .social-proof { display: flex; align-items: center; gap: 12px; margin-top: 26px; }
  .avatars { display: flex; }
  .avatars img { width: 40px; height: 40px; border-radius: 50%; border: 2px solid #fff; object-fit: cover; margin-left: -12px; background: #ddd; }
  .avatars img:first-child { margin-left: 0; }
  .social-proof p { font-size: 14px; color: var(--muted); }

  /* Poster previews */
  .hero-art { position: relative; min-height: 440px; }
  .poster-preview { position: absolute; border-radius: 18px; overflow: hidden; box-shadow: var(--shadow); background: #fff; border: 4px solid #fff; }
  .poster-preview img { object-fit: cover; width: 100%; background: linear-gradient(135deg,#EDE9FE,#E0E7FF); }
  .poster-preview figcaption { position: absolute; left: 0; right: 0; bottom: 0; padding: 10px 12px; font-size: 13px; font-weight: 700; color: #fff; background: linear-gradient(transparent, rgba(0,0,0,.55)); }
  .p-main { width: 62%; left: 2%; top: 4%; z-index: 2; }
  .p-main img { aspect-ratio: 3/4; }
  .p-top { width: 34%; right: 2%; top: 0; z-index: 1; transform: rotate(4deg); }
  .p-top img { aspect-ratio: 3/4; }
  .p-bottom { width: 30%; right: 6%; top: 40%; z-index: 3; transform: rotate(-3deg); }
  .p-bottom img { aspect-ratio: 3/4; }
  .hd-badge { position: absolute; right: 8%; bottom: 6%; z-index: 4; display: inline-flex; align-items: center; gap: 6px; background: var(--grad); color: #fff; font-size: 12.5px; font-weight: 700; padding: 9px 14px; border-radius: 999px; box-shadow: var(--shadow); }

  /* ---------- SECTION HEAD DECO ---------- */
  .deco { display: inline-flex; align-items: center; gap: 14px; }
  .deco::before, .deco::after { content: ''; width: 40px; height: 2px; background: linear-gradient(90deg, transparent, var(--purple)); }
  .deco::after { background: linear-gradient(90deg, var(--purple), transparent); }

  /* ---------- CATEGORIES ---------- */
  .cat-section { background: #fff; border-radius: 28px; margin: 10px auto; box-shadow: var(--shadow-sm); }
  .cat-grid { display: grid; grid-template-columns: repeat(9, 1fr); gap: 14px; }
  .cat-card { display: flex; flex-direction: column; align-items: center; gap: 10px; padding: 20px 8px; border-radius: 16px; border: 1px solid var(--line); background: var(--bg); text-align: center; transition: transform .2s, box-shadow .2s; }
  .cat-card:hover { transform: translateY(-4px); box-shadow: var(--shadow); background: #fff; }
  .cat-icon { display: grid; place-items: center; width: 56px; height: 56px; border-radius: 16px; }
  .cat-name { font-weight: 700; font-size: 13.5px; }

  /* ---------- PRO STRIP ---------- */
  .pro-strip { display: flex; align-items: center; gap: 20px; flex-wrap: wrap; background: linear-gradient(135deg,#FEF6E0,#FDF0F5); border: 1px solid #F5E6C8; border-radius: 18px; padding: 18px 24px; margin-top: 10px; }
  .pro-strip-title { display: inline-flex; align-items: center; gap: 8px; font-size: 16px; white-space: nowrap; }
  .pro-strip-title :global(.icon) { color: var(--gold); }
  .pro-perks { display: flex; flex-wrap: wrap; gap: 10px 22px; flex: 1; }
  .pro-perks li { display: inline-flex; align-items: center; gap: 7px; font-size: 14px; font-weight: 600; }
  .pro-perks :global(.icon) { color: var(--purple); }

  /* ---------- STEPS ---------- */
  .steps-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; }
  .step-wrap { position: relative; display: flex; align-items: stretch; }
  .step-card { position: relative; flex: 1; padding: 26px 20px; background: #fff; border: 1px solid var(--line); border-radius: 16px; box-shadow: var(--shadow-sm); }
  .step-no { position: absolute; top: 16px; right: 18px; display: grid; place-items: center; width: 30px; height: 30px; border-radius: 50%; background: var(--grad); color: #fff; font-weight: 800; font-size: 14px; }
  .step-icon { display: grid; place-items: center; width: 48px; height: 48px; border-radius: 14px; background: #EDE9FE; color: var(--purple); }
  .step-card h4 { margin: 14px 0 6px; font-size: 16px; }
  .step-card p { font-size: 13.5px; color: var(--muted); }
  .step-arrow { display: grid; place-items: center; width: 30px; color: #C4B5FD; flex-shrink: 0; }

  /* ---------- TEMPLATES ROW ---------- */
  .row-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 26px; }
  .row-head h2 { font-size: 26px; font-weight: 800; }
  .see-all { display: inline-flex; align-items: center; gap: 5px; color: var(--purple); font-weight: 700; font-size: 15px; }
  .tpl-grid { display: grid; grid-template-columns: repeat(6, 1fr); gap: 16px; }
  .tpl-thumb { position: relative; }
  .tpl-thumb img { aspect-ratio: 3/4; object-fit: cover; width: 100%; border-radius: var(--radius) var(--radius) 0 0; background: linear-gradient(135deg,#EDE9FE,#E0E7FF); }
  .tpl-thumb .badge { position: absolute; top: 10px; left: 10px; }
  .tpl-body { padding: 12px 12px 16px; }
  .tpl-body h4 { font-size: 14px; }
  .tpl-cat { display: block; font-size: 12px; color: var(--muted); margin: 3px 0 12px; }
  .tpl-btn { width: 100%; gap: 6px; }

  /* ---------- STATS ---------- */
  .stats-bar { display: grid; grid-template-columns: repeat(5, 1fr); gap: 16px; background: var(--dark); color: #fff; border-radius: 20px; padding: 30px 26px; }
  .stat { display: flex; align-items: center; gap: 14px; }
  .stat-icon { display: grid; place-items: center; width: 46px; height: 46px; border-radius: 12px; background: rgba(255,255,255,.1); color: #C4B5FD; flex-shrink: 0; }
  .stat-value { display: block; font-size: 24px; font-weight: 800; }
  .stat-label { font-size: 13px; color: #b9b3d6; }

  /* ---------- UPSELL + NEWSLETTER ---------- */
  .upsell-grid { display: grid; grid-template-columns: 1.15fr 1fr; gap: 22px; }
  .upsell { background: var(--grad); color: #fff; border-radius: 22px; padding: 32px; }
  .upsell-title { display: flex; align-items: center; gap: 10px; margin-bottom: 20px; }
  .upsell-title :global(.icon) { color: var(--gold); }
  .upsell-title h3 { font-size: 22px; font-weight: 800; }
  .upsell-list { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 24px; }
  .upsell-list li { display: flex; align-items: center; gap: 8px; font-size: 14px; font-weight: 500; }
  .upsell-list :global(.icon) { color: var(--gold); flex-shrink: 0; }
  .upsell-cta { display: flex; align-items: center; gap: 16px; flex-wrap: wrap; }
  .upsell-price { font-size: 14px; opacity: .9; }

  .newsletter { background: #fff; border: 1px solid var(--line); border-radius: 22px; padding: 32px; box-shadow: var(--shadow-sm); }
  .newsletter h4 { font-size: 20px; font-weight: 800; }
  .newsletter > p { color: var(--muted); font-size: 14px; margin: 8px 0 20px; }
  .newsletter-row { display: flex; gap: 8px; }
  .newsletter-row input { flex: 1; border: 1px solid var(--line); border-radius: 999px; padding: 12px 16px; font-family: inherit; font-size: 14px; outline: none; }
  .newsletter-row input:focus { border-color: var(--purple); }
  .newsletter-row .btn { gap: 6px; }
  .newsletter-note { font-size: 12.5px; color: var(--muted); margin-top: 14px; }

  /* ---------- RESPONSIVE ---------- */
  @media (max-width: 1024px) {
    .hero-copy h1 { font-size: 34px; }
    .cat-grid { grid-template-columns: repeat(5, 1fr); }
    .tpl-grid { grid-template-columns: repeat(3, 1fr); }
    .steps-grid { grid-template-columns: repeat(2, 1fr); }
    .step-wrap:nth-child(2) .step-arrow { display: none; }
    .stats-bar { grid-template-columns: repeat(3, 1fr); gap: 22px; }
  }
  @media (max-width: 900px) {
    .hero-grid { grid-template-columns: 1fr; }
    .hero-art { min-height: 400px; margin-top: 6px; }
    .upsell-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 620px) {
    .hero-copy h1 { font-size: 28px; }
    .hero-sub { font-size: 15px; }
    .hero-cta .btn { flex: 1; }
    .cat-grid { grid-template-columns: repeat(3, 1fr); }
    .tpl-grid { grid-template-columns: repeat(2, 1fr); }
    .steps-grid { grid-template-columns: 1fr; }
    .step-arrow { display: none !important; }
    .stats-bar { grid-template-columns: 1fr; }
    .upsell-list { grid-template-columns: 1fr; }
    .row-head h2 { font-size: 21px; }
    .newsletter-row { flex-direction: column; }
    .newsletter-row .btn { width: 100%; justify-content: center; }
  }
  @media (max-width: 400px) {
    .cat-grid { grid-template-columns: repeat(2, 1fr); }
    .tpl-grid { grid-template-columns: 1fr; }
  }
</style>
