---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
import { heroPreviews, categories } from '../data/site.js';

const plans = [
  {
    name: 'Free', price: '₹0', period: 'हमेशा फ्री', tone: 'free', icon: 'image',
    description: 'शुरुआत करने और रोज़ के पोस्टर बनाने के लिए।',
    items: ['फ्री पोस्टर टेम्पलेट्स', 'नाम, फोटो और प्रोफेशन जोड़ें', 'JPG डाउनलोड और शेयर', 'डाउनलोड पर Daily PosterHub वाटरमार्क'],
    cta: 'फ्री में शुरू करें', href: '/posters',
  },
  {
    name: 'Pro', price: '₹21', period: 'प्रति माह', tone: 'pro', icon: 'crown', badge: 'सबसे लोकप्रिय',
    description: 'व्यक्तिगत ब्रांडिंग और साफ़ HD पोस्टर के लिए।',
    items: ['Free प्लान की सभी सुविधाएं', 'बिना वाटरमार्क डाउनलोड', 'HD क्वालिटी एक्सपोर्ट', 'प्रीमियम टेम्पलेट एक्सेस', 'अनलिमिटेड डाउनलोड'],
    cta: 'Pro प्लान लें', href: '/payment?plan=monthly',
  },
  {
    name: 'Business', price: '₹299', period: 'प्रति वर्ष', tone: 'business', icon: 'briefcase',
    description: 'दुकान, एजेंसी और रोज़ की सोशल मीडिया branding के लिए।',
    items: ['Pro प्लान की सभी सुविधाएं', 'अपना logo और business branding', 'ब्रांडिंग strip हटाने का विकल्प', 'बिज़नेस-फोकस्ड पोस्टर workflow'],
    cta: 'Business शुरू करें', href: '/payment?plan=yearly',
  },
];

const showcaseTemplates = [
  { img: heroPreviews[0].img, title: 'सुप्रभात', category: 'गुड मॉर्निंग', type: 'free' },
  { img: heroPreviews[1].img, title: 'जन्मदिन शुभकामनाएं', category: 'जन्मदिन', type: 'pro' },
  { img: heroPreviews[2].img, title: 'जय श्री राम', category: 'धार्मिक', type: 'free' },
  { img: heroPreviews[0].img, title: 'आज का संदेश', category: 'शुभकामनाएं', type: 'pro' },
  { img: heroPreviews[1].img, title: 'खास अवसर', category: 'शुभकामनाएं', type: 'free' },
  { img: heroPreviews[2].img, title: 'धार्मिक पोस्टर', category: 'त्योहार', type: 'pro' },
];

const faqs = [
  ['क्या मैं फ्री में पोस्टर डाउनलोड कर सकता/सकती हूँ?', 'हाँ। Free प्लान में पोस्टर बनाना और डाउनलोड करना फ्री है। डाउनलोड की गई image पर Daily PosterHub का watermark रहेगा।'],
  ['Pro प्लान में क्या मिलेगा?', 'Pro में watermark हट जाता है, HD export मिलता है और premium templates का access मिलता है। इसकी कीमत ₹21 प्रति माह या ₹99 प्रति वर्ष है।'],
  ['Business प्लान किसके लिए है?', 'दुकानदार, एजेंसियां और नियमित social-media posting करने वाले लोग Business प्लान में अपना logo और branding इस्तेमाल कर सकते हैं। इसकी कीमत ₹299 प्रति वर्ष है।'],
  ['पोस्टर बनाने के लिए क्या install करना होगा?', 'कुछ भी install नहीं करना है। Browser में template चुनें, नाम या फोटो जोड़ें और poster डाउनलोड या share करें।'],
];
---
<Layout title='हिंदी पोस्टर बनाएं — Daily PosterHub' description='नाम, फोटो और संदेश जोड़कर सुंदर हिंदी पोस्टर बनाएं। फ्री पोस्टर डाउनलोड करें या Pro और Business प्लान से बिना watermark HD पोस्टर पाएं।'>
  <script is:inline>
    fetch('/api/auth/me').then(function (r) { return r.json(); }).then(function (d) {
      if (d && d.user) window.location.replace('/posters/');
    }).catch(function () {});
  </script>

  <section class='hero'>
    <div class='hero-orb orb-one'></div><div class='hero-orb orb-two'></div>
    <div class='container hero-grid'>
      <div class='hero-copy reveal'>
        <span class='eyebrow hero-eyebrow'><Icon name='sparkles' size={15} /> हर दिन के लिए नया डिज़ाइन</span>
        <h1>अपनी पहचान के साथ<br /><span>शानदार हिंदी पोस्टर</span> बनाएं</h1>
        <p class='hero-sub'>नाम, फोटो, profession और संदेश जोड़ें। कुछ ही मिनटों में social media और WhatsApp के लिए तैयार पोस्टर डाउनलोड करें।</p>
        <div class='hero-actions'>
          <a href='/posters' class='btn btn-primary btn-lg'><Icon name='edit' size={18} /> फ्री पोस्टर बनाएं <Icon name='arrow-right' size={17} /></a>
          <a href='#plans' class='text-link'>प्लान और कीमत देखें <Icon name='arrow-right' size={16} /></a>
        </div>
        <div class='hero-points'>
          <span><Icon name='check' size={17} /> मोबाइल पर आसान</span>
          <span><Icon name='check' size={17} /> तुरंत डाउनलोड</span>
          <span><Icon name='check' size={17} /> कोई app नहीं चाहिए</span>
        </div>
      </div>

      <div class='hero-visual reveal'>
        <div class='hero-ring ring-a'></div><div class='hero-ring ring-b'></div>
        <div class='poster-card main-poster'>
          <img src={heroPreviews[0].img} alt='सुप्रभात हिंदी पोस्टर का उदाहरण' loading='eager' />
          <div class='poster-caption'><span class='caption-dot'></span> आपका नाम, आपकी पहचान</div>
        </div>
        <div class='poster-card side-poster top-poster'><img src={heroPreviews[1].img} alt='जन्मदिन पोस्टर का उदाहरण' loading='eager' /></div>
        <div class='poster-card side-poster bottom-poster'><img src={heroPreviews[2].img} alt='धार्मिक पोस्टर का उदाहरण' loading='eager' /></div>
        <div class='floating-chip chip-edit'><Icon name='edit' size={16} /> आसान एडिटिंग</div>
        <div class='floating-chip chip-hd'><Icon name='download' size={16} /> HD डाउनलोड</div>
      </div>
    </div>
  </section>

  <section class='quick-bar-wrap'>
    <div class='container quick-bar reveal'>
      <div><span class='quick-icon'><Icon name='image' size={20} /></span><p><strong>टेम्पलेट चुनें</strong><small>अपनी पसंद का design</small></p></div>
      <span class='quick-line'></span>
      <div><span class='quick-icon'><Icon name='edit' size={20} /></span><p><strong>अपनी details जोड़ें</strong><small>नाम, फोटो, profession</small></p></div>
      <span class='quick-line'></span>
      <div><span class='quick-icon'><Icon name='download' size={20} /></span><p><strong>डाउनलोड या शेयर करें</strong><small>कुछ ही clicks में</small></p></div>
    </div>
  </section>

  <section class='section categories-section'>
    <div class='container'>
      <div class='section-intro reveal'>
        <span class='section-kicker'>हर मौके के लिए</span>
        <h2>आज किस तरह का पोस्टर बनाना है?</h2>
        <p>गुड मॉर्निंग से लेकर बिज़नेस ऑफर तक—अपनी category चुनें और अपना design तैयार करें।</p>
      </div>
      <div class='category-grid'>
        {categories.filter((c) => c.slug !== 'all').map((c) => (
          <a href={'/categories/' + c.slug} class='category-card reveal'>
            <span class='category-icon' style={'background:' + c.bg + ';color:' + c.color}><Icon name={c.icon} size={23} /></span>
            <span>{c.name}</span><Icon name='arrow-right' size={16} />
          </a>
        ))}
      </div>
      <div class='center-action'><a class='btn btn-outline' href='/categories'>सभी categories देखें <Icon name='arrow-right' size={16} /></a></div>
    </div>
  </section>

  <section class='section workflow-section'>
    <div class='container workflow-grid'>
      <div class='workflow-copy reveal'>
        <span class='section-kicker'>तेज़ और आसान</span>
        <h2>पोस्टर बनाने का आसान तरीका</h2>
        <p>Designing का अनुभव नहीं है? कोई समस्या नहीं। हमारा simple editor आपको हर step पर guide करता है।</p>
        <a href='/posters' class='btn btn-primary'>पोस्टर चुनें <Icon name='arrow-right' size={16} /></a>
      </div>
      <div class='workflow-steps reveal'>
        <article><span class='step-number'>01</span><div><h3>टेम्पलेट चुनें</h3><p>अपने अवसर के मुताबिक कोई design select करें।</p></div><span class='step-icon'><Icon name='image' size={20} /></span></article>
        <article><span class='step-number'>02</span><div><h3>अपना content जोड़ें</h3><p>नाम, फोटो, profession या छोटा message लिखें।</p></div><span class='step-icon'><Icon name='edit' size={20} /></span></article>
        <article><span class='step-number'>03</span><div><h3>तैयार poster डाउनलोड करें</h3><p>JPG में save करें या WhatsApp पर सीधे share करें।</p></div><span class='step-icon'><Icon name='download' size={20} /></span></article>
      </div>
    </div>
  </section>

  <section class='section template-section'>
    <div class='container'>
      <div class='row-heading reveal'><div><span class='section-kicker'>लोकप्रिय designs</span><h2>तुरंत शुरू करने के लिए टेम्पलेट्स</h2></div><a href='/posters' class='text-link desktop-link'>सभी पोस्टर देखें <Icon name='arrow-right' size={16} /></a></div>
      <div class='template-grid'>
        {showcaseTemplates.map((t) => (
          <article class='template-card reveal'>
            <div class='template-image'><img src={t.img} alt={t.title} loading='lazy' /><span class={'plan-tag ' + t.type}>{t.type === 'pro' ? 'PRO' : 'FREE'}</span><a href='/posters' aria-label={t.title + ' edit करें'} class='template-edit'><Icon name='edit' size={17} /></a></div>
            <div class='template-info'><h3>{t.title}</h3><p>{t.category}</p></div>
          </article>
        ))}
      </div>
      <div class='center-action mobile-link'><a class='btn btn-outline' href='/posters'>सभी पोस्टर देखें <Icon name='arrow-right' size={16} /></a></div>
    </div>
  </section>

  <section class='plans-section' id='plans'>
    <div class='container'>
      <div class='section-intro light reveal'><span class='section-kicker'>सरल और साफ़ कीमत</span><h2>अपनी जरूरत का सही प्लान चुनें</h2><p>पहले Free में शुरू करें या बिना watermark और branding के लिए upgrade करें।</p></div>
      <div class='plan-grid'>
        {plans.map((plan) => (
          <article class={'plan-card ' + plan.tone + ' reveal'}>
            {plan.badge && <span class='popular-badge'><Icon name='star' size={13} /> {plan.badge}</span>}
            <div class='plan-top'><span class='plan-icon'><Icon name={plan.icon} size={22} /></span><h3>{plan.name}</h3><p>{plan.description}</p></div>
            <div class='price'><strong>{plan.price}</strong><span>{plan.period}</span></div>
            {plan.name === 'Pro' && <p class='yearly-note'>या सिर्फ़ <b>₹99 / वर्ष</b> में</p>}
            <a href={plan.cta === 'Pro प्लान लें' ? '/pricing' : plan.href} class={'btn plan-button ' + (plan.tone === 'free' ? 'btn-outline' : 'btn-primary')}>{plan.cta} <Icon name='arrow-right' size={16} /></a>
            <ul>{plan.items.map((item) => <li><Icon name='check' size={16} /> {item}</li>)}</ul>
          </article>
        ))}
      </div>
      <p class='plans-note reveal'>सभी भुगतान पहले verify किए जाते हैं। Upgrade के बाद आपका plan account में activate कर दिया जाता है।</p>
    </div>
  </section>

  <section class='section trust-section'>
    <div class='container trust-grid'>
      <div class='trust-copy reveal'><span class='section-kicker'>आपके लिए बनाया गया</span><h2>रोज़ के पोस्टर काम को सरल बनाइए</h2><p>शुभकामनाएं, त्योहार, दुकान offers और social posts—अब हर design के लिए किसी designer का इंतज़ार नहीं।</p><a href='/pricing' class='text-link'>सभी plan सुविधाएं देखें <Icon name='arrow-right' size={16} /></a></div>
      <div class='benefit-grid reveal'>
        <div><span><Icon name='smartphone' size={21} /></span><h3>Mobile-first</h3><p>फोन पर आराम से इस्तेमाल करें।</p></div>
        <div><span><Icon name='shield' size={21} /></span><h3>सुरक्षित account</h3><p>अपना account और plan आसानी से manage करें।</p></div>
        <div><span><Icon name='infinity' size={21} /></span><h3>बार-बार इस्तेमाल</h3><p>जब चाहें नया poster बनाइए।</p></div>
        <div><span><Icon name='headphones' size={21} /></span><h3>सहायता</h3><p>सवाल हो तो Help Center देखें।</p></div>
      </div>
    </div>
  </section>

  <section class='section faq-section'>
    <div class='container faq-grid'>
      <div class='faq-copy reveal'><span class='section-kicker'>सवाल-जवाब</span><h2>जानने योग्य बातें</h2><p>पहली बार poster बना रहे हैं? ये quick answers आपकी मदद करेंगे।</p><a href='/help' class='btn btn-outline'>Help Center <Icon name='arrow-right' size={16} /></a></div>
      <div class='faq-list reveal'>{faqs.map(([q, a]) => <details><summary>{q}<Icon name='arrow-right' size={18} /></summary><p>{a}</p></details>)}</div>
    </div>
  </section>

  <section class='final-cta'>
    <div class='container final-inner reveal'><div><span class='section-kicker'>आज ही शुरू करें</span><h2>अपने अगले पोस्टर को यादगार बनाइए</h2><p>Template चुनें, अपनी details जोड़ें और तैयार design तुरंत डाउनलोड करें।</p></div><a href='/posters' class='btn btn-white btn-lg'>फ्री पोस्टर बनाएं <Icon name='arrow-right' size={18} /></a></div>
  </section>
</Layout>

<style>
  .hero { position:relative; overflow:hidden; padding:76px 0 86px; background:linear-gradient(135deg,#fbfaff 0%,#f0edff 52%,#e6edff 100%); }
  .hero-orb { position:absolute; border-radius:50%; pointer-events:none; filter:blur(1px); opacity:.65; }.orb-one { width:380px;height:380px;right:-160px;top:-120px;background:#d9d0ff; }.orb-two { width:240px;height:240px;left:42%;bottom:-180px;background:#cde5ff; }
  .hero-grid { display:grid;grid-template-columns:1.05fr .95fr;gap:56px;align-items:center;position:relative;z-index:1; }.hero-copy h1 { max-width:680px;font-size:clamp(39px,4.3vw,60px);font-weight:800;line-height:1.12;letter-spacing:-1.8px; }.hero-copy h1 span { color:var(--purple); }.hero-sub { max-width:590px;margin-top:21px;font-size:17px;color:var(--muted);line-height:1.75; }.hero-eyebrow { margin-bottom:19px;box-shadow:0 4px 14px rgba(124,58,237,.1); }.hero-actions { display:flex;align-items:center;gap:22px;margin-top:30px; }.text-link { display:inline-flex;align-items:center;gap:7px;color:var(--purple);font-size:15px;font-weight:800; }.text-link:hover { gap:11px; }.hero-points { display:flex;flex-wrap:wrap;gap:12px 20px;margin-top:27px;color:#504d65;font-size:13px;font-weight:700; }.hero-points span { display:inline-flex;align-items:center;gap:6px; }.hero-points :global(.icon) { color:#27a16b; }
  .hero-visual { min-height:490px;position:relative; }.hero-ring { position:absolute;border:1px solid rgba(124,58,237,.14);border-radius:50%; }.ring-a { width:410px;height:410px;right:5%;top:28px; }.ring-b { width:325px;height:325px;right:18%;top:70px;border-style:dashed;animation:spin 30s linear infinite; }.poster-card { position:absolute;overflow:hidden;background:#fff;border:5px solid #fff;border-radius:22px;box-shadow:0 24px 50px rgba(64,45,112,.17); }.poster-card img { width:100%;height:100%;object-fit:cover; }.main-poster { width:245px;aspect-ratio:3/4;left:17%;top:10px;z-index:2;animation:float 6s ease-in-out infinite; }.side-poster { width:145px;aspect-ratio:3/4; }.top-poster { right:3%;top:38px;transform:rotate(8deg);animation:float 7s 1s ease-in-out infinite; }.bottom-poster { right:5%;bottom:29px;transform:rotate(-7deg);animation:float 6.3s .6s ease-in-out infinite; }.poster-caption { position:absolute;bottom:0;left:0;right:0;padding:12px 13px;background:linear-gradient(transparent,rgba(20,15,45,.86));color:#fff;font-size:12px;font-weight:700; }.caption-dot { display:inline-block;width:7px;height:7px;margin-right:5px;border-radius:50%;background:#7cf0b1; }.floating-chip { position:absolute;z-index:4;display:flex;align-items:center;gap:7px;padding:10px 13px;border-radius:12px;background:rgba(255,255,255,.94);box-shadow:0 12px 28px rgba(42,31,85,.12);font-size:12px;font-weight:800;color:#494360;backdrop-filter:blur(8px); }.floating-chip :global(.icon) { color:var(--purple); }.chip-edit { left:2%;bottom:71px;animation:float 5s .5s ease-in-out infinite; }.chip-hd { right:0;top:202px;animation:float 5.7s 1.2s ease-in-out infinite; }
  .quick-bar-wrap { margin-top:-32px;position:relative;z-index:3; }.quick-bar { display:grid;grid-template-columns:1fr auto 1fr auto 1fr;align-items:center;background:#fff;border:1px solid var(--line);border-radius:18px;padding:19px 27px;box-shadow:0 16px 44px rgba(42,31,85,.1); }.quick-bar>div { display:flex;align-items:center;justify-content:center;gap:12px; }.quick-bar p { display:grid;line-height:1.3;font-size:14px; }.quick-bar small { margin-top:3px;color:var(--muted);font-size:12px; }.quick-icon { display:grid;place-items:center;width:42px;height:42px;border-radius:12px;background:#f0ecff;color:var(--purple); }.quick-line { height:34px;width:1px;background:var(--line); }
  .section { padding:92px 0; }.section-intro { max-width:690px;margin:0 auto 45px;text-align:center; }.section-kicker { display:inline-block;margin-bottom:10px;color:var(--purple);font-size:12px;font-weight:800;letter-spacing:.08em;text-transform:uppercase; }.section-intro h2,.row-heading h2,.workflow-copy h2,.trust-copy h2,.faq-copy h2 { font-size:clamp(28px,3.2vw,40px);font-weight:800;line-height:1.18;letter-spacing:-.8px; }.section-intro p,.workflow-copy>p,.trust-copy>p,.faq-copy>p { margin-top:14px;color:var(--muted);font-size:16px;line-height:1.75; }
  .categories-section { background:#fff; }.category-grid { display:grid;grid-template-columns:repeat(4,1fr);gap:14px; }.category-card { display:flex;align-items:center;gap:12px;min-height:79px;padding:14px 16px;border:1px solid var(--line);border-radius:14px;background:#fff;font-size:14px;font-weight:800;transition:.22s ease; }.category-card:hover { transform:translateY(-4px);border-color:#cabdff;box-shadow:0 15px 24px rgba(75,48,150,.1); }.category-card>:last-child { margin-left:auto;color:#a9a4bb; }.category-icon { display:grid;place-items:center;width:43px;height:43px;border-radius:12px;flex:none; }.center-action { margin-top:31px;text-align:center; }
