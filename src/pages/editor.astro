---
import Layout from '../layouts/Layout.astro';
---
<Layout title='पोस्टर एडिटर — Daily PosterHub'>
  <section class='ed-wrap'>
    <div class='ed-grid'>

      <!-- STAGE -->
      <div class='ed-stage-col'>
        <div class='stage-frame'>
          <div class='capture' id='capture'>

            <!-- TOP strip: website branding image (free plan, outside image) -->
            <img class='brand-top' id='brandStrip' src='/img/branding.webp' alt='DailyPosterHub' crossorigin='anonymous' />

            <!-- POSTER + photo circle only -->
            <div class='stage' id='stage'>
              <img id='posterImg' class='poster-img' alt='poster' crossorigin='anonymous' />
              <img id='brandOverlay' class='brand-overlay' alt='branding' />
              <img id='wmMark' class='wm-mark show' src='/img/watermark.png' alt='watermark' crossorigin='anonymous' />
              <div class='photo-circle empty' id='photoCircle'>फोटो</div>
            </div>

            <!-- BOTTOM strip: name + number (outside image) -->
            <div class='name-strip' id='nameStrip'>
              <b id='nsName'>आपका नाम</b>
              <span id='nsProf'>प्रोफेशन</span>
            </div>
          </div>
        </div>

        <!-- resize control OUTSIDE the image -->
        <div class='stage-controls'>
          <div class='sc-row'><span>फोटो साइज़</span><input id='sizeRange' type='range' min='22' max='85' value='45' /></div>
          <div class='sc-row' id='brandCtl' style='display:none'><span>ब्रांडिंग साइज़</span><input id='brandRange' type='range' min='20' max='95' value='55' /></div>
          <p class='sc-hint'>फोटो को उंगली/माउस से खींचकर गोल फ्रेम पर रखें, स्लाइडर से छोटा-बड़ा करें।</p>
        </div>
      </div>

      <!-- INFO PANEL -->
      <div class='ed-panel'>
        <h1>पोस्टर एडिट करें</h1>
        <p class='ed-sub'>अपनी फोटो, नाम और नंबर डालें। फोटो गोल फ्रेम पर आ जाएगी—खींचकर जमाएं। नाम/नंबर पोस्टर के नीचे अलग पट्टी में आएगा।</p>

        <div class='ed-kitbox'>
          <div class='ed-seltitle'>आपकी जानकारी</div>
          <label class='ed-fld'>फोटो<input id='inPhoto' type='file' accept='image/*' /></label>
          <label class='ed-fld'>नाम<input id='inName' type='text' placeholder='आपका नाम' /></label>
          <label class='ed-fld'>प्रोफेशन (छोटा टेक्स्ट)<input id='inProf' type='text' placeholder='जैसे: फोटोग्राफर / बिज़नेस' /></label>
          <button id='saveKit' class='btn btn-gold btn-sm'>जानकारी सेव करें</button>
        </div>

        <div class='ed-download'>
          <button id='btnDownload' class='btn btn-primary btn-lg'>⬇ डाउनलोड करें</button>
          <button id='btnShare' class='btn btn-gold btn-lg'>WhatsApp पर शेयर</button>
        </div>
        <p class='ed-note' id='proNote'>फ्री प्लान में ऊपर वेबसाइट ब्रांडिंग पट्टी रहेगी। <a href='/payment'>Pro लें</a> — बिना ब्रांडिंग और HD डाउनलोड।</p>
        <p class='ed-dlcount' id='dlCount' style='display:none'></p>
      </div>
    </div>
  </section>
</Layout>

<div class='adgate' id='adGate'>
  <div class='adgate-box'>
    <button class='adgate-close' id='adClose' aria-label='बंद करें'>×</button>
    <p class='adgate-h'>आपका पोस्टर तैयार हो रहा है…</p>
    <div class='adgate-ad'>
      <span class='adgate-adlabel'>विज्ञापन</span>
      <p class='adgate-adtxt'>Ad यहाँ दिखेगा</p>
    </div>
    <div class='adgate-bar'><i id='adBar'></i></div>
    <p class='adgate-timer'><b id='adCountdown'>10</b> सेकंड में डाउनलोड शुरू होगा…</p>
    <a class='adgate-pro' href='/pricing'>✨ Pro लें — बिना विज्ञापन, बिना वॉटरमार्क, तुरंत डाउनलोड</a>
  </div>
</div>

<script is:inline src='https://cdn.jsdelivr.net/npm/html2canvas@1.4.1/dist/html2canvas.min.js'></script>
<script is:inline src='https://cdn.jsdelivr.net/npm/html-to-image@1.11.11/dist/html-to-image.js'></script>

<style>
  .ed-wrap { padding: 24px 16px 60px; background: var(--grad-soft); min-height: 80vh; }
  .ed-grid { max-width: 1000px; margin: 0 auto; display: grid; grid-template-columns: 420px 1fr; gap: 32px; align-items: start; }

  .stage-frame { background: #fff; border-radius: 18px; padding: 12px; box-shadow: 0 10px 30px rgba(124,58,237,.10); }
  .capture { border-radius: 12px; overflow: hidden; background: #fff; }
  .stage { position: relative; width: 100%; line-height: 0; background: #f0eef7; overflow: hidden; }
  .poster-img { width: 100%; height: auto; display: block; }

  /* only the user's photo, as a circle */
  .photo-circle { position: absolute; left: 50%; top: 52%; transform: translate(-50%,-50%); width: 45%; aspect-ratio: 1 / 1;
    border-radius: 50%; background-size: cover; background-position: center; border: 4px solid #fff;
    box-shadow: 0 4px 16px rgba(0,0,0,.35); cursor: grab; touch-action: none; overflow: hidden; }
  .photo-circle:active { cursor: grabbing; }
  .photo-circle.empty { background: rgba(255,255,255,.65); border: 3px dashed #B4145A; display: grid; place-items: center;
    color: #B4145A; font-weight: 800; font-size: 15px; line-height: 1; }
  .brand-overlay { position: absolute; left: 50%; top: 82%; transform: translate(-50%,-50%); width: 55%; cursor: grab; touch-action: none; display: none; filter: drop-shadow(0 2px 6px rgba(0,0,0,.25)); }
  .brand-overlay.show { display: block; }
  .brand-overlay:active { cursor: grabbing; }
  .date-badge { position: absolute; top: 12px; left: 12px; right: 12px; display: flex; align-items: flex-start; justify-content: space-between; gap: 8px; pointer-events: none; z-index: 3; }
  .db-day, .db-date { display: inline-block; background: #7C3AED; color: #fff; font-size: 13px; font-weight: 700; padding: 10px 14px; line-height: 1; border-radius: 22px; white-space: nowrap; box-shadow: 0 2px 8px rgba(0,0,0,.28); }
  .db-date { background: #B4145A; }
  .wm-mark { position: absolute; left: 50%; top: 50%; transform: translate(-50%,-50%); width: 62%; max-width: 62%; opacity: .38; pointer-events: none; display: none; z-index: 2; }
  .wm-mark.show { display: block; }

  /* TOP website strip */
  .brand-top { display: block; width: 100%; height: auto; }
  .brand-strip { display: flex; align-items: center; justify-content: center; gap: 10px; padding: 11px 12px;
    background: linear-gradient(90deg,#7C3AED,#B4145A); color: #fff; }
  .bs-logo { width: 30px; height: 30px; border-radius: 8px; background: rgba(255,255,255,.22); display: inline-flex; align-items: center; justify-content: center;
    font-weight: 800; font-size: 17px; font-family: 'Poppins', sans-serif; flex-shrink: 0; }
  .bs-txt { display: flex; flex-direction: column; line-height: 1.25; text-align: left; }
  .bs-txt b { font-size: 14px; font-weight: 800; letter-spacing: .2px; }
  .bs-txt small { font-size: 11px; opacity: .92; }

  /* BOTTOM name + number strip */
  .name-strip { background: #fff; text-align: center; padding: 7px 14px; }
  .name-strip b { display: block; font-size: 17px; font-weight: 800; color: var(--ink); font-family: 'Noto Sans Devanagari', sans-serif; line-height: 1.15; }
  .name-strip span { display: block; font-size: 11.5px; font-weight: 600; color: var(--muted); margin-top: 1px; }

  .stage-controls { margin-top: 14px; background: #fff; border: 1px solid var(--line); border-radius: 12px; padding: 14px 16px; }
  .sc-row { display: flex; align-items: center; gap: 12px; font-size: 13px; font-weight: 700; margin-bottom: 10px; }
  .sc-row span { width: 86px; flex-shrink: 0; }
  .sc-row input { flex: 1; }
  .sc-hint { font-size: 11.5px; color: var(--muted); margin: 0; line-height: 1.5; }

  .ed-panel h1 { font-size: 22px; font-weight: 800; }
  .ed-sub { color: var(--muted); font-size: 13.5px; margin: 6px 0 16px; line-height: 1.6; }
  .ed-kitbox { background: #fff; border: 1px solid var(--line); border-radius: 12px; padding: 16px; margin-bottom: 16px; }
  .ed-seltitle { font-size: 13px; font-weight: 800; color: var(--purple); margin-bottom: 12px; }
  .ed-fld { display: block; font-size: 13px; font-weight: 700; margin-bottom: 10px; }
  .ed-fld input { width: 100%; margin-top: 5px; border: 1px solid var(--line); border-radius: 9px; padding: 9px 11px; font-family: inherit; font-size: 14px; outline: none; }
  .ed-fld input:focus { border-color: var(--purple); }
  .ed-download { display: flex; flex-direction: column; gap: 10px; }
  .ed-download .btn { width: 100%; }
  .ed-note { font-size: 12.5px; color: var(--muted); margin-top: 12px; line-height: 1.6; }
  .ed-note a { color: var(--gold-dark); font-weight: 700; }
  .ed-dlcount { margin-top: 10px; font-size: 12.5px; font-weight: 700; color: var(--purple); background: #F3EEFF; border: 1px solid var(--line); border-radius: 10px; padding: 9px 12px; text-align: center; }

  /* free-user ad gate */
  .adgate { position: fixed; inset: 0; background: rgba(20,16,40,.72); display: none; align-items: center; justify-content: center; z-index: 9999; padding: 20px; }
  .adgate.open { display: flex; }
  .adgate-box { position: relative; background: #fff; border-radius: 16px; padding: 24px 20px 20px; width: 100%; max-width: 360px; text-align: center; box-shadow: 0 20px 50px rgba(0,0,0,.3); }
  .adgate-h { font-size: 15px; font-weight: 800; color: var(--ink); margin-bottom: 14px; }
  .adgate-ad { background: #F3EEFF; border: 1px dashed var(--purple); border-radius: 12px; height: 210px; display: grid; place-items: center; position: relative; }
  .adgate-adlabel { position: absolute; top: 8px; left: 10px; font-size: 10px; font-weight: 700; color: var(--muted); letter-spacing: .5px; }
  .adgate-adtxt { font-size: 13px; color: var(--muted); font-weight: 600; }
  .adgate-bar { height: 6px; background: var(--line); border-radius: 6px; margin: 16px 0 10px; overflow: hidden; }
  .adgate-bar i { display: block; height: 100%; width: 0; background: var(--purple); transition: width 1s linear; }
  .adgate-timer { font-size: 13px; color: var(--muted); }
  .adgate-timer b { color: var(--purple); font-size: 15px; }
  .adgate-pro { display: block; margin-top: 14px; font-size: 12.5px; font-weight: 700; color: var(--gold-dark); text-decoration: none; }
  .adgate-close { position: absolute; top: 6px; right: 10px; background: none; border: none; font-size: 26px; line-height: 1; color: var(--muted); cursor: pointer; }

  @media (max-width: 820px) {
    .ed-grid { grid-template-columns: 1fr; gap: 20px; }
    .ed-stage-col { max-width: 400px; margin: 0 auto; width: 100%; }
    .ed-panel { max-width: 500px; margin: 0 auto; width: 100%; }
  }
</style>

<script is:inline>
  (function () {
    var SITE_URL = 'https://posterhub.pages.dev';
    var params = new URLSearchParams(location.search);
    var imgUrl = params.get('img');
    var titleParam = params.get('title') || '';
    var posterImg = document.getElementById('posterImg');
    posterImg.src = imgUrl || '/img/preview-morning.webp';

    // आज की तारीख़ + दिन (ऊपर लेफ्ट दिन, राइट तारीख़)
    var HDAYS = ['रविवार','सोमवार','मंगलवार','बुधवार','गुरुवार','शुक्रवार','शनिवार'];
    var HMON = ['जनवरी','फ़रवरी','मार्च','अप्रैल','मई','जून','जुलाई','अगस्त','सितंबर','अक्टूबर','नवंबर','दिसंबर'];
    var _now = new Date();
    var _dbDay = document.getElementById('dbDay');
    var _dbDate = document.getElementById('dbDate');
    if (_dbDay) _dbDay.textContent = HDAYS[_now.getDay()];
    if (_dbDate) _dbDate.textContent = _now.getDate() + ' ' + HMON[_now.getMonth()] + ' ' + _now.getFullYear();

    var stage = document.getElementById('stage');
    var pc = document.getElementById('photoCircle');
    var wmMark = document.getElementById('wmMark');
    // watermark फ़ाइल नहीं मिली तो छिपा दो (broken image न दिखे)
    if (wmMark) { wmMark.addEventListener('error', function () { wmMark.classList.remove('show'); wmMark.style.display = 'none'; }); }
    var strip = document.getElementById('brandStrip');
    var capture = document.getElementById('capture');
    var isPaid = false;
    var nsName = document.getElementById('nsName');
    var nsProf = document.getElementById('nsProf');

    // ===== profile =====
    var prof = {};
    try { prof = JSON.parse(localStorage.getItem('ph_profile') || '{}') || {}; } catch (e) {}
    var savedAvatar = null;
    try { savedAvatar = localStorage.getItem('ph_avatar'); } catch (e) {}

    var inName = document.getElementById('inName');
    var inProf = document.getElementById('inProf');
    var inPhoto = document.getElementById('inPhoto');

    function setPhoto(url) {
      if (url) { pc.style.backgroundImage = 'url(' + url + ')'; pc.classList.remove('empty'); pc.textContent = ''; }
      else { pc.style.backgroundImage = ''; pc.classList.add('empty'); pc.textContent = 'फोटो'; }
    }
    function renderInfo() {
      nsName.textContent = inName.value.trim() || 'आपका नाम';
      nsProf.textContent = inProf.value.trim() || 'प्रोफेशन';
    }

    inName.value = prof.name || '';
    inProf.value = prof.profession || '';
    setPhoto(prof.photo || savedAvatar || null);
    renderInfo();

    fetch('/api/auth/me').then(function (r) { return r.json(); }).then(function (d) {
      if (d && d.user) {
        if (!inName.value) inName.value = d.user.name || '';
        if (!prof.photo && !savedAvatar && d.user.avatar) { savedAvatar = d.user.avatar; setPhoto(savedAvatar); }
        if (d.user.plan === 'pro' || d.user.plan === 'business') { isPaid = true; strip.style.display = 'none'; document.getElementById('proNote').style.display = 'none'; if (wmMark) wmMark.classList.remove('show'); }
        if (d.user.plan === 'business') { document.getElementById('nameStrip').style.display = 'none'; if (d.user.branding) { showBranding(d.user.branding); } }
        renderInfo();
      }
    }).catch(function () {});

    inPhoto.addEventListener('change', function () {
      var f = this.files[0]; if (!f) return;
      var reader = new FileReader();
      reader.onload = function (e) { prof.photo = e.target.result; setPhoto(prof.photo); };
      reader.readAsDataURL(f);
    });
    [inName, inProf].forEach(function (el) { el.addEventListener('input', renderInfo); });
    document.getElementById('saveKit').addEventListener('click', function () {
      prof.name = inName.value.trim(); prof.profession = inProf.value.trim();
      try { localStorage.setItem('ph_profile', JSON.stringify(prof)); } catch (e) {}
      renderInfo();
      var b = this; b.textContent = '✓ सेव हो गया'; setTimeout(function () { b.textContent = 'जानकारी सेव करें'; }, 1500);
    });

    // ===== drag + resize photo circle =====
    var pos = { xp: 50, yp: 52 }; var sizePct = 45;
    function applyPhoto() { pc.style.left = pos.xp + '%'; pc.style.top = pos.yp + '%'; pc.style.width = sizePct + '%'; }
    applyPhoto();
    var drag = false;
    pc.addEventListener('pointerdown', function (e) { drag = true; pc.setPointerCapture(e.pointerId); e.preventDefault(); });
    pc.addEventListener('pointermove', function (e) {
      if (!drag) return;
      var r = stage.getBoundingClientRect();
      pos.xp = Math.max(0, Math.min(100, ((e.clientX - r.left) / r.width) * 100));
      pos.yp = Math.max(0, Math.min(100, ((e.clientY - r.top) / r.height) * 100));
      applyPhoto();
    });
    pc.addEventListener('pointerup', function () { drag = false; });
    pc.addEventListener('pointercancel', function () { drag = false; });
    document.getElementById('sizeRange').addEventListener('input', function () { sizePct = parseInt(this.value, 10); applyPhoto(); });

    // ===== business branding overlay =====
    var bo = document.getElementById('brandOverlay');
    var brandCtl = document.getElementById('brandCtl');
    var bpos = { xp: 50, yp: 82 }; var bsize = 55;
    function applyBrand() { bo.style.left = bpos.xp + '%'; bo.style.top = bpos.yp + '%'; bo.style.width = bsize + '%'; }
    function showBranding(url) {
      if (url) { bo.src = url; bo.classList.add('show'); brandCtl.style.display = 'flex'; applyBrand(); }
      else { bo.classList.remove('show'); brandCtl.style.display = 'none'; }
    }
    var brandData = null;
    try { brandData = localStorage.getItem('ph_branding'); } catch (e) {}
    showBranding(brandData);
    var bdrag = false;
    bo.addEventListener('pointerdown', function (e) { bdrag = true; bo.setPointerCapture(e.pointerId); e.preventDefault(); });
    bo.addEventListener('pointermove', function (e) {
      if (!bdrag) return;
      var r = stage.getBoundingClientRect();
      bpos.xp = Math.max(0, Math.min(100, ((e.clientX - r.left) / r.width) * 100));
      bpos.yp = Math.max(0, Math.min(100, ((e.clientY - r.top) / r.height) * 100));
      applyBrand();
    });
    bo.addEventListener('pointerup', function () { bdrag = false; });
    bo.addEventListener('pointercancel', function () { bdrag = false; });
    document.getElementById('brandRange').addEventListener('input', function () { bsize = parseInt(this.value, 10); applyBrand(); });

    // ===== export =====
    // IMPORTANT: फ़ॉन्ट पूरी तरह लोड होने का इंतज़ार करो, वरना html2canvas
    // fallback फ़ॉन्ट की माप से capture क�����ता है और टेक्स्ट (दिन/तारीख़, ब्रांडिंग,
    // नाम) ऊपर-नीचे खिसक जाता है। fonts.ready + थोड़ा delay इसे ठीक करता है।
    function build() {
      var f = document.fonts;
      // capture से पहले ज़रूरी फ़ॉन्ट स्पष्ट रूप से लोड करो (weights जो पोस्टर में इस्तेमाल होते हैं)
      var pre = Promise.resolve();
      if (f && f.load) {
        pre = Promise.all([
          f.load('700 13px "Noto Sans Devanagari"'),
          f.load('800 17px "Noto Sans Devanagari"'),
          f.load('600 12px "Noto Sans Devanagari"'),
          f.load('800 14px "Poppins"'),
          f.load('800 17px "Poppins"')
        ]).catch(function () {});
      }
      var ready = (f && f.ready) ? f.ready : Promise.resolve();
      return pre
        .then(function () { return ready; })
        .then(function () { return new Promise(function (res) { setTimeout(res, 250); }); })
        .then(function () { return renderCanvas(); });
    }

    // मुख्य रेंडरर: html-to-image (SVG foreignObject) = ब्राउज़र का अपना
    // rendering → download बिल्कुल website जैसा, टेक्स्ट की खिसकन खत्म।
    // सभी इमेज same-origin हैं इसलिए canvas taint नहीं होता। backup: html2canvas।
    // stage के अंदर absolute चीज़ (फ़ोटो, watermark, branding) की on-screen जगह px में
    // "freeze" करो ताकि html-to-image उन्हें बिल्कुल वैसा ही बनाए — %/aspect-ratio/transform की गड़बड़ी खत्म
    function freezeEl(el) {
      if (!el) return null;
      var cs = window.getComputedStyle(el);
      if (cs.display === 'none' || cs.visibility === 'hidden') return null;
      var sr = stage.getBoundingClientRect();
      var er = el.getBoundingClientRect();
      var prev = el.getAttribute('style');
      el.style.left = (er.left - sr.left) + 'px';
      el.style.top = (er.top - sr.top) + 'px';
      el.style.width = er.width + 'px';
      el.style.height = er.height + 'px';
      el.style.transform = 'none';
      return { el: el, prev: prev };
    }
    // ===== download-only text overlay =====
    // pill / branding / नाम का text canvas पर सीधे fillText से बीचोबीच
    // (textBaseline=middle) लिखो — रैस्टराइज़ की खिसकन खत्म। यह सिर्फ़
    // downloaded canvas पर लगता है — website/editor preview पर कोई असर नहीं।
    var STACK = "'Noto Sans Devanagari','Poppins',sans-serif";
    var _txtEls = null;
    function txtEls() {
      if (_txtEls) return _txtEls;
      var list = [];
      ['dbDay', 'dbDate', 'nsName', 'nsProf'].forEach(function (id) { var e = document.getElementById(id); if (e) list.push(e); });
      var bs = document.getElementById('brandStrip');
      if (bs) ['.bs-logo', '.bs-txt b', '.bs-txt small'].forEach(function (s) { var e = bs.querySelector(s); if (e) list.push(e); });
      _txtEls = list; return list;
    }
    function hideText() { txtEls().forEach(function (e) { e.dataset.oc = e.style.color || ''; e.style.color = 'transparent'; }); }
    function showText() { txtEls().forEach(function (e) { e.style.color = e.dataset.oc || ''; delete e.dataset.oc; }); }
    function textOverlayOps() {
      var cr = capture.getBoundingClientRect();
      var items = [];
      function push(el, o) {
        if (!el) return;
        var cs = window.getComputedStyle(el);
        if (cs.display === 'none' || cs.visibility === 'hidden') return;
        var r = el.getBoundingClientRect();
        if (!r.width || !r.height) return;
        var text = (o.text != null ? o.text : el.textContent) || '';
        if (!text.trim()) return;
        items.push({ text: text, align: o.align || 'center', color: o.color, weight: o.weight, size: o.size, family: o.family || STACK,
          x: (o.align === 'left' ? (r.left - cr.left) : (r.left - cr.left + r.width / 2)), y: (r.top - cr.top + r.height / 2) });
      }
      push(document.getElementById('dbDay'), { size: 13, weight: 700, color: '#ffffff' });
      push(document.getElementById('dbDate'), { size: 13, weight: 700, color: '#ffffff' });
      var bs = document.getElementById('brandStrip');
      if (bs && window.getComputedStyle(bs).display !== 'none') {
        push(bs.querySelector('.bs-logo'), { size: 17, weight: 800, color: '#ffffff', family: "'Poppins',sans-serif" });
        push(bs.querySelector('.bs-txt b'), { size: 14, weight: 800, color: '#ffffff', align: 'left' });
        push(bs.querySelector('.bs-txt small'), { size: 11, weight: 400, color: 'rgba(255,255,255,.92)', align: 'left' });
      }
      var ns = document.getElementById('nameStrip');
      if (ns && window.getComputedStyle(ns).display !== 'none') {
        push(document.getElementById('nsName'), { size: 17, weight: 800, color: '#1E1B2E' });
        push(document.getElementById('nsProf'), { size: 11.5, weight: 600, color: '#6B6880' });
      }
      return { capW: cr.width, items: items };
    }
    function drawText(cv, ops) {
      if (!ops || !ops.items.length || !ops.capW) return;
      var ctx = cv.getContext('2d');
      var ratio = cv.width / ops.capW;
      ctx.textBaseline = 'middle';
      ops.items.forEach(function (it) {
        ctx.font = it.weight + ' ' + (it.size * ratio) + 'px ' + it.family;
        ctx.fillStyle = it.color; ctx.textAlign = it.align;
        ctx.fillText(it.text, it.x * ratio, it.y * ratio);
      });
    }
    function renderCanvas() {
      var opts = { pixelRatio: 2, backgroundColor: '#ffffff', cacheBust: true };
      var frozen = [pc, wmMark, bo].map(freezeEl).filter(Boolean);
      function restore() { frozen.forEach(function (f) { if (f.prev === null) f.el.removeAttribute('style'); else f.el.setAttribute('style', f.prev); }); }
      var ops = textOverlayOps();
      hideText();
      var task;
      if (window.htmlToImage && window.htmlToImage.toCanvas) {
        // पहला render warm-up (foreignObject में इमेज कभी-कभी पहली बार छूट जाती है), फिर असली
        task = window.htmlToImage.toCanvas(capture, opts)
          .then(function () { return window.htmlToImage.toCanvas(capture, opts); })
          .catch(function () { return html2canvas(capture, { useCORS: true, backgroundColor: '#ffffff', scale: 2, logging: false, imageTimeout: 0 }); });
      } else {
        task = html2canvas(capture, { useCORS: true, backgroundColor: '#ffffff', scale: 2, logging: false, imageTimeout: 0 });
      }
      return task.then(function (cv) { restore(); showText(); drawText(cv, ops); return cv; }, function (err) { restore(); showText(); throw err; });
    }
    function busy(btn, on, txt) { btn.disabled = on; if (on) { btn.dataset.t = btn.textContent; btn.textContent = txt; } else { btn.textContent = btn.dataset.t; } }

    // ===== download counter =====
    var dlCountEl = document.getElementById('dlCount');
    function showDlCount(n) {
      if (!dlCountEl || !n) return;
      dlCountEl.textContent = '🔥 अब तक ' + Number(n).toLocaleString('en-IN') + ' पोस्टर डाउनलोड हो चुके हैं';
      dlCountEl.style.display = 'block';
    }
    function trackDownload() {
      try {
        fetch('/api/track-download', { method: 'POST', headers: { 'content-type': 'application/json' }, body: JSON.stringify({ title: titleParam }) })
          .then(function (r) { return r.json(); }).then(function (d) { if (d && d.total) showDlCount(d.total); }).catch(function () {});
      } catch (e) {}
    }
    fetch('/api/track-download').then(function (r) { return r.json(); }).then(function (d) { if (d && d.total) showDlCount(d.total); }).catch(function () {});

    function doDownload(btn) {
      busy(btn, true, 'बन रहा है...');
      build().then(function (canvas) {
        var a = document.createElement('a');
        a.download = 'posterhub-' + Date.now() + '.jpg';
        a.href = canvas.toDataURL('image/jpeg', 0.92); a.click();
        trackDownload();
        busy(btn, false);
      }).catch(function () { busy(btn, false); alert('डाउनलोड में समस्या।'); });
    }

    // free users को download से पहले 10 सेकंड का ad-gate; pro/business को सीधे download
    var adTimer = null;
    function showAdGate(cb) {
      var gate = document.getElementById('adGate');
      var cd = document.getElementById('adCountdown');
      var bar = document.getElementById('adBar');
      if (!gate) { cb(); return; }
      gate.classList.add('open');
      var n = 10;
      if (cd) cd.textContent = n;
      if (bar) bar.style.width = '0%';
      clearInterval(adTimer);
      adTimer = setInterval(function () {
        n--;
        if (cd) cd.textContent = n > 0 ? n : 0;
        if (bar) bar.style.width = ((10 - n) / 10 * 100) + '%';
        if (n <= 0) { clearInterval(adTimer); gate.classList.remove('open'); cb(); }
      }, 1000);
    }
    (function () {
      var adClose = document.getElementById('adClose');
      if (adClose) adClose.addEventListener('click', function () { clearInterval(adTimer); var g = document.getElementById('adGate'); if (g) g.classList.remove('open'); });
    })();

    document.getElementById('btnDownload').addEventListener('click', function () {
      var btn = this;
      if (isPaid) { doDownload(btn); return; }
      showAdGate(function () { doDownload(btn); });
    });

    document.getElementById('btnShare').addEventListener('click', function () {
      var btn = this; busy(btn, true, 'तैयार...');
      var text = 'Daily PosterHub से बनाया 👇 ' + SITE_URL;
      build().then(function (canvas) {
        canvas.toBlob(function (blob) {
          trackDownload();
          var file = new File([blob], 'poster.jpg', { type: 'image/jpeg' });
          if (navigator.canShare && navigator.canShare({ files: [file] })) {
            navigator.share({ files: [file], text: text, url: SITE_URL }).then(function () { busy(btn, false); }).catch(function () { busy(btn, false); });
          } else {
            var a = document.createElement('a'); a.download = 'poster.jpg'; a.href = URL.createObjectURL(blob); a.click();
            window.open('https://wa.me/?text=' + encodeURIComponent(text), '_blank');
            busy(btn, false);
          }
        }, 'image/jpeg', 0.92);
      }).catch(function () { busy(btn, false); alert('शेयर में समस्या।'); });
    });
  })();
</script>
