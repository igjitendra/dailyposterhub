---
import Layout from '../layouts/Layout.astro';
---
<Layout title='पोस्टर एडिटर — Daily PosterHub'>
  <section class='ed-wrap'>
    <div class='ed-grid'>

      <!-- STAGE -->
      <div class='ed-stage-col'>
        <div class='stage-frame'>
          <div class='capture' id='capture'>
            <!-- Free plan branding strip (ABOVE image, outside poster) -->
            <div class='brand-strip' id='brandStrip'>
              <span class='bs-logo'>D</span>
              <span class='bs-txt'><b>DailyPosterHub</b><small>फ्री पोस्टर रोज़ — posterhub.pages.dev</small></span>
            </div>
            <div class='stage' id='stage'>
              <img id='posterImg' class='poster-img' alt='poster' crossorigin='anonymous' />

              <!-- Free watermark (inside image) -->
              <div class='watermark' id='watermark'>▶ @jitendrauno</div>

              <!-- Personal brand kit (liquid glass) -->
              <div id='brandCard' class='kit'>
                <button class='kit-close' id='kitClose' title='हटाएं' aria-label='हटाएं'>×</button>
                <div class='kit-photo' id='kitPhoto'><span id='kitPhotoLetter'>D</span></div>
                <div class='kit-info'>
                  <div class='kit-name' id='kitName'>आपका नाम</div>
                  <div class='kit-line'></div>
                  <div class='kit-row'><span class='kit-ic'><svg viewBox='0 0 24 24' width='11' height='11' fill='#fff'><path d='M10 2h4a2 2 0 0 1 2 2v2h3a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h3V4a2 2 0 0 1 2-2zm4 4V4h-4v2h4z'/></svg></span><span id='kitProf'>प्रोफेशन यहाँ लिखें</span></div>
                  <div class='kit-row'><span class='kit-ic'><svg viewBox='0 0 24 24' width='11' height='11' fill='#fff'><path d='M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.1 21 3 13.9 3 5c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.2.2 2.4.6 3.6.1.4 0 .8-.3 1l-2.2 2.2z'/></svg></span><span id='kitPhone'>98765 43210</span></div>
                  <div class='kit-row'><span class='kit-ic'><svg viewBox='0 0 24 24' width='11' height='11' fill='#fff'><path d='M12 12a5 5 0 1 0 0-10 5 5 0 0 0 0 10zm0 2c-4 0-8 2-8 5v1h16v-1c0-3-4-5-8-5z'/></svg></span><span id='kitUser'>@yourusername</span></div>
                  <div class='kit-socials'>
                    <span class='soc' style='background:#1877F2'><svg viewBox='0 0 24 24' width='11' height='11' fill='#fff'><path d='M13 22v-8h2.5l.5-3H13V9c0-.9.3-1.5 1.6-1.5H16V5c-.3 0-1.2-.1-2.2-.1C11.6 4.9 10 6.2 10 8.7V11H7.5v3H10v8h3z'/></svg></span>
                    <span class='soc' style='background:#E4405F'><svg viewBox='0 0 24 24' width='11' height='11' fill='#fff'><path d='M12 8.5A3.5 3.5 0 1 0 12 15.5 3.5 3.5 0 0 0 12 8.5zM17 3H7a4 4 0 0 0-4 4v10a4 4 0 0 0 4 4h10a4 4 0 0 0 4-4V7a4 4 0 0 0-4-4zm-5 14a5 5 0 1 1 0-10 5 5 0 0 1 0 10zm5.5-9a1 1 0 1 1 0-2 1 1 0 0 1 0 2z'/></svg></span>
                    <span class='soc' style='background:#25D366'><svg viewBox='0 0 24 24' width='11' height='11' fill='#fff'><path d='M12 2a10 10 0 0 0-8.6 15l-1 3.7 3.8-1A10 10 0 1 0 12 2zm5.3 14.1c-.2.6-1.3 1.2-1.8 1.2-.5.1-1 .3-3.3-.7-2.8-1.1-4.5-3.9-4.6-4.1-.1-.2-1-1.3-1-2.5s.6-1.8.9-2 .5-.3.7-.3h.5c.2 0 .4 0 .6.5l.8 2c.1.1.1.3 0 .5l-.4.5c-.1.2-.3.3-.1.6.1.2.7 1.1 1.5 1.7 1 .9 1.8 1.1 2 1.2.2.1.4.1.5-.1l.7-.9c.2-.2.3-.2.6-.1l1.8.9c.2.1.4.2.5.3.1.1.1.7-.1 1.3z'/></svg></span>
                    <span class='soc' style='background:#FF0000'><svg viewBox='0 0 24 24' width='11' height='11' fill='#fff'><path d='M22 12s0-3.3-.4-4.8c-.2-.9-.9-1.5-1.7-1.7C18.3 5 12 5 12 5s-6.3 0-7.9.4c-.8.2-1.5.9-1.7 1.8C2 8.7 2 12 2 12s0 3.3.4 4.8c.2.9.9 1.5 1.7 1.8C5.7 19 12 19 12 19s6.3 0 7.9-.4c.8-.2 1.5-.9 1.7-1.7.4-1.6.4-4.9.4-4.9zm-12 3V9l5 3-5 3z'/></svg></span>
                  </div>
                </div>
              </div>

              <!-- shown only when kit removed -->
              <button class='re-add btn btn-primary btn-sm' id='reAdd' hidden>＋ ब्रांड किट जोड़ें</button>
            </div>
          </div>
        </div>

        <!-- controls OUTSIDE the image -->
        <div class='stage-controls'>
          <div class='sc-row'><span>साइज़</span><input id='sizeRange' type='range' min='55' max='160' value='100' /></div>
          <div class='sc-row'><span>बैकग्राउंड</span><input id='bgRange' type='range' min='0' max='100' value='40' /></div>
          <p class='sc-hint'>बैकग्राउंड कम करें → पीछे का पोस्टर झलकेगा (glass इफेक्ट)।</p>
        </div>
      </div>

      <!-- INFO PANEL -->
      <div class='ed-panel'>
        <h1>पोस्टर एडिट करें</h1>
        <p class='ed-sub'>अपनी जानकारी भरें—ब्रांड किट पोस्टर पर आ जाएगी। उसे खींचकर खाली जगह पर रखें, ‘साइज़’ से छोटा-बड़ा करें।</p>

        <div class='ed-kitbox'>
          <div class='ed-seltitle'>आपकी जानकारी</div>
          <label class='ed-fld'>नाम<input id='inName' type='text' placeholder='आपका नाम' /></label>
          <label class='ed-fld'>प्रोफेशन<input id='inProf' type='text' placeholder='जैसे: फोटोग्राफर' /></label>
          <label class='ed-fld'>मोबाइल<input id='inPhone' type='text' placeholder='98765 43210' /></label>
          <label class='ed-fld'>यूज़रनेम<input id='inUser' type='text' placeholder='@yourusername' /></label>
          <label class='ed-fld'>फोटो<input id='inPhoto' type='file' accept='image/*' /></label>
          <button id='saveKit' class='btn btn-gold btn-sm'>जानकारी सेव करें</button>
        </div>

        <div class='ed-download'>
          <button id='btnDownload' class='btn btn-primary btn-lg'>⬇ डाउनलोड करें</button>
          <button id='btnShare' class='btn btn-gold btn-lg'>WhatsApp पर शेयर</button>
        </div>
        <p class='ed-note' id='proNote'>फ्री प्लान में ऊपर ब्रांडिंग पट्टी और हल्का वॉटरमार्क रहेगा। <a href='/payment'>Pro लें</a> — बिना ब्रांडिंग और HD डाउनलोड।</p>
      </div>
    </div>
  </section>
</Layout>

<script is:inline src='https://cdn.jsdelivr.net/npm/html2canvas@1.4.1/dist/html2canvas.min.js'></script>

<style>
  .ed-wrap { padding: 24px 16px 60px; background: var(--grad-soft); min-height: 80vh; }
  .ed-grid { max-width: 1000px; margin: 0 auto; display: grid; grid-template-columns: 420px 1fr; gap: 32px; align-items: start; }

  .stage-frame { background: #fff; border-radius: 18px; padding: 12px; box-shadow: 0 10px 30px rgba(124,58,237,.10); }
  .capture { border-radius: 12px; overflow: hidden; }
  .stage { position: relative; width: 100%; line-height: 0; background: #f0eef7; overflow: hidden; }
  .poster-img { width: 100%; height: auto; display: block; }

  .watermark { position: absolute; right: 9px; bottom: 9px; color: rgba(255,255,255,.85); font-size: 13px; font-weight: 800;
    text-shadow: 0 1px 4px rgba(0,0,0,.65); pointer-events: none; line-height: 1; letter-spacing: .3px; }

  /* liquid glass brand kit */
  .kit { position: absolute; left: 50%; top: 70%; transform: translate(-50%,-50%) scale(1); width: 82%; max-width: 360px;
    display: flex; gap: 14px; align-items: center; padding: 14px 16px; border-radius: 20px;
    background: rgba(255,255,255,.20); backdrop-filter: blur(14px) saturate(150%); -webkit-backdrop-filter: blur(14px) saturate(150%);
    border: 1px solid rgba(255,255,255,.5); box-shadow: 0 8px 32px rgba(0,0,0,.28);
    cursor: grab; touch-action: none; user-select: none; }
  .kit:active { cursor: grabbing; }
  .kit-close { position: absolute; top: -11px; right: -11px; width: 27px; height: 27px; border-radius: 50%; background: #fff;
    color: #B4145A; border: none; font-size: 17px; font-weight: 800; cursor: pointer; box-shadow: 0 2px 7px rgba(0,0,0,.35);
    display: grid; place-items: center; line-height: 1; z-index: 3; }
  .kit-photo { flex-shrink: 0; width: 92px; height: 92px; border-radius: 16px; overflow: hidden; background: rgba(255,255,255,.4);
    border: 3px solid rgba(255,255,255,.85); display: grid; place-items: center; color: #B4145A; font-weight: 800; font-size: 34px;
    background-size: cover; background-position: center; line-height: 1; box-shadow: 0 3px 10px rgba(0,0,0,.2); }
  .kit-info { min-width: 0; flex: 1; line-height: 1.15; }
  .kit-name { color: #fff; font-weight: 800; font-size: 21px; font-family: 'Noto Sans Devanagari', sans-serif; text-shadow: 0 1px 5px rgba(0,0,0,.55); }
  .kit-line { height: 1px; background: rgba(255,255,255,.55); margin: 5px 0 7px; }
  .kit-row { display: flex; align-items: center; gap: 7px; margin: 4px 0; font-size: 13px; font-weight: 600; color: #fff; text-shadow: 0 1px 4px rgba(0,0,0,.5); }
  .kit-ic { flex-shrink: 0; width: 19px; height: 19px; border-radius: 50%; background: rgba(255,255,255,.28); display: grid; place-items: center; }
  .kit-socials { display: flex; align-items: center; gap: 7px; margin-top: 8px; }
  .soc { width: 20px; height: 20px; border-radius: 50%; display: grid; place-items: center; }

  .re-add { position: absolute; left: 50%; top: 50%; transform: translate(-50%,-50%); z-index: 4; }

  .brand-strip { display: flex; align-items: center; justify-content: center; gap: 10px; padding: 11px 12px;
    background: linear-gradient(90deg,#7C3AED,#B4145A); color: #fff; }
  .bs-logo { width: 30px; height: 30px; border-radius: 8px; background: rgba(255,255,255,.22); display: grid; place-items: center;
    font-weight: 800; font-size: 17px; font-family: 'Poppins', sans-serif; flex-shrink: 0; }
  .bs-txt { display: flex; flex-direction: column; line-height: 1.25; text-align: left; }
  .bs-txt b { font-size: 14px; font-weight: 800; letter-spacing: .2px; }
  .bs-txt small { font-size: 11px; opacity: .92; }

  .stage-controls { margin-top: 14px; background: #fff; border: 1px solid var(--line); border-radius: 12px; padding: 14px 16px; }
  .sc-row { display: flex; align-items: center; gap: 12px; font-size: 13px; font-weight: 700; margin-bottom: 12px; }
  .sc-row span { width: 86px; flex-shrink: 0; }
  .sc-row input { flex: 1; }
  .sc-hint { font-size: 11.5px; color: var(--muted); margin: 0; line-height: 1.5; }

  .ed-panel h1 { font-size: 22px; font-weight: 800; }
  .ed-sub { color: var(--muted); font-size: 13.5px; margin: 6px 0 16px; line-height: 1.6; }
  .ed-kitbox { background: #fff; border: 1px solid var(--line); border-radius: 12px; padding: 16px; margin-bottom: 16px; }
  .ed-seltitle { font-size: 13px; font-weight: 800; color: var(--purple); margin-bottom: 12px; }
  .ed-fld { display: block; font-size: 13px; font-weight: 700; margin-bottom: 10px; }
  .ed-fld input { width: 100%; margin-top: 5px; border: 1px solid var(--line); border-radius: 9px; padding: 9px 11px; font-family: inherit; font-size: 14px; outline: none; }
  .ed-fld input:focus { border-color: var(--purple); }
  .ed-download { display: flex; flex-direction: column; gap: 10px; }
  .ed-download .btn { width: 100%; }
  .ed-note { font-size: 12.5px; color: var(--muted); margin-top: 12px; line-height: 1.6; }
  .ed-note a { color: var(--gold-dark); font-weight: 700; }

  @media (max-width: 820px) {
    .ed-grid { grid-template-columns: 1fr; gap: 20px; }
    .ed-stage-col { max-width: 400px; margin: 0 auto; width: 100%; }
    .ed-panel { max-width: 500px; margin: 0 auto; width: 100%; }
  }
</style>

<script is:inline>
  (function () {
    var SITE_URL = 'https://posterhub.pages.dev';
    var params = new URLSearchParams(location.search);
    var imgUrl = params.get('img');
    var posterImg = document.getElementById('posterImg');
    posterImg.src = imgUrl || '/img/preview-morning.webp';

    var stage = document.getElementById('stage');
    var card = document.getElementById('brandCard');
    var strip = document.getElementById('brandStrip');
    var watermark = document.getElementById('watermark');
    var capture = document.getElementById('capture');
    var reAdd = document.getElementById('reAdd');
    var kitClose = document.getElementById('kitClose');

    // ===== profile / brand kit =====
    var prof = {};
    try { prof = JSON.parse(localStorage.getItem('ph_profile') || '{}') || {}; } catch (e) {}
    var savedAvatar = null;
    try { savedAvatar = localStorage.getItem('ph_avatar'); } catch (e) {}

    var inName = document.getElementById('inName');
    var inProf = document.getElementById('inProf');
    var inPhone = document.getElementById('inPhone');
    var inUser = document.getElementById('inUser');
    var inPhoto = document.getElementById('inPhoto');

    function setPhoto(url, letter) {
      var el = document.getElementById('kitPhoto');
      var lt = document.getElementById('kitPhotoLetter');
      if (url) { el.style.backgroundImage = 'url(' + url + ')'; lt.style.display = 'none'; }
      else { el.style.backgroundImage = ''; lt.style.display = 'block'; lt.textContent = (letter || 'D').trim().charAt(0).toUpperCase(); }
    }
    function renderKit() {
      var name = inName.value.trim() || 'आपका नाम';
      document.getElementById('kitName').textContent = name;
      document.getElementById('kitProf').textContent = inProf.value.trim() || 'प्रोफेशन यहाँ लिखें';
      document.getElementById('kitPhone').textContent = inPhone.value.trim() || '98765 43210';
      var u = inUser.value.trim() || '@yourusername';
      if (u && u.charAt(0) !== '@') u = '@' + u;
      document.getElementById('kitUser').textContent = u;
      if (!prof.photo) setPhoto(savedAvatar || null, name);
    }

    inName.value = prof.name || '';
    inProf.value = prof.profession || '';
    inPhone.value = prof.phone || '';
    inUser.value = prof.username || '';
    if (prof.photo) setPhoto(prof.photo, prof.name);
    else setPhoto(savedAvatar || null, prof.name);

    fetch('/api/auth/me').then(function (r) { return r.json(); }).then(function (d) {
      if (d && d.user) {
        if (!inName.value) inName.value = d.user.name || '';
        if (!prof.photo && d.user.avatar) savedAvatar = d.user.avatar;
        if (d.user.plan === 'pro') { strip.style.display = 'none'; watermark.style.display = 'none'; document.getElementById('proNote').style.display = 'none'; }
        renderKit();
      }
    }).catch(function () {});
    renderKit();

    inPhoto.addEventListener('change', function () {
      var f = this.files[0]; if (!f) return;
      var reader = new FileReader();
      reader.onload = function (e) { prof.photo = e.target.result; setPhoto(prof.photo, inName.value); };
      reader.readAsDataURL(f);
    });
    [inName, inProf, inPhone, inUser].forEach(function (el) { el.addEventListener('input', renderKit); });
    document.getElementById('saveKit').addEventListener('click', function () {
      prof.name = inName.value.trim(); prof.profession = inProf.value.trim();
      prof.phone = inPhone.value.trim(); prof.username = inUser.value.trim();
      try { localStorage.setItem('ph_profile', JSON.stringify(prof)); } catch (e) {}
      renderKit();
      var b = this; b.textContent = '✓ सेव हो गया'; setTimeout(function () { b.textContent = 'जानकारी सेव करें'; }, 1500);
    });

    // remove / re-add
    kitClose.addEventListener('click', function (e) { e.stopPropagation(); card.hidden = true; reAdd.hidden = false; });
    reAdd.addEventListener('click', function () { card.hidden = false; reAdd.hidden = true; });

    // ===== brand card drag + scale + bg opacity =====
    var pos = { xp: 50, yp: 70 }; var scale = 1; var bgAlpha = 0.40;
    function applyKit() {
      card.style.left = pos.xp + '%';
      card.style.top = pos.yp + '%';
      card.style.transform = 'translate(-50%,-50%) scale(' + scale + ')';
      card.style.background = 'rgba(255,255,255,' + (bgAlpha * 0.5) + ')';
      card.style.borderColor = 'rgba(255,255,255,' + (0.25 + bgAlpha * 0.5) + ')';
    }
    applyKit();
    var kdrag = false;
    card.addEventListener('pointerdown', function (e) { if (e.target === kitClose) return; kdrag = true; card.setPointerCapture(e.pointerId); e.preventDefault(); });
    card.addEventListener('pointermove', function (e) {
      if (!kdrag) return;
      var r = stage.getBoundingClientRect();
      pos.xp = Math.max(0, Math.min(100, ((e.clientX - r.left) / r.width) * 100));
      pos.yp = Math.max(0, Math.min(100, ((e.clientY - r.top) / r.height) * 100));
      applyKit();
    });
    card.addEventListener('pointerup', function () { kdrag = false; });
    card.addEventListener('pointercancel', function () { kdrag = false; });
    document.getElementById('sizeRange').addEventListener('input', function () { scale = this.value / 100; applyKit(); });
    document.getElementById('bgRange').addEventListener('input', function () { bgAlpha = this.value / 100; applyKit(); });

    // ===== export =====
    function build() {
      kitClose.style.visibility = 'hidden';
      reAdd.style.display = 'none';
      function restore() { kitClose.style.visibility = ''; reAdd.style.display = ''; }
      return html2canvas(capture, { useCORS: true, backgroundColor: '#ffffff', scale: 2, logging: false })
        .then(function (c) { restore(); return c; })
        .catch(function (e) { restore(); throw e; });
    }
    function busy(btn, on, txt) { btn.disabled = on; if (on) { btn.dataset.t = btn.textContent; btn.textContent = txt; } else { btn.textContent = btn.dataset.t; } }

    document.getElementById('btnDownload').addEventListener('click', function () {
      var btn = this; busy(btn, true, 'बन रहा है...');
      build().then(function (canvas) {
        var a = document.createElement('a');
        a.download = 'posterhub-' + Date.now() + '.png';
        a.href = canvas.toDataURL('image/png'); a.click();
        busy(btn, false);
      }).catch(function () { busy(btn, false); alert('डाउनलोड में समस्या।'); });
    });

    document.getElementById('btnShare').addEventListener('click', function () {
      var btn = this; busy(btn, true, 'तैयार...');
      var text = 'Daily PosterHub से बनाया 👇 ' + SITE_URL;
      build().then(function (canvas) {
        canvas.toBlob(function (blob) {
          var file = new File([blob], 'poster.png', { type: 'image/png' });
          if (navigator.canShare && navigator.canShare({ files: [file] })) {
            navigator.share({ files: [file], text: text, url: SITE_URL }).then(function () { busy(btn, false); }).catch(function () { busy(btn, false); });
          } else {
            var a = document.createElement('a'); a.download = 'poster.png'; a.href = URL.createObjectURL(blob); a.click();
            window.open('https://wa.me/?text=' + encodeURIComponent(text), '_blank');
            busy(btn, false);
          }
        }, 'image/png');
      }).catch(function () { busy(btn, false); alert('शेयर में समस्या।'); });
    });
  })();
</script>
