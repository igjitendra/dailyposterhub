---
import Layout from '../../layouts/Layout.astro';
import Icon from '../../components/Icon.astro';
import { categories } from '../../data/site.js';
const cats = categories.filter((c) => c.slug !== 'all');
---
<Layout title='सभी श्रेणियां — Daily PosterHub' description='हर अवसर के लिए हिंदी poster categories देखें और अपना पसंदीदा design चुनकर तुरंत edit करें।'>
  <section class='categories-hero'>
    <div class='container categories-hero-inner'>
      <div class='crumb'><a href='/'>होम</a><span>/</span><b>सभी श्रेणियां</b></div>
      <span class='hero-label'><Icon name='grid' size={15} /> POSTER CATEGORIES</span>
      <h1>हर अवसर के लिए <span>एक सही पोस्टर</span></h1>
      <p>सुबह की शुभकामना, जन्मदिन, त्योहार या आपके business का offer—अपनी category चुनें और design को अपना बनाएं।</p>
      <div class='category-search'><Icon name='search' size={19} /><input id='categorySearch' type='search' placeholder='Category खोजें...' aria-label='Category खोजें' /></div>
    </div>
  </section>
  <section class='categories-content'>
    <div class='container'>
      <div class='categories-top'><div><span class='count-label'>BROWSE COLLECTIONS</span><h2>किस तरह का poster बनाना है?</h2></div><p id='categoryCount'>{cats.length} categories उपलब्ध हैं</p></div>
      <div class='category-grid' id='categoryGrid'>
        {cats.map((c, i) => (
          <a href={'/categories/' + c.slug} class={'category-card ' + ((c.slug === 'festival' || c.slug === 'special-days') ? 'featured' : '')} data-name={c.name} data-slug={c.slug}>
            <span class='card-index'>0{i + 1}</span>
            <span class='card-icon' style={'color:' + c.color + ';background:' + c.bg}><Icon name={c.icon} size={28} /></span>
            <h3>{c.name}</h3><p>{c.slug === 'festival' ? 'आने वाले त्योहार और उनके पोस्टर' : c.slug === 'special-days' ? 'आज से अगले 7 दिनों के पोस्टर' : 'नाम और फोटो जोड़कर तैयार करें'}</p><span class='card-link'>पोस्टर देखें <Icon name='arrow-right' size={16} /></span>
          </a>
        ))}
      </div>
      <div class='no-category' id='noCategory' hidden><Icon name='search' size={29} /><h2>कोई category नहीं मिली</h2><p>दूसरा शब्द लिखकर खोजें या सभी categories देखें।</p><button id='showAll' class='btn btn-outline'>सभी categories</button></div>
      <div class='category-bottom'><div><span><Icon name='sparkles' size={19} /></span><div><b>अपना poster बनाना आसान है</b><p>Category चुनें → design edit करें → तुरंत download या share करें।</p></div></div><a href='/posters' class='btn btn-primary'>सभी पोस्टर देखें <Icon name='arrow-right' size={16} /></a></div>
    </div>
  </section>
</Layout>
<style>
.categories-hero{position:relative;overflow:hidden;padding:61px 0 72px;background:radial-gradient(600px 300px at 84% 20%,#dfe7ff 0,transparent 72%),linear-gradient(135deg,#fbfaff,#eeeaff)}.categories-hero:after{content:'';position:absolute;left:-90px;bottom:-140px;width:310px;height:310px;border-radius:50%;border:42px solid rgba(124,58,237,.08)}.categories-hero-inner{position:relative;z-index:1;text-align:center}.crumb{display:flex;justify-content:center;align-items:center;gap:8px;color:var(--muted);font-size:12px}.crumb a{color:var(--purple);font-weight:700}.hero-label{display:inline-flex;align-items:center;gap:7px;margin-top:20px;padding:7px 12px;border:1px solid #ddd4ff;border-radius:999px;background:#fff;color:var(--purple);font-size:12px;font-weight:800;letter-spacing:.05em}.categories-hero h1{max-width:750px;margin:15px auto 0;font-size:clamp(34px,4vw,52px);font-weight:800;line-height:1.13;letter-spacing:-1px}.categories-hero h1 span{color:var(--purple)}.categories-hero p{max-width:650px;margin:14px auto 0;color:var(--muted);font-size:16px;line-height:1.72}.category-search{display:flex;align-items:center;gap:10px;width:min(100%,440px);margin:27px auto 0;padding:0 15px;border:1px solid #ddd7f1;border-radius:13px;background:#fff;box-shadow:0 10px 25px rgba(55,39,120,.08)}.category-search :global(.icon){color:var(--purple)}.category-search input{width:100%;height:49px;border:0;outline:0;background:transparent;font:600 14px inherit;color:var(--ink)}.categories-content{padding:47px 0 78px;background:#fbfaff}.categories-top{display:flex;align-items:end;justify-content:space-between;gap:20px;margin-bottom:29px}.count-label{color:var(--purple);font-size:11px;font-weight:800;letter-spacing:.1em}.categories-top h2{margin-top:6px;font-size:clamp(26px,3vw,36px);font-weight:800;line-height:1.2}.categories-top p{color:var(--muted);font-size:12px;font-weight:700}.category-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:15px}.category-card{position:relative;min-height:205px;padding:23px;overflow:hidden;border:1px solid var(--line);border-radius:17px;background:#fff;box-shadow:0 4px 14px rgba(37,27,80,.05);transition:.23s}.category-card.featured{background:linear-gradient(145deg,#fff,#f3f0ff);border-color:#d6ccff}.category-card.featured:after{content:'लोकप्रिय';position:absolute;right:15px;bottom:15px;padding:4px 7px;border-radius:6px;background:#ede9fe;color:var(--purple);font-size:9px;font-weight:800}.category-card:hover{transform:translateY(-6px);border-color:#d3c8ff;box-shadow:0 19px 32px rgba(50,32,115,.13)}.card-index{position:absolute;right:17px;top:15px;color:#e5e0f3;font:800 22px Poppins,sans-serif}.card-icon{display:grid;place-items:center;width:55px;height:55px;border-radius:16px}.category-card h3{margin-top:21px;font-size:18px}.category-card p{margin-top:4px;color:var(--muted);font-size:13px}.card-link{display:inline-flex;align-items:center;gap:6px;margin-top:20px;color:var(--purple);font-size:13px;font-weight:800;transition:gap .2s}.category-card:hover .card-link{gap:10px}.no-category{padding:58px 20px;text-align:center;border:1px dashed #cfc5ef;border-radius:17px;background:#fff;color:var(--muted)}.no-category :global(.icon){color:var(--purple)}.no-category h2{margin-top:12px;color:var(--ink);font-size:20px}.no-category p{margin:6px 0 17px;font-size:14px}.category-bottom{display:flex;align-items:center;justify-content:space-between;gap:22px;margin-top:38px;padding:20px 22px;border:1px solid #dfd7fa;border-radius:16px;background:linear-gradient(110deg,#f1edff,#fff)}.category-bottom>div{display:flex;align-items:center;gap:13px}.category-bottom>div>span{display:grid;place-items:center;width:42px;height:42px;border-radius:12px;background:#e4ddff;color:var(--purple)}.category-bottom b{font-size:14px}.category-bottom p{margin-top:2px;color:var(--muted);font-size:12px}@media(max-width:1050px){.category-grid{grid-template-columns:repeat(3,1fr)}}@media(max-width:760px){.category-grid{grid-template-columns:repeat(2,1fr)}.categories-top{align-items:flex-start;flex-direction:column;gap:8px}.category-bottom{align-items:flex-start;flex-direction:column}.category-bottom .btn{width:100%}}@media(max-width:460px){.categories-hero{padding:45px 0 54px}.categories-content{padding:31px 0 54px}.category-grid{gap:11px}.category-card{min-height:195px;padding:17px}.card-icon{width:46px;height:46px;border-radius:13px}.category-card h3{margin-top:15px;font-size:15px}.category-card p{font-size:11px;line-height:1.45}.card-link{margin-top:14px;font-size:12px}.card-index{right:11px;top:10px;font-size:17px}.category-bottom{padding:16px}.category-bottom p{line-height:1.5}}
</style>
<script is:inline>
(function(){var input=document.getElementById('categorySearch'),cards=[].slice.call(document.querySelectorAll('.category-card')),empty=document.getElementById('noCategory'),grid=document.getElementById('categoryGrid'),count=document.getElementById('categoryCount');function apply(){var q=input.value.trim().toLowerCase(),n=0;cards.forEach(function(card){var show=card.dataset.name.toLowerCase().indexOf(q)>-1;card.hidden=!show;if(show)n++});empty.hidden=n>0;grid.hidden=n===0;count.textContent=n+' categor'+(n===1?'y':'ies')+' उपलब्ध हैं'}input.addEventListener('input',apply);document.getElementById('showAll').onclick=function(){input.value='';apply();input.focus()}})();
</script>
