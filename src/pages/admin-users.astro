---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
---
<Layout title='Admin — यूज़र डैशबोर्ड'>
  <section class='au-wrap'>
    <div class='au-inner'>
      <div class='au-card card'>
        <h1><Icon name='users' size={20} /> यूज़र डैशबोर्ड</h1>
        <p class='au-sub'>WhatsApp पर payment verify करने के बाद यहां से Pro चालू/बंद करें।</p>

        <label class='au-label'>Admin Key
          <div class='key-row'>
            <input id='adminKey' type='password' placeholder='आपकी ADMIN_KEY' />
            <button id='loadBtn' class='btn btn-primary'>लोड करें</button>
          </div>
        </label>

        <div class='stats' id='stats' hidden>
          <div class='stat'><span class='num' id='stTotal'>0</span><span class='lbl'>कुल यूज़र</span></div>
          <div class='stat'><span class='num' id='stPro'>0</span><span class='lbl'>Pro</span></div>
          <div class='stat'><span class='num' id='stFree'>0</span><span class='lbl'>Free</span></div>
        </div>

        <p id='auMsg' class='au-msg' hidden></p>
      </div>

      <div class='au-card card manual'>
        <h2>ईमेल से Pro चालू करें</h2>
        <div class='fld'><input id='userEmail' type='email' placeholder='user@example.com' /></div>
        <div class='au-btns'>
          <button id='proBtn' class='btn btn-gold'>Pro चालू करें</button>
          <button id='bizBtn' class='btn btn-primary'>Business चालू</button>
          <button id='freeBtn' class='btn btn-outline'>Free करें</button>
        </div>
      </div>

      <div class='au-card card' id='dlCard' hidden>
        <h2>📥 सबसे ज़्यादा डाउनलोड होने वाले पोस्टर</h2>
        <p class='au-sub' style='margin:0 0 14px'>कुल डाउनलोड: <b id='dlTotal'>0</b></p>
        <div class='table-wrap'>
          <table class='utable'>
            <thead><tr><th>#</th><th>पोस्टर</th><th>डाउनलोड</th></tr></thead>
            <tbody id='dlBody'></tbody>
          </table>
        </div>
        <p id='dlEmpty' class='muted' hidden>अभी कोई डाउनलोड नहीं।</p>
      </div>

      <div class='au-card card' id='listCard' hidden>
        <div class='list-head'>
          <h2>सभी यूज़र</h2>
          <input id='search' class='search' type='text' placeholder='नाम / ईमेल खोजें...' />
        </div>
        <div class='table-wrap'>
          <table class='utable'>
            <thead><tr><th>यूज़र</th><th>प्लान</th><th>जॉइन</th><th></th></tr></thead>
            <tbody id='uBody'></tbody>
          </table>
        </div>
        <p id='listEmpty' class='muted' hidden>अभी कोई यूज़र नहीं।</p>
      </div>
    </div>
  </section>
</Layout>

<style>
  .au-wrap { min-height: 66vh; padding: 40px 20px; background: var(--grad-soft); }
  .au-inner { max-width: 760px; margin: 0 auto; display: flex; flex-direction: column; gap: 18px; }
  .au-card { padding: 26px 24px; background: #fff; }
  .au-card h1 { font-size: 21px; font-weight: 800; display: flex; align-items: center; gap: 9px; }
  .au-card h2 { font-size: 17px; font-weight: 800; margin-bottom: 14px; }
  .au-sub { color: var(--muted); font-size: 13.5px; margin: 8px 0 20px; line-height: 1.6; }
  .au-label { display: block; font-size: 13.5px; font-weight: 700; }
  .key-row { display: flex; gap: 10px; margin-top: 8px; }
  .key-row input { flex: 1; border: 1px solid var(--line); border-radius: 10px; padding: 12px 14px; font-family: inherit; font-size: 15px; outline: none; }
  .key-row input:focus { border-color: var(--purple); }
  .fld input { width: 100%; border: 1px solid var(--line); border-radius: 10px; padding: 12px 14px; font-family: inherit; font-size: 15px; outline: none; margin-bottom: 12px; }

  .stats { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin-top: 18px; }
  .stat { background: var(--bg); border: 1px solid var(--line); border-radius: 12px; padding: 14px; text-align: center; }
  .stat .num { display: block; font-size: 24px; font-weight: 800; color: var(--purple); }
  .stat .lbl { font-size: 12.5px; color: var(--muted); }

  .au-btns { display: flex; gap: 10px; }
  .au-btns .btn { flex: 1; }

  .list-head { display: flex; align-items: center; justify-content: space-between; gap: 12px; margin-bottom: 14px; flex-wrap: wrap; }
  .search { border: 1px solid var(--line); border-radius: 10px; padding: 9px 12px; font-family: inherit; font-size: 14px; outline: none; }
  .table-wrap { overflow-x: auto; }
  .utable { width: 100%; border-collapse: collapse; font-size: 14px; }
  .utable th { text-align: left; font-size: 12px; color: var(--muted); text-transform: uppercase; padding: 8px 10px; border-bottom: 1px solid var(--line); }
  .utable td { padding: 10px; border-bottom: 1px solid var(--line); vertical-align: middle; }
  .u-cell { display: flex; align-items: center; gap: 10px; }
  .u-av { width: 36px; height: 36px; border-radius: 9px; background: var(--grad); color: #fff; display: grid; place-items: center; font-weight: 800; font-size: 15px; flex-shrink: 0; background-size: cover; background-position: center; overflow: hidden; }
  .u-name { font-weight: 700; }
  .u-email { font-size: 12px; color: var(--muted); word-break: break-all; }
  .u-since { font-size: 12.5px; color: var(--muted); white-space: nowrap; }
  .btn-mini { font-family: inherit; font-weight: 700; font-size: 12.5px; padding: 7px 12px; border-radius: 8px; border: none; cursor: pointer; white-space: nowrap; }
  .to-pro { background: var(--gold); color: #3a2a00; }
  .to-free { background: #FEE2E2; color: #B91C1C; }

  .au-msg { margin-top: 16px; font-size: 13.5px; font-weight: 600; padding: 11px 14px; border-radius: 10px; line-height: 1.5; }
  .au-msg.err { background: #FEE2E2; color: #B91C1C; }
  .au-msg.ok { background: #DCFCE7; color: #166534; }
  .muted { color: var(--muted); font-size: 14px; padding: 8px 0; }
</style>

<script is:inline>
  (function () {
    var KEY = 'ph_admin_key';
    var keyInput = document.getElementById('adminKey');
    var emailInput = document.getElementById('userEmail');
    var msg = document.getElementById('auMsg');
    var USERS = [];

    var saved = sessionStorage.getItem(KEY);
    if (saved) keyInput.value = saved;

    function show(text, kind) { msg.textContent = text; msg.className = 'au-msg ' + kind; msg.hidden = false; }
    function esc(s) { var d = document.createElement('div'); d.textContent = (s == null ? '' : s); return d.innerHTML; }
    function fmtDate(s) { if (!s) return '—'; try { return new Date(s).toLocaleDateString('hi-IN', { day: 'numeric', month: 'short', year: 'numeric' }); } catch (e) { return '—'; } }

    function renderStats(d) {
      document.getElementById('stats').hidden = false;
      document.getElementById('stTotal').textContent = d.total || 0;
      document.getElementById('stPro').textContent = d.pro || 0;
      document.getElementById('stFree').textContent = d.free || 0;
    }

    function renderList(filter) {
      var body = document.getElementById('uBody');
      var empty = document.getElementById('listEmpty');
      document.getElementById('listCard').hidden = false;
      var f = (filter || '').toLowerCase();
      var rows = USERS.filter(function (u) {
        return !f || (u.name || '').toLowerCase().indexOf(f) >= 0 || (u.email || '').toLowerCase().indexOf(f) >= 0;
      });
      body.innerHTML = '';
      empty.hidden = rows.length > 0;
      rows.forEach(function (u) {
        var tr = document.createElement('tr');
        var initial = (u.name || 'U').trim().charAt(0).toUpperCase();
        var avStyle = u.avatar ? (" style=\"background-image:url('" + esc(u.avatar) + "')\"") : '';
        var avText = u.avatar ? '' : initial;
        var isBiz = u.plan === 'business';
        var isPro = u.plan === 'pro' || isBiz;
        var badge = isBiz ? '<span class="badge badge-pro">BUSINESS</span>' : (isPro ? '<span class="badge badge-pro">PRO</span>' : '<span class="badge badge-free">FREE</span>');
        var btn = isPro
          ? '<button class="btn-mini to-free" data-email="' + esc(u.email) + '" data-plan="free">Free करें</button>'
          : '<button class="btn-mini to-pro" data-email="' + esc(u.email) + '" data-plan="pro">Pro चालू</button>';
        tr.innerHTML = '<td><div class="u-cell"><span class="u-av"' + avStyle + '>' + avText + '</span>' +
          '<div><div class="u-name">' + esc(u.name || '—') + '</div><div class="u-email">' + esc(u.email) + '</div></div></div></td>' +
          '<td>' + badge + '</td><td class="u-since">' + fmtDate(u.createdAt) + '</td><td>' + btn + '</td>';
        body.appendChild(tr);
      });
      body.querySelectorAll('.btn-mini').forEach(function (b) {
        b.addEventListener('click', function () { setPlan(b.getAttribute('data-email'), b.getAttribute('data-plan')); });
      });
    }

    function loadDownloadStats() {
      fetch('/api/track-download').then(function (r) { return r.json(); }).then(function (d) {
        document.getElementById('dlCard').hidden = false;
        document.getElementById('dlTotal').textContent = (d.total || 0).toLocaleString('en-IN');
        var body = document.getElementById('dlBody');
        var empty = document.getElementById('dlEmpty');
        var top = d.top || [];
        body.innerHTML = '';
        empty.hidden = top.length > 0;
        top.forEach(function (t, i) {
          var tr = document.createElement('tr');
          tr.innerHTML = '<td>' + (i + 1) + '</td><td>' + esc(t.title) + '</td><td><b>' + (t.count || 0) + '</b></td>';
          body.appendChild(tr);
        });
      }).catch(function () {});
    }

    function loadUsers() {
      var key = keyInput.value.trim();
      if (!key) { show('Admin Key डालें।', 'err'); return; }
      sessionStorage.setItem(KEY, key);
      show('लोड हो रहा है...', 'ok');
      fetch('/api/admin/users', { headers: { 'x-admin-key': key } })
        .then(function (r) { return r.json().then(function (j) { return { ok: r.ok, j: j }; }); })
        .then(function (res) {
          if (!res.ok) { show((res.j && res.j.message) || 'लोड नहीं हुआ।', 'err'); return; }
          USERS = res.j.users || [];
          renderStats(res.j);
          renderList('');
          loadDownloadStats();
          msg.hidden = true;
        }).catch(function () { show('नेटवर्क समस्या।', 'err'); });
    }

    function setPlan(email, plan) {
      var key = keyInput.value.trim();
      if (!key) { show('Admin Key डालें।', 'err'); return; }
      if (!email) { show('ईमेल डालें।', 'err'); return; }
      sessionStorage.setItem(KEY, key);
      show('रुकिए...', 'ok');
      fetch('/api/admin/set-plan', {
        method: 'POST',
        headers: { 'content-type': 'application/json', 'x-admin-key': key },
        body: JSON.stringify({ email: email, plan: plan }),
      }).then(function (r) { return r.json().then(function (j) { return { ok: r.ok, j: j }; }); })
        .then(function (res) {
          if (res.ok) {
            show((res.j.name || email) + ' का प्लान अब: ' + (res.j.plan === 'business' ? 'BUSINESS ✅' : (res.j.plan === 'pro' ? 'PRO ✅' : 'FREE')), 'ok');
            loadUsers();
          } else { show((res.j && res.j.message) || 'एरर।', 'err'); }
        }).catch(function () { show('नेटवर्क समस्या।', 'err'); });
    }

    document.getElementById('loadBtn').addEventListener('click', loadUsers);
    keyInput.addEventListener('keydown', function (e) { if (e.key === 'Enter') loadUsers(); });
    document.getElementById('proBtn').addEventListener('click', function () { setPlan(emailInput.value.trim(), 'pro'); });
    document.getElementById('bizBtn').addEventListener('click', function () { setPlan(emailInput.value.trim(), 'business'); });
    document.getElementById('freeBtn').addEventListener('click', function () { setPlan(emailInput.value.trim(), 'free'); });
    document.getElementById('search').addEventListener('input', function () { renderList(this.value); });

    if (saved) loadUsers();
  })();
</script>
