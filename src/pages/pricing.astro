---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
import { pricing, payment } from '../data/site.js';

const freeFeatures = [
  { ok: true, text: 'सभी फ्री टेम्पलेट्स' },
  { ok: true, text: 'नाम, फोटो व संदेश जोड़ें' },
  { ok: true, text: 'ब्राउज़र में सेव (लोकल)' },
  { ok: false, text: 'वॉटरमार्क हटाएं' },
  { ok: false, text: 'क्लाउड लॉगिन व सिंक' },
  { ok: false, text: 'HD डाउनलोड व Pro टेम्पलेट' },
];
const proFeatures = [
  'सभी फ्री + Pro टेम्पलेट्स',
  'कोई वॉटरमार्क नहीं',
  'क्लाउड लॉगिन — कहीं भी सेव',
  'HD / फुल क्वालिटी डाउनलोड',
  'प्रोफाइल एक बार — हर पोस्टर में ऑटो',
  'प्रायॉरिटी सपोर्ट',
];
---
<Layout title='प्राइसिंग — Daily PosterHub'>
  <section class='page-hero'>
    <div class='container'>
      <h1>सिंपल और <span class='grad-text'>सस्ती</span> प्राइसिंग</h1>
      <p>फ्री में शुरू करें, जब चाहें Pro पर अपग्रेड करें</p>
    </div>
  </section>

  <section class='section' style='padding-top:34px'>
    <div class='container'>
      <div class='plans'>
        <!-- FREE -->
        <div class='plan card'>
          <h3>फ्री</h3>
          <div class='price'><span class='amt'>{pricing.currency}0</span><span class='per'>/हमेशा</span></div>
          <p class='plan-note'>शुरुआत के लिए बेहतरीन</p>
          <ul class='feat'>
            {freeFeatures.map((f) => (
              <li class={f.ok ? 'yes' : 'no'}>
                <Icon name={f.ok ? 'check' : 'close'} size={16} /> {f.text}
              </li>
            ))}
          </ul>
          <a href='/posters' class='btn btn-outline btn-lg'>फ्री में शुरू करें</a>
        </div>

        <!-- PRO -->
        <div class='plan plan-pro card'>
          <span class='ribbon'><Icon name='crown' size={14} /> सबसे लोकप्रिय</span>
          <h3>Pro</h3>
          <div class='price'>
            <span class='amt'>{pricing.currency}{pricing.monthly}</span><span class='per'>/माह</span>
          </div>
          <p class='plan-note'>या {pricing.currency}{pricing.yearly}/साल — <strong>2 महीने फ्री</strong></p>
          <ul class='feat'>
            {proFeatures.map((f) => (
              <li class='yes'><Icon name='check' size={16} /> {f}</li>
            ))}
          </ul>
          <a href='#pay' class='btn btn-gold btn-lg'><Icon name='crown' size={16} /> Pro खरीदें</a>
        </div>
      </div>

      <!-- UPI PAYMENT BOX -->
      <div class='pay-box card' id='pay'>
        <div class='pay-head'>
          <span class='pay-icon'><Icon name='credit-card' size={22} /></span>
          <div>
            <h3>UPI से भुगतान करें</h3>
            <p>नीचे दिए UPI ID या नंबर पर भुगतान करके Pro एक्टिवेट करवाएं</p>
          </div>
        </div>
        <div class='pay-rows'>
          <div class='pay-row'>
            <span class='pay-label'>UPI ID</span>
            <span class='pay-value'>{payment.upiId}</span>
            <button class='btn btn-outline btn-sm copy-btn' data-copy={payment.upiId}>कॉपी</button>
          </div>
          <div class='pay-row'>
            <span class='pay-label'>UPI नंबर</span>
            <span class='pay-value'>{payment.upiNumber}</span>
            <button class='btn btn-outline btn-sm copy-btn' data-copy={payment.upiNumber}>कॉपी</button>
          </div>
          <div class='pay-row'>
            <span class='pay-label'>नाम</span>
            <span class='pay-value'>{payment.payeeName}</span>
          </div>
        </div>
        <p class='pay-note'>
          <Icon name='shield-check' size={16} />
          भुगतान के बाद screenshot हमें भेजें — आपका Pro एक्टिवेट कर दिया जाएगा।
        </p>
      </div>

      <p class='guarantee'><Icon name='shield' size={15} /> सुरक्षित भुगतान • कभी भी कैंसिल करें • कोई छिपा शुल्क नहीं</p>
    </div>
  </section>
</Layout>

<style>
  .page-hero { background: var(--grad-soft); padding: 44px 0; text-align: center; }
  .page-hero h1 { font-size: 36px; font-weight: 800; }
  .page-hero p { color: var(--muted); margin-top: 8px; }

  .plans { display: grid; grid-template-columns: repeat(2, minmax(0,1fr)); gap: 24px; max-width: 800px; margin: 0 auto; }
  .plan { padding: 34px 30px; }
  .plan h3 { font-size: 22px; font-weight: 800; }
  .price { margin: 14px 0 4px; }
  .amt { font-size: 44px; font-weight: 800; }
  .per { color: var(--muted); font-size: 15px; }
  .plan-note { color: var(--muted); font-size: 14px; margin-bottom: 20px; }

  .feat { display: flex; flex-direction: column; gap: 12px; margin-bottom: 26px; }
  .feat li { display: flex; align-items: center; gap: 9px; font-size: 15px; }
  .feat .yes :global(.icon) { color: #16A34A; }
  .feat .no { color: var(--muted); }
  .feat .no :global(.icon) { color: #CBD5E1; }

  .plan .btn { width: 100%; }
  .plan-pro { position: relative; border: 2px solid var(--purple); box-shadow: var(--shadow); }
  .ribbon { position: absolute; top: -14px; left: 50%; transform: translateX(-50%); display: inline-flex; align-items: center; gap: 5px; background: var(--gold); color: #3a2a00; font-size: 13px; font-weight: 700; padding: 6px 16px; border-radius: 999px; white-space: nowrap; }

  /* UPI box */
  .pay-box { max-width: 800px; margin: 30px auto 0; padding: 28px 30px; }
  .pay-head { display: flex; align-items: flex-start; gap: 14px; margin-bottom: 20px; }
  .pay-icon { display: grid; place-items: center; width: 46px; height: 46px; border-radius: 12px; background: #EDE9FE; color: var(--purple); flex-shrink: 0; }
  .pay-head h3 { font-size: 20px; font-weight: 800; }
  .pay-head p { color: var(--muted); font-size: 14px; margin-top: 4px; }
  .pay-rows { display: flex; flex-direction: column; gap: 12px; }
  .pay-row { display: flex; align-items: center; gap: 14px; background: var(--bg); border: 1px solid var(--line); border-radius: 12px; padding: 14px 16px; }
  .pay-label { font-size: 13px; color: var(--muted); width: 90px; flex-shrink: 0; }
  .pay-value { font-size: 16px; font-weight: 700; flex: 1; word-break: break-all; }
  .copy-btn { flex-shrink: 0; }
  .pay-note { display: flex; align-items: center; gap: 8px; font-size: 13.5px; color: var(--muted); margin-top: 18px; }
  .pay-note :global(.icon) { color: #16A34A; flex-shrink: 0; }

  .guarantee { display: flex; align-items: center; justify-content: center; gap: 8px; color: var(--muted); font-size: 14px; margin-top: 26px; }

  @media (max-width: 640px) {
    .plans { grid-template-columns: 1fr; }
    .pay-row { flex-wrap: wrap; }
    .pay-label { width: 100%; }
  }
</style>

<script>
  document.querySelectorAll('.copy-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const text = btn.getAttribute('data-copy');
      try {
        await navigator.clipboard.writeText(text);
        const old = btn.textContent;
        btn.textContent = 'कॉपी हुआ!';
        setTimeout(() => { btn.textContent = old; }, 1500);
      } catch (e) {}
    });
  });
</script>
