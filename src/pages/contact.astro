---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import Icon from '../components/Icon.astro';
import { contact, payment } from '../data/site.js';
---
<Layout title='संपर्क करें — Daily PosterHub'>
  <PageHero
    title='संपर्क <span class="grad-text">करें</span>'
    crumb='संपर्क करें'
    subtitle='कोई सवाल या सुझाव? हमें मैसेज करें — हम जल्दी जवाब देंगे'
  />
  <section class='section'>
    <div class='container contact-grid'>
      <!-- Info -->
      <div class='info'>
        <a href={'tel:' + contact.phoneRaw} class='info-row card'>
          <span class='info-icon'><Icon name='phone' size={20} /></span>
          <div><span class='info-label'>फोन / WhatsApp</span><strong>{contact.phone}</strong></div>
        </a>
        <a href={'mailto:' + contact.email} class='info-row card'>
          <span class='info-icon'><Icon name='mail' size={20} /></span>
          <div><span class='info-label'>ईमेल</span><strong>{contact.email}</strong></div>
        </a>
        <div class='info-row card'>
          <span class='info-icon'><Icon name='map-pin' size={20} /></span>
          <div><span class='info-label'>लोकेशन</span><strong>{contact.location}</strong></div>
        </div>
        <div class='info-row card'>
          <span class='info-icon'><Icon name='clock' size={20} /></span>
          <div><span class='info-label'>समय</span><strong>{contact.hours}</strong></div>
        </div>
        <div class='info-row card'>
          <span class='info-icon'><Icon name='credit-card' size={20} /></span>
          <div><span class='info-label'>Pro भुगतान (UPI)</span><strong>{payment.upiId} • {payment.upiNumber}</strong></div>
        </div>
      </div>

      <!-- Form -->
      <form id='contactForm' class='c-form card'>
        <h3>मैसेज भेजें</h3>
        <label>नाम<input id='contactName' type='text' placeholder='आपका नाम' required /></label>
        <label>ईमेल<input id='contactEmail' type='email' placeholder='you@example.com' required /></label>
        <label>फोन<input id='contactPhone' type='tel' placeholder='मोबाइल नंबर' /></label>
        <label>मैसेज<textarea id='contactMessage' rows='4' placeholder='अपना सवाल या सुझाव लिखें...' required></textarea></label>
        <button class='btn btn-primary btn-lg' type='submit'><Icon name='send' size={16} /> भेजें</button><p id='contactStatus' class='contact-status'></p>
      </form>
    </div>
  </section>
</Layout>

<style>
  .contact-grid { display: grid; grid-template-columns: 1fr 1.1fr; gap: 24px; align-items: start; }
  .info { display: flex; flex-direction: column; gap: 14px; }
  .info-row { display: flex; align-items: center; gap: 14px; padding: 16px 18px; }
  .info-icon { display: grid; place-items: center; width: 46px; height: 46px; border-radius: 12px; background: #EDE9FE; color: var(--purple); flex-shrink: 0; }
  .info-label { display: block; font-size: 12.5px; color: var(--muted); }
  .info-row strong { font-size: 15px; word-break: break-all; }

  .c-form { padding: 28px; display: flex; flex-direction: column; gap: 14px; }
  .c-form h3 { font-size: 20px; font-weight: 800; }
  .c-form label { font-size: 14px; font-weight: 600; display: flex; flex-direction: column; gap: 6px; }
  .c-form input, .c-form textarea { border: 1px solid var(--line); border-radius: 10px; padding: 12px 14px; font-family: inherit; font-size: 15px; outline: none; resize: vertical; }
  .c-form input:focus, .c-form textarea:focus { border-color: var(--purple); }
  .c-form .btn { gap: 8px; margin-top: 4px; }
  .contact-status { min-height:20px; color:#166534; font-size:13px; font-weight:700; }
  .contact-status.err { color:#b91c1c; }
  @media (max-width: 820px) { .contact-grid { grid-template-columns: 1fr; } }
</style>
<script is:inline>(function(){var f=document.getElementById('contactForm');if(!f)return;f.addEventListener('submit',function(e){e.preventDefault();var st=document.getElementById('contactStatus'),b=f.querySelector('button');b.disabled=true;st.textContent='भेजा जा रहा है...';fetch('/api/contact',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify({name:contactName.value,email:contactEmail.value,phone:contactPhone.value,message:contactMessage.value})}).then(function(r){return r.json().then(function(j){return{ok:r.ok,j:j}})}).then(function(x){st.textContent=x.ok?'आपका मैसेज भेज दिया गया है।':(x.j.message||'मैसेज नहीं भेजा गया।');st.className='contact-status'+(x.ok?'':' err');if(x.ok)f.reset()}).catch(function(){st.textContent='नेटवर्क समस्या।';st.className='contact-status err'}).finally(function(){b.disabled=false})})})();</script>
