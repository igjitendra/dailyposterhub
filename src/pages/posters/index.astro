---
import Layout from '../../layouts/Layout.astro';
import Icon from '../../components/Icon.astro';
import { categories, heroPreviews } from '../../data/site.js';
const cats = categories.filter((c) => c.slug !== 'all');
const fallback = [
  { id:'morning', img:heroPreviews[0].img, title:'सुप्रभात', category:'गुड मॉर्निंग', type:'free', description:'हर सुबह की प्यारी शुभकामना', posterDate:'', createdAt:'2026-07-11' },
  { id:'birthday', img:heroPreviews[1].img, title:'जन्मदिन शुभकामनाएं', category:'जन्मदिन', type:'pro', description:'अपनों के लिए खास बर्थडे पोस्टर', posterDate:'', createdAt:'2026-07-10' },
  { id:'ram', img:heroPreviews[2].img, title:'जय श्री राम', category:'धार्मिक', type:'free', description:'भक्ति और आस्था का पोस्टर', posterDate:'', createdAt:'2026-07-09' },
  { id:'wish', img:heroPreviews[0].img, title:'आज की शुभकामना', category:'शुभकामनाएं', type:'pro', description:'नाम जोड़कर तुरंत शेयर करें', posterDate:'', createdAt:'2026-07-08' },
  { id:'festival', img:heroPreviews[2].img, title:'पर्व विशेष', category:'त्योहार', type:'free', description:'त्योहार के लिए सुंदर design', posterDate:'2026-07-29', createdAt:'2026-07-07' },
  { id:'offer', img:heroPreviews[1].img, title:'खास ऑफर', category:'बिज़नेस', type:'pro', description:'अपने business offer का poster', posterDate:'', createdAt:'2026-07-06' },
];
---
<Layout title='सभी हिंदी पोस्टर — Daily PosterHub' description='हजारों हिंदी poster templates खोजें, category filter करें और अपना नाम व फोटो जोड़कर डाउनलोड करें।'>
  <section class='library-hero'>
    <div class='hero-mesh'></div>
    <div class='container hero-layout'>
      <div class='hero-copy'>
        <div class='poster-breadcrumb'><a href='/'>होम</a><span>/</span><b>पोस्टर लाइब्रेरी</b></div>
        <span class='hero-label'><Icon name='sparkles' size={15} /> हर दिन नए designs</span>
        <h1>हर मौके के लिए<br/><span>दमदार हिंदी पोस्टर</span></h1>
        <p>Template चुनें, अपनी फोटो और नाम लगाएं—फिर WhatsApp, Instagram या Facebook के लिए तैयार poster डाउनलोड करें।</p>
        <div class='hero-actions'><a href='#posterCollection' class='btn btn-primary btn-lg'><Icon name='grid' size={18}/> पोस्टर देखें</a><a href='/categories' class='hero-link'>Categories खोलें <Icon name='arrow-right' size={16}/></a></div>
      </div>
      <div class='hero-dashboard'>
        <div class='dashboard-top'><span>POSTER LIBRARY</span><b>Live Collection</b></div>
        <div class='metric-grid'>
          <div><span class='metric-icon purple'><Icon name='image' size={20}/></span><strong id='heroTotal'>—</strong><small>कुल पोस्टर</small></div>
          <div><span class='metric-icon green'><Icon name='download' size={20}/></span><strong id='heroFree'>—</strong><small>Free designs</small></div>
          <div><span class='metric-icon gold'><Icon name='crown' size={20}/></span><strong id='heroPro'>—</strong><small>Pro designs</small></div>
        </div>
        <div class='dashboard-note'><span><Icon name='check-circle' size={17}/></span><p><b>Mobile-ready editor</b><small>नाम, फोटो और branding तुरंत जोड़ें</small></p></div>
      </div>
    </div>
  </section>

  <section class='poster-library' id='posterCollection'>
    <div class='container'>
      <div class='control-shell'>
        <div class='search-row'>
          <div class='power-search'><Icon name='search' size={20}/><input id='posterSearch' type='search' placeholder='पोस्टर खोजें—जैसे जन्मदिन, धार्मिक, ऑफर...' aria-label='पोस्टर खोजें'/><button id='clearSearch' type='button' aria-label='खोज साफ करें'>×</button></div>
          <div class='type-tabs' id='typeTabs' aria-label='Poster type'><button class='active' data-type='all'>सभी</button><button data-type='free'>Free</button><button data-type='pro'>Pro</button></div>
          <select id='sortPosters' class='sort-select' aria-label='पोस्टर क्रम'><option value='newest'>नए पहले</option><option value='title'>नाम A–Z</option><option value='category'>Category</option></select>
        </div>
        <div class='filter-head'><div><span class='filter-kicker'>FILTER BY CATEGORY</span><p>अपनी जरूरत की category चुनें</p></div><a href='/categories'>सभी categories <Icon name='arrow-right' size={15}/></a></div>
        <div class='category-rail' id='catFilters'>
          <button class='category-chip active' data-cat='__all__'><span><Icon name='grid' size={16}/></span>सभी</button>
          <button class='category-chip' data-cat='__week__'><span><Icon name='clock' size={16}/></span>अगले 7 दिन</button>
          <button class='category-chip' data-cat='__favorites__'><span><Icon name='heart' size={16}/></span>पसंदीदा</button>
          {cats.map((c) => <button class='category-chip' data-cat={c.name}><span style={'color:'+c.color+';background:'+c.bg}><Icon name={c.icon} size={16}/></span>{c.name}</button>)}
        </div>
      </div>

      <div class='week-panel' id='weekPanel' hidden>
        <div class='week-copy'><span class='week-icon'><Icon name='clock' size={20}/></span><div><b>अगले 7 दिनों के पोस्टर</b><p>आज से सातवें दिन तक उपलब्ध special posters</p></div></div>
        <div class='week-dates' id='weekDates'></div>
      </div>

      <div class='collection-toolbar'>
        <div><span class='collection-kicker'>CURATED FOR YOU</span><h2 id='resultTitle'>सभी पोस्टर</h2><p id='resultCount'>पोस्टर लोड हो रहे हैं...</p></div>
        <button id='viewToggle' class='view-toggle' type='button' aria-label='Compact view'><Icon name='grid' size={17}/><span>Compact</span></button>
      </div>

      <div class='poster-grid' id='tplGrid' aria-live='polite'>
        {Array.from({length:8}).map(() => <div class='poster-skeleton'><span></span><i></i><i></i></div>)}
      </div>
      <div class='empty-state' id='emptyBox' hidden><span><Icon name='search' size={29}/></span><h2 id='emptyTitle'>कोई poster नहीं मिला</h2><p>दूसरी category, type या keyword आज़माएं।</p><button class='btn btn-outline' id='resetFilters'>सभी पोस्टर देखें</button></div>
      <div class='load-more-wrap'><button id='loadMore' class='load-more' type='button' hidden>और पोस्टर दिखाएं <Icon name='chevron-down' size={17}/></button></div>
    </div>
  </section>

  <section class='library-cta'><div class='container'><div><span>POSTERHUB PRO</span><h2>बिना watermark HD पोस्टर बनाएं</h2><p>Premium templates, HD download और business branding unlock करें।</p></div><a href='/pricing' class='btn btn-white btn-lg'><Icon name='crown' size={17}/> Pro देखें</a></div></section>
</Layout>
<script id='fallbackData' type='application/json' set:html={JSON.stringify(fallback)}></script>
<style is:global>
.library-hero{position:relative;overflow:hidden;padding:64px 0 70px;background:linear-gradient(135deg,#faf9ff 0%,#eeeaff 55%,#e9f0ff 100%)}.hero-mesh{position:absolute;inset:0;opacity:.45;background-image:radial-gradient(#9f8cff 1px,transparent 1px);background-size:24px 24px;mask-image:linear-gradient(to right,transparent,#000 45%,transparent)}.library-hero:before,.library-hero:after{content:'';position:absolute;border-radius:50%;filter:blur(1px)}.library-hero:before{width:380px;height:380px;left:-220px;top:-180px;background:#dcd4ff}.library-hero:after{width:330px;height:330px;right:-180px;bottom:-210px;background:#cbdcff}.hero-layout{position:relative;z-index:1;display:grid;grid-template-columns:1.05fr .95fr;align-items:center;gap:70px}.poster-breadcrumb{display:flex;align-items:center;gap:8px;color:var(--muted);font-size:12px}.poster-breadcrumb a{color:var(--purple);font-weight:800}.hero-label{display:inline-flex;align-items:center;gap:7px;margin-top:22px;padding:7px 12px;border:1px solid #d9d0ff;border-radius:999px;background:rgba(255,255,255,.78);color:var(--purple);font-size:12px;font-weight:800}.hero-copy h1{margin-top:15px;font-size:clamp(39px,4.5vw,60px);line-height:1.1;letter-spacing:-1.6px;font-weight:800}.hero-copy h1 span{color:var(--purple)}.hero-copy>p{max-width:620px;margin-top:17px;color:var(--muted);font-size:16px;line-height:1.75}.hero-actions{display:flex;align-items:center;gap:20px;margin-top:27px}.hero-link{display:inline-flex;align-items:center;gap:7px;color:var(--purple);font-size:14px;font-weight:800}.hero-dashboard{padding:24px;border:1px solid rgba(255,255,255,.9);border-radius:20px;background:rgba(255,255,255,.76);box-shadow:0 22px 55px rgba(60,42,125,.13);backdrop-filter:blur(12px)}.dashboard-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:18px}.dashboard-top span{color:var(--purple);font:800 10px Poppins,sans-serif;letter-spacing:.12em}.dashboard-top b{padding:5px 9px;border-radius:7px;background:#dcfce7;color:#15803d;font-size:10px}.metric-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px}.metric-grid>div{padding:16px;border:1px solid var(--line);border-radius:14px;background:#fff}.metric-icon{display:grid;place-items:center;width:38px;height:38px;border-radius:11px}.metric-icon.purple{background:#ede9fe;color:#7c3aed}.metric-icon.green{background:#dcfce7;color:#16a34a}.metric-icon.gold{background:#fff3c4;color:#b77900}.metric-grid strong{display:block;margin-top:12px;font:800 25px Poppins,sans-serif}.metric-grid small{display:block;margin-top:1px;color:var(--muted);font-size:10px}.dashboard-note{display:flex;align-items:center;gap:11px;margin-top:12px;padding:13px 14px;border-radius:13px;background:linear-gradient(100deg,#f2efff,#fff)}.dashboard-note>span{display:grid;place-items:center;width:37px;height:37px;border-radius:10px;background:#7c3aed;color:#fff}.dashboard-note p{display:grid}.dashboard-note b{font-size:13px}.dashboard-note small{color:var(--muted);font-size:10px}.poster-library{padding:34px 0 82px;background:#f8f7fc}.control-shell{position:sticky;top:82px;z-index:35;padding:18px;border:1px solid var(--line);border-radius:18px;background:rgba(255,255,255,.94);box-shadow:0 12px 32px rgba(40,28,86,.08);backdrop-filter:blur(14px)}.search-row{display:grid;grid-template-columns:minmax(280px,1fr) auto 150px;gap:11px}.power-search{display:flex;align-items:center;gap:10px;padding:0 13px;border:1px solid #dcd6ed;border-radius:11px;background:#fbfaff}.power-search svg{color:var(--purple)}.power-search input{width:100%;height:46px;border:0;outline:0;background:transparent;font:600 13px inherit}.power-search button{border:0;background:transparent;color:#9892a9;font-size:24px;cursor:pointer}.type-tabs{display:flex;padding:4px;border:1px solid var(--line);border-radius:11px;background:#f5f3fa}.type-tabs button{min-width:61px;border:0;border-radius:8px;background:transparent;color:var(--muted);font:800 12px inherit;cursor:pointer}.type-tabs button.active{background:#fff;color:var(--purple);box-shadow:0 2px 8px rgba(0,0,0,.07)}.sort-select{border:1px solid var(--line);border-radius:11px;background:#fff;padding:0 11px;font:700 12px inherit;color:var(--ink);outline:0}.filter-head{display:flex;align-items:end;justify-content:space-between;margin:18px 1px 10px}.filter-kicker,.collection-kicker{color:var(--purple);font:800 10px Poppins,sans-serif;letter-spacing:.1em}.filter-head p{margin-top:2px;color:var(--muted);font-size:11px}.filter-head a{display:flex;align-items:center;gap:5px;color:var(--purple);font-size:11px;font-weight:800}.category-rail{display:flex;gap:8px;overflow-x:auto;padding:1px 1px 4px;scrollbar-width:thin}.category-chip{display:inline-flex;align-items:center;gap:7px;flex:none;min-height:40px;padding:5px 11px 5px 6px;border:1px solid var(--line);border-radius:10px;background:#fff;color:#59546a;font:700 12px inherit;cursor:pointer;transition:.18s}.category-chip>span{display:grid;place-items:center;width:29px;height:29px;border-radius:8px;background:#ede9fe;color:var(--purple)}.category-chip:hover,.category-chip.active{border-color:#8b6cff;color:var(--purple);box-shadow:0 6px 14px rgba(124,58,237,.1)}.category-chip.active{background:#f4f0ff}.week-panel{display:flex;align-items:center;gap:20px;margin:22px 0;padding:17px;border:1px solid #c7d2fe;border-radius:16px;background:linear-gradient(110deg,#eef2ff,#fff)}.week-copy{display:flex;align-items:center;gap:11px;min-width:245px}.week-icon{display:grid;place-items:center;width:42px;height:42px;border-radius:12px;background:#4f46e5;color:#fff}.week-copy b{font-size:14px}.week-copy p{margin-top:2px;color:var(--muted);font-size:10px}.week-dates{display:flex;gap:7px;overflow-x:auto}.mini-date{flex:none;min-width:66px;padding:8px;border:1px solid #dfe3ff;border-radius:10px;background:#fff;text-align:center}.mini-date b{display:block;font:800 17px/1 Poppins,sans-serif}.mini-date span{display:block;margin-top:4px;color:#4f46e5;font-size:9px;font-weight:800}.mini-date{cursor:pointer}.mini-date.active{border-color:#4f46e5;background:#4f46e5;color:#fff}.mini-date.active span{color:#e0e7ff}.view-toggle.active{border-color:#7c3aed;background:#ede9fe;color:#7c3aed}.collection-toolbar{display:flex;align-items:end;justify-content:space-between;margin:34px 0 20px}.collection-toolbar h2{margin-top:4px;font-size:30px;line-height:1.2}.collection-toolbar p{margin-top:4px;color:var(--muted);font-size:12px}.view-toggle{display:flex;align-items:center;gap:7px;min-height:40px;padding:0 12px;border:1px solid var(--line);border-radius:10px;background:#fff;color:var(--muted);font:700 11px inherit;cursor:pointer}.poster-grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:17px}.poster-grid.compact{grid-template-columns:repeat(5,minmax(0,1fr))}.poster-card{overflow:hidden;border:1px solid var(--line);border-radius:16px;background:#fff;box-shadow:0 3px 12px rgba(37,27,80,.05);transition:.23s}.poster-card:hover{transform:translateY(-6px);border-color:#cfc2ff;box-shadow:0 18px 31px rgba(50,32,115,.13)}.poster-image{position:relative;overflow:hidden;aspect-ratio:3/4;background:#ece9f7}.poster-image img{width:100%;height:100%;object-fit:cover;transition:transform .38s}.poster-card:hover img{transform:scale(1.045)}.poster-badge{position:absolute;top:10px;left:10px;padding:5px 8px;border-radius:7px;font:800 9px Poppins,sans-serif;letter-spacing:.05em}.poster-badge.free{background:#dcfce7;color:#166534}.poster-badge.pro{background:#ffe9a8;color:#704d00}.fav-btn{position:absolute;top:9px;right:9px;display:grid;place-items:center;width:36px;height:36px;border:0;border-radius:10px;background:rgba(255,255,255,.93);color:#6b647d;font-size:21px;box-shadow:0 4px 13px rgba(0,0,0,.13);cursor:pointer}.fav-btn.active{background:#fce7f3;color:#db2777}.image-overlay{position:absolute;inset:auto 0 0;padding:38px 11px 11px;background:linear-gradient(transparent,rgba(20,15,43,.82));opacity:0;transform:translateY(5px);transition:.22s}.poster-card:hover .image-overlay{opacity:1;transform:none}.overlay-edit{display:flex;justify-content:center;align-items:center;min-height:39px;border-radius:9px;background:#fff;color:var(--purple);font-size:12px;font-weight:800}.poster-info{padding:13px}.poster-meta{display:flex;align-items:center;justify-content:space-between;gap:8px}.poster-category{overflow:hidden;text-overflow:ellipsis;white-space:nowrap;color:var(--purple);font-size:10px;font-weight:800}.poster-date{color:var(--muted);font-size:9px}.poster-info h3{overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;min-height:40px;margin-top:5px;font-size:15px;line-height:1.35}.poster-info p{overflow:hidden;text-overflow:ellipsis;white-space:nowrap;margin-top:3px;color:var(--muted);font-size:10.5px}.card-actions{display:grid;grid-template-columns:1fr 42px;gap:7px;margin-top:12px}.poster-edit-btn{display:flex;align-items:center;justify-content:center;min-height:42px;border-radius:10px;background:var(--grad);color:#fff;font-size:12px;font-weight:800;box-shadow:0 7px 15px rgba(124,58,237,.18)}.share-card{display:grid;place-items:center;border:1px solid #d8d1ee;border-radius:10px;background:#fff;color:var(--purple);cursor:pointer}.poster-skeleton{overflow:hidden;border-radius:16px;background:#fff;border:1px solid var(--line);padding-bottom:15px}.poster-skeleton span{display:block;aspect-ratio:3/4;background:linear-gradient(90deg,#efedf5 25%,#f8f7fb 50%,#efedf5 75%);background-size:200% 100%;animation:shimmer 1.3s infinite}.poster-skeleton i{display:block;height:12px;margin:13px 14px 0;border-radius:5px;background:#efedf5}.poster-skeleton i:last-child{width:60%;margin-top:7px}@keyframes shimmer{to{background-position:-200% 0}}.empty-state{max-width:520px;margin:30px auto;padding:55px 25px;text-align:center;border:1px dashed #cfc5ef;border-radius:18px;background:#fff}.empty-state>span{display:grid;place-items:center;width:55px;height:55px;margin:auto;border-radius:15px;background:#eeeaff;color:var(--purple)}.empty-state h2{margin-top:14px;font-size:20px}.empty-state p{margin:6px 0 18px;color:var(--muted);font-size:13px}.load-more-wrap{text-align:center}.load-more{display:inline-flex;align-items:center;gap:7px;min-height:46px;margin-top:28px;padding:0 20px;border:1px solid #cabfff;border-radius:11px;background:#fff;color:var(--purple);font:800 13px inherit;cursor:pointer}.library-cta{padding:44px 0;background:#17142a;color:#fff}.library-cta .container{display:flex;align-items:center;justify-content:space-between;gap:30px}.library-cta span{color:#a996ff;font:800 10px Poppins,sans-serif;letter-spacing:.12em}.library-cta h2{margin-top:4px;font-size:28px}.library-cta p{margin-top:4px;color:#c6c0d9;font-size:13px}.library-cta .btn{flex:none}@media(max-width:1050px){.hero-layout{gap:35px}.poster-grid{grid-template-columns:repeat(3,1fr)}.poster-grid.compact{grid-template-columns:repeat(4,1fr)}}@media(max-width:820px){.hero-layout{grid-template-columns:1fr}.hero-copy{text-align:center}.poster-breadcrumb,.hero-actions{justify-content:center}.hero-copy>p{margin-left:auto;margin-right:auto}.hero-dashboard{max-width:620px;margin:auto;width:100%}.control-shell{top:70px}.search-row{grid-template-columns:1fr auto}.sort-select{min-height:43px;grid-column:1/-1}.week-panel{align-items:flex-start;flex-direction:column}.week-copy{min-width:0}.poster-grid{grid-template-columns:repeat(2,1fr)}.poster-grid.compact{grid-template-columns:repeat(3,1fr)}}@media(max-width:560px){.library-hero{padding:43px 0 51px}.hero-copy h1{font-size:37px}.hero-copy>p{font-size:14px}.hero-actions{align-items:stretch;flex-direction:column}.hero-actions .btn{width:100%}.hero-dashboard{padding:15px}.metric-grid>div{padding:12px}.metric-grid strong{font-size:21px}.metric-grid small{font-size:8.5px}.poster-library{padding:20px 0 55px}.control-shell{position:relative;top:auto;padding:12px;margin:0 -5px;border-radius:14px}.search-row{grid-template-columns:1fr}.power-search input{height:45px}.type-tabs{min-height:44px}.type-tabs button{flex:1}.sort-select{grid-column:auto;min-height:44px}.filter-head{margin-top:14px}.filter-head p,.filter-head a{display:none}.category-chip{min-height:39px}.collection-toolbar{margin:27px 0 15px}.collection-toolbar h2{font-size:24px}.view-toggle span{display:none}.poster-grid,.poster-grid.compact{grid-template-columns:repeat(2,minmax(0,1fr));gap:10px}.poster-card{border-radius:13px}.poster-info{padding:10px}.poster-info h3{min-height:35px;font-size:13px}.poster-info p{display:none}.poster-date{display:none}.card-actions{grid-template-columns:1fr 37px;gap:5px;margin-top:9px}.poster-edit-btn{min-height:39px;font-size:11px}.share-card{min-height:39px}.fav-btn{width:32px;height:32px;font-size:18px}.image-overlay{display:none}.library-cta .container{align-items:flex-start;flex-direction:column}.library-cta .btn{width:100%}}@media(max-width:360px){.poster-grid,.poster-grid.compact{grid-template-columns:1fr}.poster-info p{display:block}}
</style>
<script is:inline>
(function(){
  var POSTERS=[],fallback=[],mode='__all__',type='all',query='',sort='newest',visible=12,compact=false,selectedDay='';
  try{fallback=JSON.parse(document.getElementById('fallbackData').textContent)||[]}catch(e){}
  var grid=document.getElementById('tplGrid'),empty=document.getElementById('emptyBox'),weekPanel=document.getElementById('weekPanel'),title=document.getElementById('resultTitle'),count=document.getElementById('resultCount'),loadMore=document.getElementById('loadMore');
  var favorites=[];try{favorites=JSON.parse(localStorage.getItem('dph_favorites')||'[]')||[]}catch(e){}
  function esc(v){var d=document.createElement('div');d.textContent=v==null?'':v;return d.innerHTML}
  function source(){return POSTERS.length?POSTERS:fallback}
  function id(p){return String(p.id||p.img||p.title)}
  function dateText(v){if(!v)return'';try{return new Intl.DateTimeFormat('hi-IN',{day:'numeric',month:'short'}).format(new Date(v+'T00:00:00'))}catch(e){return''}}
  function editorUrl(p){return '/editor?img='+encodeURIComponent(p.img||'')+'&title='+encodeURIComponent(p.title||'')+'&type='+encodeURIComponent(p.type||'free')}
  function sevenDays(){var out=[],now=new Date();now.setHours(0,0,0,0);for(var i=0;i<7;i++){var d=new Date(now);d.setDate(now.getDate()+i);var iso=new Date(d.getTime()-d.getTimezoneOffset()*60000).toISOString().slice(0,10);out.push({iso:iso,md:iso.slice(5),date:d})}return out}
  function inWeek(p){var pd=String(p.posterDate||''),md=pd.slice(5);return sevenDays().some(function(d){return pd===d.iso||md===d.md})}
  function filtered(){var list=source().filter(function(p){var cat=mode==='__all__'||(mode==='__week__'?inWeek(p):(mode==='__favorites__'?favorites.indexOf(id(p))>-1:p.category===mode));var plan=type==='all'||p.type===type;var hay=((p.title||'')+' '+(p.category||'')+' '+(p.description||'')+' '+(p.festivalName||'')).toLowerCase();var day=!selectedDay||String(p.posterDate||'')===selectedDay||String(p.posterDate||'').slice(5)===selectedDay.slice(5);return cat&&plan&&hay.indexOf(query.toLowerCase())>-1&&(mode!=='__week__'||day)});if(sort==='title')list.sort(function(a,b){return String(a.title||'').localeCompare(String(b.title||''),'hi')});else if(sort==='category')list.sort(function(a,b){return String(a.category||'').localeCompare(String(b.category||''),'hi')});else list.sort(function(a,b){return String(b.createdAt||'').localeCompare(String(a.createdAt||''))});return list}
  function updateMetrics(){var list=source();document.getElementById('heroTotal').textContent=list.length;document.getElementById('heroFree').textContent=list.filter(function(p){return p.type!=='pro'}).length;document.getElementById('heroPro').textContent=list.filter(function(p){return p.type==='pro'}).length}
  function render(){var list=filtered(),shown=list.slice(0,visible);weekPanel.hidden=mode!=='__week__';title.textContent=query?'खोज के नतीजे':mode==='__all__'?'सभी पोस्टर':mode==='__week__'?'अगले 7 दिनों के पोस्टर':mode==='__favorites__'?'पसंदीदा पोस्टर':mode;count.textContent=list.length+' poster मिले';grid.innerHTML='';grid.classList.toggle('compact',compact);empty.hidden=!!list.length;loadMore.hidden=shown.length>=list.length;if(!list.length){document.getElementById('emptyTitle').textContent=mode==='__favorites__'?'अभी कोई पसंदीदा poster नहीं':'कोई poster नहीं मिला';return}shown.forEach(function(p){var pid=id(p),kind=p.type==='pro'?'pro':'free',fav=favorites.indexOf(pid)>-1,card=document.createElement('article');card.className='poster-card';var url=editorUrl(p);card.innerHTML="<div class='poster-image'><img src='"+esc(p.img)+"' alt='"+esc(p.title)+"' loading='lazy'><span class='poster-badge "+kind+"'>"+(kind==='pro'?'PRO':'FREE')+"</span><button class='fav-btn"+(fav?' active':'')+"' data-fav='"+esc(pid)+"' aria-label='पसंदीदा'>"+(fav?'♥':'♡')+"</button><div class='image-overlay'><a class='overlay-edit' href='"+url+"'>अभी edit करें →</a></div></div><div class='poster-info'><div class='poster-meta'><span class='poster-category'>"+esc(p.category||'Poster')+"</span><span class='poster-date'>"+esc(dateText(p.posterDate))+"</span></div><h3>"+esc(p.title)+"</h3><p>"+esc(p.description||p.festivalName||p.category||'')+"</p><div class='card-actions'><a class='poster-edit-btn' href='"+url+"'>पोस्टर बनाएं</a><button class='share-card' data-share='"+esc(pid)+"' aria-label='शेयर करें'>↗</button></div></div>";grid.appendChild(card)});grid.querySelectorAll('[data-fav]').forEach(function(b){b.onclick=function(){var x=b.dataset.fav,i=favorites.indexOf(x);if(i>-1)favorites.splice(i,1);else favorites.push(x);localStorage.setItem('dph_favorites',JSON.stringify(favorites));render()}});grid.querySelectorAll('[data-share]').forEach(function(b){b.onclick=function(){var p=source().find(function(x){return id(x)===b.dataset.share});if(!p)return;var u=location.origin+editorUrl(p);if(navigator.share)navigator.share({title:p.title,text:'यह poster देखें',url:u}).catch(function(){});else navigator.clipboard&&navigator.clipboard.writeText(u).then(function(){b.textContent='✓';setTimeout(function(){b.textContent='↗'},1200)})}})}
  function renderWeek(){var box=document.getElementById('weekDates');box.innerHTML='';sevenDays().forEach(function(d,i){var el=document.createElement('button');el.className='mini-date';el.dataset.iso=d.iso;el.innerHTML='<b>'+d.date.getDate()+'</b><span>'+(i===0?'आज':new Intl.DateTimeFormat('hi-IN',{month:'short'}).format(d.date))+'</span>';el.onclick=function(){selectedDay=selectedDay===d.iso?'':d.iso;box.querySelectorAll('.mini-date').forEach(function(x){x.classList.toggle('active',x.dataset.iso===selectedDay)});visible=12;render()};box.appendChild(el)})}
  document.querySelectorAll('.category-chip').forEach(function(b){b.onclick=function(){mode=b.dataset.cat;selectedDay='';visible=12;document.querySelectorAll('.category-chip').forEach(function(x){x.classList.toggle('active',x===b)});render()}});
  document.querySelectorAll('#typeTabs button').forEach(function(b){b.onclick=function(){type=b.dataset.type;visible=12;document.querySelectorAll('#typeTabs button').forEach(function(x){x.classList.toggle('active',x===b)});render()}});
  document.getElementById('posterSearch').oninput=function(){query=this.value;visible=12;render()};document.getElementById('clearSearch').onclick=function(){document.getElementById('posterSearch').value='';query='';render()};document.getElementById('sortPosters').onchange=function(){sort=this.value;render()};document.getElementById('loadMore').onclick=function(){visible+=12;render()};document.getElementById('viewToggle').onclick=function(){compact=!compact;this.classList.toggle('active',compact);render()};document.getElementById('resetFilters').onclick=function(){mode='__all__';type='all';query='';visible=12;selectedDay='';document.getElementById('posterSearch').value='';document.querySelectorAll('.category-chip').forEach(function(x){x.classList.toggle('active',x.dataset.cat==='__all__')});document.querySelectorAll('#typeTabs button').forEach(function(x){x.classList.toggle('active',x.dataset.type==='all')});render()};
  renderWeek();updateMetrics();render();fetch('/api/templates').then(function(r){return r.json()}).then(function(data){if(Array.isArray(data)&&data.length)POSTERS=data;updateMetrics();render()}).catch(function(){render()});
})();
</script>
