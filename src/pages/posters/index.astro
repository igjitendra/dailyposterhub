---
import Layout from '../../layouts/Layout.astro';
import Icon from '../../components/Icon.astro';
import { categories, templates } from '../../data/site.js';
const cats = categories.filter((c) => c.slug !== 'all');
const fallback = templates;
---
<Layout title='डेली पोस्टर — Daily PosterHub'>
  <section class='page-hero'>
    <div class='container'>
      <h1>विशेष <span class='grad-text'>दिवस</span></h1>
      <p>खास दिनों के पोस्टर — जयंती, पुण्यतिथि, त्योहार व अन्य खास मौके। तारीख़ चुनें, एडिट करें और डाउनलोड करें।</p>
    </div>
  </section>

  <section class='section' style='padding-top:24px'>
    <div class='container'>
      <div class='filters' id='catFilters'>
        <button class='chip active' data-cat='__daily__'><Icon name='sparkles' size={15} /> विशेष दिवस</button>
        <button class='chip' data-cat='__all__'><Icon name='grid' size={15} /> सभी</button>
        {cats.map((c) => (
          <button class='chip' data-cat={c.name}><Icon name={c.icon} size={15} /> {c.name}</button>
        ))}
      </div>

      <div class='date-strip' id='dateStrip'></div>

      <p class='daily-note' id='dailyNote'>आज के विशेष दिवस — जयंती, पुण्यतिथि, त्योहार व अन्य खास मौकों के पोस्टर। नई तारीख़ अपने-आप जुड़ती रहती है।</p>

      <div class='grid-info' id='gridInfo'></div>

      <div class='tpl-grid' id='tplGrid'></div>

      <div class='empty' id='emptyBox' hidden>
        <Icon name='image' size={30} />
        <p id='emptyText'>इस तारीख़ के लिए अभी कोई पोस्टर नहीं है।</p>
      </div>
    </div>
  </section>
</Layout>

<script id='fallbackData' type='application/json' set:html={JSON.stringify(fallback)}></script>

<style>
  .page-hero { background: var(--grad-soft); padding: 44px 0; text-align: center; }
  .page-hero h1 { font-size: 36px; font-weight: 800; }
  .page-hero p { color: var(--muted); margin-top: 8px; }

  .filters { display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 16px; }
  .chip { display: inline-flex; align-items: center; gap: 6px; font-size: 14px; font-weight: 600; padding: 8px 16px; border-radius: 999px; background: #fff; border: 1px solid var(--line); cursor: pointer; font-family: inherit; color: var(--ink); }
  .chip.active, .chip:hover { background: var(--purple); color: #fff; border-color: var(--purple); }

  .date-strip { display: flex; gap: 8px; overflow-x: auto; padding: 4px 0 12px; margin-bottom: 12px; border-bottom: 1px solid var(--line); scrollbar-width: thin; }
  .datechip { flex-shrink: 0; font-size: 13.5px; font-weight: 700; padding: 9px 15px; border-radius: 12px; background: var(--bg); border: 1px solid var(--line); cursor: pointer; font-family: inherit; color: var(--ink); white-space: nowrap; }
  .datechip.active { background: var(--grad); color: #fff; border-color: transparent; }

  .grid-info { font-size: 13.5px; color: var(--muted); margin: 4px 0 16px; font-weight: 600; }
  .daily-note { font-size: 13px; color: var(--muted); margin: 0 0 14px; line-height: 1.5; }

  .tpl-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; }
  .tpl-card { overflow: hidden; }
  .tpl-thumb { position: relative; }
  .tpl-thumb img { aspect-ratio: 3/4; object-fit: cover; width: 100%; border-radius: var(--radius) var(--radius) 0 0; background: linear-gradient(135deg,#EDE9FE,#E0E7FF); display: block; }
  .tpl-thumb .badge { position: absolute; top: 12px; left: 12px; }
  .tpl-body { padding: 14px 16px 18px; }
  .tpl-body h4 { font-size: 15px; }
  .tpl-cat { display: block; font-size: 13px; color: var(--muted); margin: 4px 0 12px; }
  .tpl-btn { width: 100%; gap: 6px; }

  .empty { text-align: center; padding: 60px 20px; color: var(--muted); }
  .empty :global(.icon) { color: var(--line); margin-bottom: 10px; }
  .empty p { font-size: 15px; }

  @media (max-width: 1024px) { .tpl-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 760px) { .tpl-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .tpl-grid { grid-template-columns: 1fr; gap: 16px; } .tpl-thumb img { aspect-ratio: 4/5; } .page-hero h1 { font-size: 28px; } }
</style>

<script is:inline>
  (function () {
    var HMONTHS = ['जनवरी','फ़रवरी','मार्च','अप्रैल','मई','जून','जुलाई','अगस्त','सितंबर','अक्टूबर','नवंबर','दिसंबर'];
    var POSTERS = [];
    var fallback = [];
    try { fallback = JSON.parse(document.getElementById('fallbackData').textContent) || []; } catch (e) {}

    var mode = 'daily';
    var selectedMD = null;

    function pad(n) { return String(n).padStart(2, '0'); }
    function toMD(s) { if (!s) return null; var m = String(s).match(/^(\d{4})-(\d{2})-(\d{2})/); return m ? (m[2] + '-' + m[3]) : null; }
    function byLatest(a, b) { return String(b.createdAt || '').localeCompare(String(a.createdAt || '')); }
    function esc(s) { var d = document.createElement('div'); d.textContent = (s == null ? '' : s); return d.innerHTML; }

    function buildDateChips() {
      var strip = document.getElementById('dateStrip');
      strip.innerHTML = '';
      var today = new Date();
      for (var i = 0; i < 7; i++) {
        var d = new Date(today.getFullYear(), today.getMonth(), today.getDate() + i);
        var val = pad(d.getMonth() + 1) + '-' + pad(d.getDate());
        var dateTxt = d.getDate() + ' ' + HMONTHS[d.getMonth()];
        var label = i === 0 ? ('आज · ' + dateTxt) : (i === 1 ? ('कल · ' + dateTxt) : dateTxt);
        var b = document.createElement('button');
        b.className = 'datechip' + (i === 0 ? ' active' : '');
        b.setAttribute('data-md', val);
        b.textContent = label;
        b.addEventListener('click', function () {
          selectedMD = this.getAttribute('data-md');
          var all = document.querySelectorAll('.datechip');
          for (var j = 0; j < all.length; j++) all[j].classList.toggle('active', all[j] === this);
          render();
        });
        strip.appendChild(b);
      }
      selectedMD = pad(today.getMonth() + 1) + '-' + pad(today.getDate());
    }

    function render() {
      var grid = document.getElementById('tplGrid');
      var empty = document.getElementById('emptyBox');
      var info = document.getElementById('gridInfo');
      var strip = document.getElementById('dateStrip');
      var list = [];

      var note = document.getElementById('dailyNote');
      if (mode === 'daily') {
        strip.style.display = 'flex';
        if (note) note.style.display = 'block';
        list = POSTERS.filter(function (p) { return toMD(p.posterDate) === selectedMD; }).sort(byLatest);
      } else {
        strip.style.display = 'none';
        if (note) note.style.display = 'none';
        var src = POSTERS.length ? POSTERS : fallback;
        if (mode === '__all__') list = src.slice().sort(byLatest);
        else list = src.filter(function (p) { return p.category === mode; }).sort(byLatest);
      }

      info.textContent = list.length ? (list.length + ' पोस्टर') : '';
      grid.innerHTML = '';

      if (!list.length) {
        empty.hidden = false;
        document.getElementById('emptyText').textContent = mode === 'daily'
          ? 'इस दिन के लिए अभी कोई विशेष पोस्टर नहीं — जल्द ही जोड़े जाएंगे!'
          : 'इस श्रेणी में अभी कोई पोस्टर नहीं है।';
        return;
      }
      empty.hidden = true;

      list.forEach(function (t) {
        var card = document.createElement('article');
        card.className = 'tpl-card card';
        var badge = t.type === 'pro' ? '<span class="badge badge-pro">Pro</span>' : '<span class="badge badge-free">फ़्री</span>';
        card.innerHTML = "<div class='tpl-thumb'><img src='" + esc(t.img) + "' alt='" + esc(t.title) + "' loading='lazy'>" + badge + "</div>" +
          "<div class='tpl-body'><h4>" + esc(t.title) + "</h4><span class='tpl-cat'>" + esc(t.category || '') + "</span>" +
          "<a href='/editor?img=" + encodeURIComponent(t.img || '') + "&title=" + encodeURIComponent(t.title || '') + "&type=" + encodeURIComponent(t.type || 'free') + "' class='btn btn-primary btn-sm tpl-btn'>एडिट करें</a></div>";
        grid.appendChild(card);
      });
    }

    var chips = document.querySelectorAll('#catFilters .chip');
    for (var i = 0; i < chips.length; i++) {
      chips[i].addEventListener('click', function () {
        for (var j = 0; j < chips.length; j++) chips[j].classList.toggle('active', chips[j] === this);
        var c = this.getAttribute('data-cat');
        mode = c === '__daily__' ? 'daily' : c;
        render();
      });
    }

    buildDateChips();
    render();
    fetch('/api/templates').then(function (r) { return r.json(); }).then(function (d) {
      POSTERS = Array.isArray(d) ? d : [];
      render();
    }).catch(function () { render(); });
  })();
</script>
