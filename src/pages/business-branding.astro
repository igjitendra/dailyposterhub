---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
---
<Layout title='Business Branding Layout'>
<section class='hero'><div class='container'><span class='eyebrow'>BUSINESS BRANDING</span><h1>1080×180 <span class='grad-text'>Branding Strip</span> बनाएं</h1><p>Prompt बनाएं, AI से layout तैयार करें, फिर crop करके अपने poster के नीचे लगाएं।</p></div></section>
<section class='section'><div class='container grid'>
<form class='card form' id='brandForm'><h2>1. Details और Prompt</h2><label>Business Name<input id='name' placeholder='Sharma Digital Seva'></label><label>Social Username<input id='social' placeholder='@sharmadigital'></label><label>Email<input id='email' placeholder='hello@example.com'></label><label>Phone Number<input id='phone' placeholder='98765 43210'></label><label>Website<input id='website' placeholder='www.example.in'></label><label>Address<input id='address' placeholder='Main Market, Lucknow'></label><label>Logo Upload (optional)<input id='logo' type='file' accept='image/*'></label><fieldset><legend>Layout में क्या दिखाना है?</legend><label><input id='showEmail' type='checkbox'> Email</label><label><input id='showPhone' type='checkbox' checked> Phone number</label><label><input id='showWebsite' type='checkbox' checked> Website</label><label><input id='showAddress' type='checkbox' checked> Address</label></fieldset><button class='btn btn-primary' id='promptBtn' type='button'>Prompt बनाएं</button><textarea id='prompt' rows='10' readonly placeholder='आपका detailed AI prompt यहां बनेगा...'></textarea><button class='btn btn-outline' id='copyBtn' type='button'>Prompt Copy करें</button></form>
<div class='right'><div class='card crop-card'><h2>2. Final Layout Upload + Crop</h2><p>AI से बनी image upload करें। Crop box का ratio exactly 1080×180 (6:1) है।</p><input id='layoutFile' type='file' accept='image/*'><div class='cropbox' id='cropbox'><img id='cropImage' alt='Crop preview'></div><label>Zoom<input id='zoom' type='range' min='1' max='3' step='.01' value='1'></label><p class='hint'>Image को crop box में drag करें, zoom slider से size adjust करें।</p><button id='saveBtn' type='button' class='btn btn-primary'>Save Branding Strip</button><button id='downloadBtn' type='button' class='btn btn-outline'>JPG Download</button><p id='status'></p></div><div class='card preview'><h2>Poster के नीचे ऐसा दिखेगा</h2><div class='poster'>आपका पसंदीदा Poster</div><img id='savedPreview' alt='Branding strip preview'></div></div>
</div></section>
</Layout>
<style>
.hero{padding:46px 0;background:var(--grad-soft);text-align:center}.hero h1{font-size:clamp(30px,4vw,44px);font-weight:800}.hero p{color:var(--muted)}.grid{display:grid;grid-template-columns:390px 1fr;gap:24px}.form,.crop-card,.preview{padding:22px}.form h2,.crop-card h2,.preview h2{font-size:20px;margin-bottom:10px}.form label{display:flex;flex-direction:column;gap:5px;margin:10px 0;font-size:13px;font-weight:700}.form input,.form textarea,.crop-card input[type=file]{border:1px solid var(--line);border-radius:9px;padding:10px;font:14px inherit}.form textarea{width:100%;margin-top:10px;resize:vertical;font:11px/1.45 monospace}.form .btn,.crop-card .btn{width:100%;margin-top:10px}fieldset{margin:15px 0;border:1px dashed var(--purple);border-radius:10px;padding:10px}fieldset label{display:inline-flex;flex-direction:row;margin:6px 10px 6px 0;gap:6px}.crop-card>p,.hint{color:var(--muted);font-size:13px;line-height:1.5}.cropbox{position:relative;width:100%;aspect-ratio:6/1;overflow:hidden;background:#e9e5f6;border:2px dashed var(--purple);border-radius:10px;cursor:grab}.cropbox img{position:absolute;left:50%;top:50%;max-width:none;transform:translate(-50%,-50%);user-select:none;pointer-events:none}.crop-card label{display:flex;gap:10px;align-items:center;margin-top:12px;font-size:13px;font-weight:700}.crop-card input[type=range]{flex:1}.poster{display:grid;place-items:center;aspect-ratio:3/4;background:#f2edff;color:#8d80b3;font-weight:800}.preview img{display:none;width:100%;aspect-ratio:6/1;object-fit:fill;background:#eee;margin-top:0}.preview img.show{display:block}#status{min-height:20px;color:#166534;font-size:13px;font-weight:700}@media(max-width:800px){.grid{grid-template-columns:1fr}.form{position:static}} 
</style>
<script is:inline>
(function(){var img=document.getElementById('cropImage'),box=document.getElementById('cropbox'),src='',zoom=1,x=0,y=0,drag=false,start={x:0,y:0};function v(id){return document.getElementById(id).value.trim()}function selected(){return ['showEmail','showPhone','showWebsite','showAddress'].filter(function(id){return document.getElementById(id).checked}).map(function(id){return id.replace('show','')})}function prompt(){var fields=selected().join(', ')||'only business name and social username';return `Create a premium horizontal business branding strip for the bottom of an Indian social media poster. Exact final canvas size MUST be 1080 x 180 pixels, strict 6:1 horizontal ratio. Research best modern local-business branding hierarchy and use safe margins. Place a logo placeholder on LEFT, business name "${v('name')||'BUSINESS NAME'}" large in center, social username "${v('social')||'@username'}" below it. Include only these details: ${fields}. Values: email ${v('email')||'email'}, phone ${v('phone')||'phone'}, website ${v('website')||'website'}, address ${v('address')||'address'}. Use elegant professional Indian business styling, high contrast text, clean icon system, balanced spacing, no people, no watermark, no extra invented text. Output only the 1080x180 strip.`}function render(){if(!src)return;img.style.width=(1080*zoom)+'px';img.style.height='auto';img.style.transform='translate(calc(-50% + '+x+'px),calc(-50% + '+y+'px))'}promptBtn.onclick=function(){document.getElementById('prompt').value=prompt()};copyBtn.onclick=function(){promptBtn.onclick();navigator.clipboard&&navigator.clipboard.writeText(document.getElementById('prompt').value);copyBtn.textContent='Copied ✓';setTimeout(function(){copyBtn.textContent='Prompt Copy करें'},1000)};layoutFile.onchange=function(){var r=new FileReader();r.onload=function(e){src=e.target.result;img.src=src;img.onload=function(){zoom=Math.max(1080/img.naturalWidth,180/img.naturalHeight);document.getElementById('zoom').value=zoom;render()}};r.readAsDataURL(this.files[0])};document.getElementById('zoom').oninput=function(){zoom=Number(this.value);render()};box.onpointerdown=function(e){drag=true;start={x:e.clientX-x,y:e.clientY-y};box.setPointerCapture(e.pointerId)};box.onpointermove=function(e){if(!drag)return;x=e.clientX-start.x;y=e.clientY-start.y;render()};box.onpointerup=function(){drag=false};function output(){var c=document.createElement('canvas');c.width=1080;c.height=180;var ctx=c.getContext('2d');if(!src)return null;var im=new Image();im.src=src;var w=1080*zoom,h=im.naturalHeight*(w/im.naturalWidth);ctx.drawImage(im,(1080-w)/2+x,(180-h)/2+y,w,h);return c.toDataURL('image/png')}saveBtn.onclick=function(){var out=output();if(!out){status.textContent='पहले layout upload करें।';return}localStorage.setItem('ph_branding',out);savedPreview.src=out;savedPreview.classList.add('show');status.textContent='Saved! अब poster edit करें और strip नीचे अपने-आप लगेगी।'};downloadBtn.onclick=function(){var out=output();if(!out)return;var a=document.createElement('a');a.href=out;a.download='branding-1080x180.jpg';a.click()};try{var old=localStorage.getItem('ph_branding');if(old){savedPreview.src=old;savedPreview.classList.add('show')}}catch(e){}})();
</script>
