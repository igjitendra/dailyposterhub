---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
---
<Layout title='Business Branding Layout — Daily PosterHub'>
  <section class='bb-hero'><div class='container'><span class='eyebrow'><Icon name='briefcase' size={15} /> BUSINESS PLAN FEATURE</span><h1>अपनी <span class='grad-text'>Branding Strip</span> बनाएं</h1><p>Logo, business name, social username, website और address जोड़ें। यह पट्टी poster के नीचे लगाकर एक professional पहचान बनाएं।</p></div></section>
  <section class='section'><div class='container bb-grid'>
    <aside class='bb-form card'>
      <h2>Business Details</h2><p class='muted'>सारी जानकारी बाद में फिर बदल सकते हैं।</p>
      <label>Logo Upload<input id='logoInput' type='file' accept='image/*' /></label>
      <label>Business Name<input id='businessName' maxlength='50' placeholder='जैसे: शर्मा डिजिटल सेवा' /></label>
      <label>Social Media Username<input id='socialName' maxlength='50' placeholder='जैसे: @sharma.digital' /></label>
      <label>Website<input id='website' maxlength='80' placeholder='www.yourbusiness.in' /></label>
      <label>Address / Location<input id='address' maxlength='90' placeholder='शहर, जिला, राज्य' /></label>
      <label>Mobile Number<input id='mobile' maxlength='20' inputmode='tel' placeholder='98765 43210' /></label>
      <label>Theme Color<input id='theme' type='color' value='#7C3AED' /></label>
      <button id='downloadBtn' type='button' class='btn btn-primary btn-lg'><Icon name='download' size={17} /> JPG डाउनलोड करें</button>
      <button id='saveBtn' type='button' class='btn btn-outline'><Icon name='check' size={17} /> Update Profile</button>
      <p id='status' class='status'></p>
    </aside>
    <main class='bb-preview-wrap'><div class='preview-head'><div><h2>Live Preview</h2><p>यह branding strip poster के नीचे दिखाई देगी।</p></div><span class='badge badge-pro'>BUSINESS</span></div>
      <div class='poster-demo'><div class='demo-poster'>आपका Poster Preview</div><div id='strip' class='brand-strip'><div class='logo-box' id='logoBox'>B</div><div class='brand-main'><strong id='outName'>आपका बिज़नेस नाम</strong><span id='outSocial'>@social_username</span></div><div class='brand-meta'><span id='outWeb'>www.website.in</span><span id='outAddress'>आपका पता</span></div></div></div>
      <p class='tip'><Icon name='sparkles' size={16} /> पहले <b>Update Profile</b> दबाएं। फिर Poster Editor में यह strip आपके poster के नीचे दिखेगी।</p>
    </main>
  </div></section>
</Layout>
<style>
.bb-hero{padding:48px 0;background:radial-gradient(600px 260px at 80% 0,#ded4ff,transparent 70%),var(--grad-soft);text-align:center}.bb-hero h1{margin-top:8px;font-size:clamp(30px,4vw,44px);font-weight:800}.bb-hero p{max-width:650px;margin:10px auto 0;color:var(--muted);font-size:15px;line-height:1.7}.bb-grid{display:grid;grid-template-columns:390px 1fr;gap:28px;align-items:start}.bb-form{padding:24px;position:sticky;top:18px}.bb-form h2{font-size:20px}.muted{margin:4px 0 18px;color:var(--muted);font-size:13px}.bb-form label{display:flex;flex-direction:column;gap:6px;margin-bottom:13px;font-size:13px;font-weight:700}.bb-form input{border:1px solid var(--line);border-radius:10px;padding:11px 12px;font:14px inherit;outline:0}.bb-form input:focus{border-color:var(--purple)}.bb-form input[type=color]{height:44px;padding:4px}.bb-form .btn{width:100%;margin-top:7px}.status{min-height:18px;margin:10px 0 0;color:#166534;font-size:13px;font-weight:700;text-align:center}.preview-head{display:flex;justify-content:space-between;align-items:center;margin-bottom:16px}.preview-head h2{font-size:22px}.preview-head p{margin-top:3px;color:var(--muted);font-size:13px}.poster-demo{max-width:680px;margin:auto;border-radius:18px;overflow:hidden;box-shadow:0 18px 40px rgba(46,28,100,.14);background:#fff}.demo-poster{display:grid;place-items:center;aspect-ratio:3/4;background:linear-gradient(145deg,#f3efff,#ffeef4);color:#8b7eaf;font-size:20px;font-weight:800}.brand-strip{display:flex;align-items:center;gap:12px;min-height:92px;padding:12px 16px;background:linear-gradient(110deg,#7C3AED,#4F46E5);color:#fff}.logo-box{display:grid;place-items:center;width:60px;height:60px;overflow:hidden;border-radius:12px;background:rgba(255,255,255,.2);font:800 26px Poppins,sans-serif;flex:none}.logo-box img{width:100%;height:100%;object-fit:cover}.brand-main{display:grid;gap:4px;min-width:0;flex:1}.brand-main strong{overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-size:18px}.brand-main span{font-size:12px;opacity:.9}.brand-meta{display:grid;gap:5px;text-align:right;font-size:11px;opacity:.95}.brand-meta span{max-width:190px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.tip{max-width:680px;margin:18px auto 0;padding:12px 14px;border-radius:11px;background:#eeeaff;color:#5e47a1;font-size:13px;display:flex;gap:8px;align-items:flex-start}@media(max-width:850px){.bb-grid{grid-template-columns:1fr}.bb-form{position:static;max-width:680px;margin:auto}}@media(max-width:480px){.section{padding:34px 0}.bb-form{padding:19px}.brand-strip{gap:9px;padding:10px}.logo-box{width:50px;height:50px}.brand-main strong{font-size:15px}.brand-meta{display:none}.demo-poster{font-size:16px}}
</style>
<script is:inline src='https://cdn.jsdelivr.net/npm/html2canvas@1.4.1/dist/html2canvas.min.js'></script>
<script is:inline>
(function(){var ids=['businessName','socialName','website','address','mobile','theme'], logo=null;var strip=document.getElementById('strip'),box=document.getElementById('logoBox');function get(){var o={};ids.forEach(function(id){o[id]=document.getElementById(id).value});o.logo=logo;return o}function render(){var o=get();strip.style.background='linear-gradient(110deg,'+(o.theme||'#7C3AED')+','+(o.theme||'#4F46E5')+')';outName.textContent=o.businessName||'आपका बिज़नेस नाम';outSocial.textContent=o.socialName||'@social_username';outWeb.textContent=o.website||'www.website.in';outAddress.textContent=[o.address,o.mobile].filter(Boolean).join(' • ')||'आपका पता'}function load(){try{var o=JSON.parse(localStorage.getItem('ph_brand_profile')||'{}');ids.forEach(function(id){if(o[id])document.getElementById(id).value=o[id]});logo=o.logo||null;if(logo){box.innerHTML='<img src="'+logo+'" alt="logo">'}}catch(e){}render()}ids.forEach(function(id){document.getElementById(id).addEventListener('input',render)});logoInput.addEventListener('change',function(){var f=this.files[0];if(!f)return;var r=new FileReader();r.onload=function(e){logo=e.target.result;box.innerHTML='<img src="'+logo+'" alt="logo">';render()};r.readAsDataURL(f)});saveBtn.addEventListener('click',function(){html2canvas(strip,{scale:3,backgroundColor:null}).then(function(cv){try{localStorage.setItem('ph_brand_profile',JSON.stringify(get()));localStorage.setItem('ph_branding',cv.toDataURL('image/png'));status.textContent='Profile update हो गया। Editor में branding strip दिखेगी।'}catch(e){status.textContent='Save नहीं हुआ।'}}).catch(function(){status.textContent='Branding save नहीं हुई।'});});function stripToData(){var cv=document.createElement('canvas'),c=cv.getContext('2d'),o=get();cv.width=1200;cv.height=160;c.fillStyle=o.theme||'#7C3AED';c.fillRect(0,0,1200,160);c.fillStyle='#fff';c.font='bold 40px Arial';c.fillText(o.businessName||'आपका बिज़नेस नाम',155,70);c.font='24px Arial';c.fillText(o.socialName||'@social_username',155,112);c.textAlign='right';c.fillText((o.website||'www.website.in')+'  '+(o.address||''),1160,90);if(logo){var im=new Image();im.src=logo;try{c.drawImage(im,25,25,110,110)}catch(e){}}else{c.font='bold 64px Arial';c.textAlign='left';c.fillText('B',55,105)}return cv.toDataURL('image/png')}downloadBtn.addEventListener('click',function(){html2canvas(strip,{scale:3,backgroundColor:null}).then(function(cv){var a=document.createElement('a');a.download='business-branding.jpg';a.href=cv.toDataURL('image/jpeg',.95);a.click()})});load()})();
</script>
