---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
---
<Layout title='Business Branding Layout'>
<section class='hero'><div class='container'><span class='eyebrow'>BUSINESS BRANDING</span><h1>1080×180 <span class='grad-text'>Branding Strip</span> बनाएं</h1><p>Prompt बनाएं, AI से layout तैयार करें, फिर crop करके अपने poster के नीचे लगाएं।</p></div></section>
<section class='section'><div class='container grid'>
<form class='card form' id='brandForm'><h2>1. Details और Prompt</h2><label>Business Name<input id='name' placeholder='Sharma Digital Seva'></label><label>Social Username<input id='social' placeholder='@sharmadigital'></label><label>Email<input id='email' placeholder='hello@example.com'></label><label>Phone Number<input id='phone' placeholder='98765 43210'></label><label>Website<input id='website' placeholder='www.example.in'></label><label>Address<input id='address' placeholder='Main Market, Lucknow'></label><label>Logo Upload (optional)<input id='logo' type='file' accept='image/*'></label><fieldset><legend>Layout में क्या दिखाना है?</legend><label><input id='showEmail' type='checkbox'> Email</label><label><input id='showPhone' type='checkbox' checked> Phone number</label><label><input id='showWebsite' type='checkbox' checked> Website</label><label><input id='showAddress' type='checkbox' checked> Address</label></fieldset><button class='btn btn-primary' id='promptBtn' type='button'>Prompt बनाएं</button><textarea id='prompt' rows='10' readonly placeholder='आपका detailed AI prompt यहां बनेगा...'></textarea><button class='btn btn-outline' id='copyBtn' type='button'>Prompt Copy करें</button></form>
<div class='right'><div class='card crop-card'><h2>2. Final Layout Upload + Crop</h2><p>AI से बनी image upload करें। Crop box का ratio exactly 1080×180 (6:1) है।</p><input id='layoutFile' type='file' accept='image/*'><div class='workspace' id='workspace'><img id='cropImage' alt='Crop preview'><div class='cropframe' id='cropbox'><span>1080 × 180 Crop Area</span></div></div><label>Zoom<input id='zoom' type='range' min='1' max='3' step='.01' value='1'></label><p class='hint'>Image को crop box में drag करें, zoom slider से size adjust करें।</p><button id='saveBtn' type='button' class='btn btn-primary'>Save Branding Strip</button><button id='downloadBtn' type='button' class='btn btn-outline'>JPG Download</button><p id='status'></p></div><div class='card preview'><h2>Poster के नीचे ऐसा दिखेगा</h2><div class='poster'>आपका पसंदीदा Poster</div><img id='savedPreview' alt='Branding strip preview'></div></div>
</div></section>
</Layout>
<style>
.hero{padding:46px 0;background:var(--grad-soft);text-align:center}.hero h1{font-size:clamp(30px,4vw,44px);font-weight:800}.hero p{color:var(--muted)}.grid{display:grid;grid-template-columns:390px 1fr;gap:24px}.form,.crop-card,.preview{padding:22px}.form h2,.crop-card h2,.preview h2{font-size:20px;margin-bottom:10px}.form label{display:flex;flex-direction:column;gap:5px;margin:10px 0;font-size:13px;font-weight:700}.form input,.form textarea,.crop-card input[type=file]{border:1px solid var(--line);border-radius:9px;padding:10px;font:14px inherit}.form textarea{width:100%;margin-top:10px;resize:vertical;font:11px/1.45 monospace}.form .btn,.crop-card .btn{width:100%;margin-top:10px}fieldset{margin:15px 0;border:1px dashed var(--purple);border-radius:10px;padding:10px}fieldset label{display:inline-flex;flex-direction:row;margin:6px 10px 6px 0;gap:6px}.crop-card>p,.hint{color:var(--muted);font-size:13px;line-height:1.5}.workspace{position:relative;width:100%;height:380px;overflow:hidden;background:#201a34;border-radius:12px;cursor:grab}.workspace img{position:absolute;left:50%;top:50%;max-width:none;transform:translate(-50%,-50%);user-select:none;pointer-events:none}.cropbox{position:absolute;left:50%;top:50%;width:86%;aspect-ratio:6/1;transform:translate(-50%,-50%);border:3px dashed #fff;box-shadow:0 0 0 999px rgba(0,0,0,.48);border-radius:6px;pointer-events:none}.cropbox span{position:absolute;top:-28px;left:0;padding:4px 8px;border-radius:5px;background:var(--purple);color:#fff;font-size:11px;font-weight:800}.crop-card label{display:flex;gap:10px;align-items:center;margin-top:12px;font-size:13px;font-weight:700}.crop-card input[type=range]{flex:1}.poster{display:grid;place-items:center;aspect-ratio:3/4;background:#f2edff;color:#8d80b3;font-weight:800}.preview img{display:none;width:100%;aspect-ratio:6/1;object-fit:fill;background:#eee;margin-top:0}.preview img.show{display:block}#status{min-height:20px;color:#166534;font-size:13px;font-weight:700}@media(max-width:800px){.grid{grid-template-columns:1fr}.form{position:static}} 
</style>
<script is:inline>
(function(){var img=cropImage,work=workspace,frame=cropbox,src='',scale=1,px=0,py=0,drag=false,start={x:0,y:0};function fit(){if(!img.naturalWidth)return;var r=frame.getBoundingClientRect(),min=Math.max(r.width/img.naturalWidth,r.height/img.naturalHeight);scale=Math.max(scale,min);zoom.min=min;zoom.value=scale;draw()}function draw(){if(!src)return;img.style.width=(img.naturalWidth*scale)+'px';img.style.height=(img.naturalHeight*scale)+'px';img.style.transform='translate(calc(-50% + '+px+'px),calc(-50% + '+py+'px))'}function out(){if(!src)return null;var fr=frame.getBoundingClientRect(),wr=work.getBoundingClientRect(),c=document.createElement('canvas'),ctx=c.getContext('2d');c.width=1080;c.height=180;var ratio=1080/fr.width;var iw=img.naturalWidth*scale,ih=img.naturalHeight*scale;var left=wr.width/2-iw/2+px,top=wr.height/2-ih/2+py;ctx.drawImage(img,(left-(fr.left-wr.left))*ratio,(top-(fr.top-wr.top))*ratio,iw*ratio,ih*ratio);return c.toDataURL('image/png')}layoutFile.onchange=function(){var r=new FileReader();r.onload=function(e){src=e.target.result;img.onload=function(){scale=1;px=py=0;fit()};img.src=src};r.readAsDataURL(this.files[0])};zoom.oninput=function(){scale=Number(this.value);draw()};work.onpointerdown=function(e){drag=true;start={x:e.clientX-px,y:e.clientY-py};work.setPointerCapture(e.pointerId)};work.onpointermove=function(e){if(!drag)return;px=e.clientX-start.x;py=e.clientY-start.y;draw()};work.onpointerup=function(){drag=false};saveBtn.onclick=function(){var o=out();if(!o){status.textContent='पहले layout upload करें।';return}localStorage.setItem('ph_branding',o);savedPreview.src=o;savedPreview.classList.add('show');status.textContent='Saved! अब editor में strip poster के नीचे full width दिखेगी।'};downloadBtn.onclick=function(){var o=out();if(!o)return;var a=document.createElement('a');a.href=o;a.download='branding-1080x180.png';a.click()};
function v(id){return document.getElementById(id).value.trim()}function fields(){return ['showEmail','showPhone','showWebsite','showAddress'].filter(function(x){return document.getElementById(x).checked}).map(function(x){return x.slice(4)}).join(', ')||'business name only'}function makePrompt(){return `Create a premium 1080 x 180 pixel horizontal business branding strip, strict 6:1 ratio. Research best professional local-business layout hierarchy. Left: logo. Center: business name ${v('name')||'BUSINESS NAME'} and social ${v('social')||'@username'}. Show only: ${fields()}. Data: ${v('email')} ${v('phone')} ${v('website')} ${v('address')}. Safe margins, white high contrast text, no people, no watermark, no extra text.`}promptBtn.onclick=function(){prompt.value=makePrompt()};copyBtn.onclick=function(){prompt.value=makePrompt();navigator.clipboard&&navigator.clipboard.writeText(prompt.value);copyBtn.textContent='Copied ✓';setTimeout(function(){copyBtn.textContent='Prompt Copy करें'},900)};try{var old=localStorage.getItem('ph_branding');if(old){savedPreview.src=old;savedPreview.classList.add('show')}}catch(e){}})();
</script>
