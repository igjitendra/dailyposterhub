---
import Layout from '../../layouts/Layout.astro';

export function getStaticPaths() {
  const mods = import.meta.glob('../../content/blog/*.md', { eager: true });
  return Object.entries(mods).map(([path, mod]) => ({
    params: { slug: path.split('/').pop().replace(/\.md$/, '') },
    props: { mod },
  }));
}

const { mod } = Astro.props;
const fm = mod.frontmatter;
const { Content } = mod;
const allHeadings = (typeof mod.getHeadings === 'function' ? mod.getHeadings() : []) || [];
const headings = allHeadings.filter((h) => h.depth === 2 || h.depth === 3);

const fmt = (d) => {
  try { return new Intl.DateTimeFormat('hi-IN', { day: 'numeric', month: 'long', year: 'numeric' }).format(new Date(d)); }
  catch (e) { return d; }
};

const pageTitle = (fm.seoTitle || fm.title) + ' — Daily PosterHub';
const metaDesc = fm.metaDescription || fm.excerpt || '';
const author = fm.author || 'Daily PosterHub Team';
const showToc = fm.toc !== false && headings.length > 0;
const faqs = Array.isArray(fm.faqs) ? fm.faqs.filter((f) => f && f.question && f.answer) : [];
const canonicalHref = fm.canonical || new URL('/blog/' + Astro.params.slug + '/', Astro.site).toString();

const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: fm.title,
  description: metaDesc,
  author: { '@type': 'Person', name: author },
  datePublished: fm.date,
  image: fm.cover || undefined,
  mainEntityOfPage: canonicalHref,
  publisher: { '@type': 'Organization', name: 'Daily PosterHub' },
};
const faqLd = faqs.length ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.question, acceptedAnswer: { '@type': 'Answer', text: f.answer } })),
} : null;
---
<Layout title={pageTitle} description={metaDesc} image={fm.cover || '/img/og-image.webp'} canonicalUrl={canonicalHref} type='article'>
  <article class='section'>
    <div class='container post-wrap'>
      <a href='/blog' class='back'>← सभी पोस्ट</a>
      {fm.cover ? <img class='post-cover' src={fm.cover} alt={fm.title} /> : null}
      <span class='post-tag'>{fm.tag}</span>
      <h1 class='post-title'>{fm.title}</h1>
      <div class='post-meta'><span>{fmt(fm.date)}</span> · <span>{author}</span></div>

      {showToc && (
        <nav class='toc'>
          <p class='toc-h'>विषय-सूची</p>
          <ul>
            {headings.map((h) => (
              <li class={h.depth === 3 ? 'sub' : ''}><a href={'#' + h.slug}>{h.text}</a></li>
            ))}
          </ul>
        </nav>
      )}

      <div class='post-body'><Content /></div>

      {faqs.length > 0 && (
        <section class='faq'>
          <h2>अक्सर पूछे जाने वाले सवाल (FAQ)</h2>
          {faqs.map((f) => (
            <details class='faq-item'>
              <summary>{f.question}</summary>
              <p>{f.answer}</p>
            </details>
          ))}
        </section>
      )}
    </div>
  </article>

  <script type='application/ld+json' set:html={JSON.stringify(articleLd)} />
  {faqLd && <script type='application/ld+json' set:html={JSON.stringify(faqLd)} />}
</Layout>

<style>
  .post-wrap { max-width: 780px; margin: 0 auto; }
  .back { display: inline-block; color: var(--purple); font-weight: 700; font-size: 14px; margin-bottom: 20px; }
  .post-cover { width: 100%; border-radius: 18px; margin: 6px 0 22px; aspect-ratio: 16/9; object-fit: cover; background: var(--grad-soft); }
  .post-tag { display: inline-block; background: var(--purple); color: #fff; font-size: 12px; font-weight: 700; padding: 4px 12px; border-radius: 999px; }
  .post-title { font-size: 32px; font-weight: 800; line-height: 1.25; margin: 14px 0 8px; }
  .post-meta { color: var(--muted); font-size: 14px; margin-bottom: 20px; display: flex; gap: 6px; }

  .toc { background: var(--bg); border: 1px solid var(--line); border-radius: 14px; padding: 16px 20px; margin: 0 0 26px; }
  .toc-h { font-weight: 800; font-size: 15px; margin-bottom: 8px; }
  .toc ul { list-style: none; padding: 0; margin: 0; }
  .toc li { margin: 5px 0; }
  .toc li.sub { padding-left: 16px; }
  .toc a { color: var(--purple); font-size: 14px; text-decoration: none; }
  .toc a:hover { text-decoration: underline; }

  .post-body :global(p) { color: var(--ink); line-height: 1.85; margin-bottom: 16px; }
  .post-body :global(h2) { font-size: 22px; font-weight: 800; margin: 26px 0 10px; scroll-margin-top: 90px; }
  .post-body :global(h3) { font-size: 18px; font-weight: 700; margin: 20px 0 8px; scroll-margin-top: 90px; }
  .post-body :global(ul), .post-body :global(ol) { padding-left: 22px; margin-bottom: 16px; color: var(--ink); }
  .post-body :global(li) { margin-bottom: 8px; line-height: 1.7; }
  .post-body :global(img) { max-width: 100%; border-radius: 12px; margin: 10px 0; }
  .post-body :global(a) { color: var(--purple); text-decoration: underline; }

  .faq { margin-top: 40px; border-top: 1px solid var(--line); padding-top: 26px; }
  .faq h2 { font-size: 22px; font-weight: 800; margin-bottom: 16px; }
  .faq-item { border: 1px solid var(--line); border-radius: 12px; padding: 14px 16px; margin-bottom: 12px; background: #fff; }
  .faq-item summary { font-weight: 700; cursor: pointer; font-size: 15.5px; list-style: none; }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::before { content: '+ '; color: var(--purple); font-weight: 800; }
  .faq-item[open] summary::before { content: '− '; }
  .faq-item p { margin-top: 10px; color: var(--muted); line-height: 1.7; font-size: 14.5px; }

  @media (max-width: 560px) { .post-title { font-size: 24px; } }
</style>
