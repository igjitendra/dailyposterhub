---
import Icon from '../components/Icon.astro';
---
<!doctype html>
<html lang="hi">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex, nofollow" />
  <title>App Settings — Daily PosterHub</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+Devanagari:wght@400;500;600;700;800&family=Poppins:wght@500;600;700;800&display=swap" rel="stylesheet" />
</head>
<body>
  <div id="loginView" class="login-view">
    <div class="login-card">
      <span class="logo">D</span><span class="eyebrow">DAILY POSTERHUB</span>
      <h1>App Settings</h1><p>पूरी website और advertising settings manage करने के लिए Admin Key डालें।</p>
      <label>Admin Key<input id="adminKey" type="password" placeholder="आपकी ADMIN_KEY" autocomplete="current-password" /></label>
      <button id="loginBtn" class="btn primary">Settings खोलें <Icon name="arrow-right" size={16} /></button>
      <p id="loginMsg" class="message"></p>
    </div>
  </div>

  <div id="appView" class="app-shell" hidden>
    <aside class="sidebar">
      <div class="brand"><span class="brand-icon">D</span><span>Daily<span>PosterHub</span></span></div>
      <nav class="tabs">
        <button class="tab active" data-tab="general"><Icon name="grid" size={18} /> सामान्य</button>
        <button class="tab" data-tab="ads"><Icon name="megaphone" size={18} /> Ads Setup</button>
        <button class="tab" data-tab="payment"><Icon name="credit-card" size={18} /> Payment</button>
        <button class="tab" data-tab="maintenance"><Icon name="shield" size={18} /> Maintenance</button>
      </nav>
      <div class="side-footer"><a href="/" target="_blank"><Icon name="eye" size={16} /> Website देखें</a><button id="logoutBtn"><Icon name="close" size={16} /> Logout</button></div>
    </aside>
    <main class="main">
      <header class="topbar"><button id="menuBtn" class="menu-btn"><Icon name="menu" size={22} /></button><div><p class="eyebrow">ADMIN CONTROL CENTER</p><h1>App Settings</h1></div><span id="saveState" class="save-state">लोड हो रहा है…</span></header>
      <div id="notice" class="notice" hidden></div>
      <form id="settingsForm">
        <section class="panel active" data-panel="general">
          <div class="panel-heading"><div><h2>सामान्य website settings</h2><p>Brand name, contact और basic website information update करें।</p></div></div>
          <div class="form-card grid two">
            <label>Website का नाम<input name="siteName" maxlength="80" placeholder="Daily PosterHub" /></label>
            <label>Tagline<input name="tagline" maxlength="180" placeholder="हर दिन नया पोस्टर..." /></label>
            <label>Support Email<input name="supportEmail" type="email" placeholder="support@example.com" /></label>
            <label>WhatsApp Number<input name="whatsapp" inputmode="tel" placeholder="919999999999" /></label>
          </div>
          <div class="info-card"><span><Icon name="sparkles" size={18} /></span><p>Brand name और tagline को page title/SEO में live बदलने के लिए अलग server-side integration चाहिए। यह page अभी values को सुरक्षित रखता है ताकि आप आगे site-wide use कर सकें।</p></div>
        </section>

        <section class="panel" data-panel="ads">
          <div class="panel-heading"><div><h2>Ads और advertising partners</h2><p>Google AdSense, Adsterra या किसी trusted advertising company की script और ad units जोड़ें।</p></div><label class="switch"><input name="adsEnabled" type="checkbox" /><span></span><b>Ads चालू</b></label></div>
          <div class="warning-card"><Icon name="shield" size={19} /><p>केवल trusted company का HTTPS script URL और ad code डालें। गलत या unknown code आपकी website पर risk पैदा कर सकता है।</p></div>
          <div class="form-card grid two ads-fields">
            <label>Ad Provider<select name="adProvider"><option>Google AdSense</option><option>Adsterra</option><option>Monetag</option><option>Media.net</option><option>Custom / Other</option></select></label>
            <label>Provider Script URL<input name="adScriptUrl" type="url" placeholder="https://example.com/ads.js" /></label>
          </div>
          <div class="form-card">
            <label>Top Ad Code<textarea name="topCode" rows="5" placeholder="Top banner का ad code paste करें..."></textarea><small>हर page में header के नीचे दिखेगा।</small></label>
            <label>Content Ad Code<textarea name="contentCode" rows="5" placeholder="Content के बाद दिखने वाला ad code paste करें..."></textarea><small>हर page के main content के बाद दिखेगा।</small></label>
            <label>Footer Ad Code<textarea name="footerCode" rows="5" placeholder="Footer के ऊपर दिखने वाला ad code paste करें..."></textarea><small>हर page में footer के ऊपर दिखेगा।</small></label>
            <label>Sticky Bottom Ad Code<textarea name="stickyCode" rows="5" placeholder="Mobile/desktop sticky bottom ad code paste करें..."></textarea><small>Screen के नीचे fixed ad के रूप में दिखेगा।</small></label>
          </div>
          <div class="ads-preview"><span>AD PREVIEW</span><div id="adPreview">Ads अभी बंद हैं</div></div>
        </section>

        <section class="panel" data-panel="payment">
          <div class="panel-heading"><div><h2>Payment settings</h2><p>Pro और Business plan के लिए payment information बदलें।</p></div></div>
          <div class="form-card grid two"><label>UPI ID<input name="upiId" placeholder="name@upi" /></label><div class="price-note"><Icon name="credit-card" size={20} /><div><b>Plan prices</b><p>Free ₹0 · Pro ₹21/month या ₹99/year · Business ₹299/year</p></div></div></div>
        </section>

        <section class="panel" data-panel="maintenance">
          <div class="panel-heading"><div><h2>Maintenance mode</h2><p>Update के समय website visitors को temporary message दिखाने के लिए तैयार रखें।</p></div><label class="switch"><input name="maintenance" type="checkbox" /><span></span><b>Maintenance mode</b></label></div>
          <div class="form-card"><label>Maintenance Message<textarea name="maintenanceMessage" rows="4" maxlength="300" placeholder="हम थोड़ी देर में वापस आएंगे।"></textarea></label></div>
          <div class="warning-card"><Icon name="sparkles" size={19} /><p>इस version में maintenance preference save होगी। Live visitor blocking को enable करने के लिए Cloudflare middleware/edge rule जोड़ना होगा।</p></div>
        </section>

        <div class="save-bar"><div><b>सभी बदलाव एक साथ save होंगे</b><span>Admin Key के साथ KV storage में सुरक्षित रखा जाएगा।</span></div><button class="btn primary save-btn" type="submit"><Icon name="check" size={17} /> बदलाव Save करें</button></div>
      </form>
    </main>
  </div>

<style>
:root{--purple:#7C3AED;--ink:#1E1B2E;--muted:#6B6880;--line:#E7E4F0;--bg:#F6F5FB}*{box-sizing:border-box}body{margin:0;background:var(--bg);color:var(--ink);font-family:'Noto Sans Devanagari',Poppins,Arial,sans-serif}.login-view{min-height:100vh;display:grid;place-items:center;padding:22px;background:radial-gradient(circle at 75% 10%,#ddd3ff,transparent 35%),linear-gradient(135deg,#f9f8ff,#eeeaff)}.login-card{width:min(100%,430px);padding:32px;border:1px solid rgba(255,255,255,.8);border-radius:22px;background:#fff;box-shadow:0 22px 55px rgba(56,37,123,.13);text-align:center}.logo,.brand-icon{display:grid;place-items:center;background:linear-gradient(135deg,#7C3AED,#4F46E5);color:#fff;font-family:Poppins,Arial,sans-serif;font-weight:800}.logo{width:60px;height:60px;margin:auto;border-radius:18px;font-size:32px}.eyebrow{margin:13px 0 0;color:var(--purple);font:800 11px Poppins,Arial,sans-serif;letter-spacing:.1em}.login-card h1{margin:9px 0 5px;font-size:26px}.login-card p{margin:0;color:var(--muted);font-size:14px;line-height:1.6}.login-card label,.form-card label{display:flex;flex-direction:column;gap:7px;text-align:left;font-size:13px;font-weight:800}.login-card label{margin-top:23px}.login-card input,.form-card input,.form-card select,.form-card textarea{width:100%;border:1px solid var(--line);border-radius:10px;background:#fff;padding:12px 13px;color:var(--ink);font:500 14px inherit;outline:0}.login-card input:focus,.form-card input:focus,.form-card select:focus,.form-card textarea:focus{border-color:var(--purple);box-shadow:0 0 0 3px rgba(124,58,237,.1)}.form-card textarea{resize:vertical;line-height:1.5}.btn{display:inline-flex;align-items:center;justify-content:center;gap:8px;border:0;border-radius:10px;padding:12px 18px;font:800 14px inherit;cursor:pointer}.primary{background:linear-gradient(135deg,#7C3AED,#4F46E5);color:#fff;box-shadow:0 9px 18px rgba(92,54,204,.22)}.login-card .btn{width:100%;margin-top:16px}.message{min-height:20px;margin-top:12px!important;font-weight:700}.message.err{color:#b91c1c}.app-shell{min-height:100vh;display:grid;grid-template-columns:244px 1fr}.sidebar{display:flex;flex-direction:column;position:sticky;top:0;height:100vh;padding:22px 14px;background:#19162c;color:#fff}.brand{display:flex;align-items:center;gap:10px;padding:0 10px;font:800 17px Poppins,Arial,sans-serif}.brand-icon{width:35px;height:35px;border-radius:11px;font-size:19px}.brand span span{color:#a892ff}.tabs{display:grid;gap:5px;margin-top:36px}.tab,.side-footer button,.side-footer a{display:flex;align-items:center;gap:10px;width:100%;border:0;border-radius:10px;background:transparent;color:#beb8d2;padding:12px 13px;text-decoration:none;font:700 14px inherit;cursor:pointer;text-align:left}.tab:hover,.tab.active{background:#302951;color:#fff}.side-footer{margin-top:auto;display:grid;gap:3px}.side-footer a:hover,.side-footer button:hover{color:#fff}.main{min-width:0;padding:0 38px 38px}.topbar{display:flex;align-items:center;justify-content:space-between;gap:20px;padding:31px 0 24px}.topbar .eyebrow{margin:0}.topbar h1{margin:4px 0 0;font-size:27px}.save-state{padding:7px 10px;border-radius:999px;background:#e9e4ff;color:var(--purple);font-size:12px;font-weight:800}.menu-btn{display:none}.notice{margin-bottom:18px;padding:12px 15px;border-radius:10px;background:#dcfce7;color:#166534;font-size:13px;font-weight:700}.notice.err{background:#fee2e2;color:#b91c1c}.panel{display:none}.panel.active{display:block}.panel-heading{display:flex;align-items:flex-start;justify-content:space-between;gap:18px;margin-bottom:19px}.panel-heading h2{margin:0;font-size:22px}.panel-heading p{max-width:630px;margin:5px 0 0;color:var(--muted);font-size:13px;line-height:1.6}.form-card{margin-top:14px;padding:21px;border:1px solid var(--line);border-radius:15px;background:#fff;box-shadow:0 3px 13px rgba(35,26,73,.04)}.grid{display:grid;gap:16px}.grid.two{grid-template-columns:repeat(2,minmax(0,1fr))}.form-card small{color:var(--muted);font-size:11px;font-weight:500}.form-card label+label{margin-top:16px}.grid label+label{margin-top:0}.info-card,.warning-card{display:flex;gap:11px;align-items:flex-start;margin-top:14px;padding:14px 16px;border-radius:13px;font-size:12.5px;line-height:1.55}.info-card{background:#ede9fe;color:#523995}.warning-card{background:#fff6dc;color:#745200}.info-card p,.warning-card p{margin:0}.switch{display:inline-flex;align-items:center;gap:8px;white-space:nowrap;font-size:12px!important}.switch input{position:absolute;opacity:0}.switch span{position:relative;width:40px;height:23px;border-radius:999px;background:#d7d2e3;transition:.2s}.switch span:after{content:'';position:absolute;top:3px;left:3px;width:17px;height:17px;border-radius:50%;background:#fff;transition:.2s}.switch input:checked+span{background:var(--purple)}.switch input:checked+span:after{transform:translateX(17px)}.ads-preview{margin-top:16px;padding:15px;border:1px dashed #cfc5ef;border-radius:14px;background:#fbfaff}.ads-preview>span{color:var(--purple);font:800 10px Poppins,Arial,sans-serif;letter-spacing:.08em}.ads-preview div{display:grid;place-items:center;min-height:68px;margin-top:8px;border-radius:9px;background:#f1eef8;color:var(--muted);font-size:13px}.price-note{display:flex;align-items:center;gap:12px;padding:15px;border-radius:12px;background:#f3f0ff;color:var(--purple)}.price-note b{font-size:14px}.price-note p{margin:2px 0 0;color:var(--muted);font-size:12px}.save-bar{position:sticky;bottom:16px;display:flex;align-items:center;justify-content:space-between;gap:18px;margin-top:24px;padding:15px 17px;border:1px solid #ddd5fb;border-radius:15px;background:rgba(255,255,255,.94);box-shadow:0 12px 28px rgba(39,26,82,.11);backdrop-filter:blur(10px)}.save-bar b{display:block;font-size:13px}.save-bar span{display:block;margin-top:2px;color:var(--muted);font-size:11px}.save-btn{min-width:160px}@media(max-width:760px){.app-shell{display:block}.sidebar{position:fixed;z-index:20;left:-255px;width:244px;transition:left .25s}.sidebar.open{left:0}.main{padding:0 17px 28px}.topbar{padding:21px 0 19px}.topbar h1{font-size:22px}.menu-btn{display:grid;place-items:center;width:41px;height:41px;border:1px solid var(--line);border-radius:10px;background:#fff}.topbar{justify-content:flex-start}.save-state{margin-left:auto}.grid.two{grid-template-columns:1fr}.panel-heading{flex-direction:column}.save-bar{align-items:stretch;flex-direction:column}.save-btn{width:100%}.sidebar:after{content:'';position:fixed;display:none;inset:0;left:244px;background:rgba(0,0,0,.3)}.sidebar.open:after{display:block}}@media(max-width:420px){.topbar .save-state{display:none}.login-card{padding:27px 20px}}
</style>

<script is:inline>
(function(){var KEY='ph_admin_key',saved=sessionStorage.getItem(KEY),key=document.getElementById('adminKey'),login=document.getElementById('loginView'),app=document.getElementById('appView'),msg=document.getElementById('loginMsg'),form=document.getElementById('settingsForm'),state=document.getElementById('saveState'),notice=document.getElementById('notice');if(saved)key.value=saved;function headers(){return {'content-type':'application/json','x-admin-key':key.value.trim()}}function show(t,err){notice.textContent=t;notice.className='notice'+(err?' err':'');notice.hidden=false;setTimeout(function(){notice.hidden=true},4500)}function data(){var f=new FormData(form);return {general:{siteName:f.get('siteName'),tagline:f.get('tagline'),supportEmail:f.get('supportEmail'),whatsapp:f.get('whatsapp'),upiId:f.get('upiId'),maintenance:f.get('maintenance')==='on',maintenanceMessage:f.get('maintenanceMessage')},ads:{enabled:f.get('adsEnabled')==='on',provider:f.get('adProvider'),scriptUrl:f.get('adScriptUrl'),topCode:f.get('topCode'),contentCode:f.get('contentCode'),footerCode:f.get('footerCode'),stickyCode:f.get('stickyCode')}}}function fill(s){var g=s.general||{},a=s.ads||{};['siteName','tagline','supportEmail','whatsapp','upiId','maintenanceMessage'].forEach(function(n){form.elements[n].value=g[n]||''});form.elements.maintenance.checked=!!g.maintenance;form.elements.adsEnabled.checked=!!a.enabled;form.elements.adProvider.value=a.provider||'Google AdSense';form.elements.adScriptUrl.value=a.scriptUrl||'';form.elements.topCode.value=a.topCode||a.headerCode||'';form.elements.contentCode.value=a.contentCode||'';form.elements.footerCode.value=a.footerCode||'';form.elements.stickyCode.value=a.stickyCode||'';preview()}function preview(){var a=data().ads,box=document.getElementById('adPreview');box.textContent=a.enabled?'Ads ON · '+(a.provider||'Custom provider'):'Ads अभी बंद हैं'}function load(){var k=key.value.trim();if(!k){msg.textContent='Admin Key डालें।';msg.className='message err';return}sessionStorage.setItem(KEY,k);fetch('/api/admin/settings',{headers:{'x-admin-key':k}}).then(function(r){return r.json().then(function(j){return{ok:r.ok,j:j}})}).then(function(res){if(!res.ok){msg.textContent=res.j.message||'Access नहीं मिला।';msg.className='message err';return}fill(res.j.settings);login.hidden=true;app.hidden=false;state.textContent='सभी settings loaded'}).catch(function(){msg.textContent='नेटवर्क समस्या।';msg.className='message err'})}document.getElementById('loginBtn').onclick=load;key.addEventListener('keydown',function(e){if(e.key==='Enter')load()});form.addEventListener('input',preview);form.addEventListener('submit',function(e){e.preventDefault();state.textContent='Save हो रहा है…';fetch('/api/admin/settings',{method:'POST',headers:headers(),body:JSON.stringify(data())}).then(function(r){return r.json().then(function(j){return{ok:r.ok,j:j}})}).then(function(res){if(res.ok){fill(res.j.settings);state.textContent='Saved ✓';show('Settings सफलतापूर्वक save हो गईं।')}else{state.textContent='Save नहीं हुआ';show(res.j.message||'Settings save नहीं हुईं।',true)}}).catch(function(){state.textContent='नेटवर्क समस्या';show('नेटवर्क समस्या।',true)})});document.querySelectorAll('.tab').forEach(function(b){b.onclick=function(){document.querySelectorAll('.tab').forEach(function(x){x.classList.toggle('active',x===b)});document.querySelectorAll('.panel').forEach(function(x){x.classList.toggle('active',x.dataset.panel===b.dataset.tab)});document.querySelector('.sidebar').classList.remove('open')}});document.getElementById('menuBtn').onclick=function(){document.querySelector('.sidebar').classList.toggle('open')};document.getElementById('logoutBtn').onclick=function(){sessionStorage.removeItem(KEY);location.reload()};if(saved)load()})();
</script>
</body></html>
