---
import Icon from './Icon.astro';
import { site, nav, pricing, categories } from '../data/site.js';
---
<!-- Pro promo banner -->
<div class='promo'>
  <div class='container promo-inner'>
    <span class='promo-text'>
      <Icon name='crown' size={16} />
      अभी Pro बनें और पाएं Premium Posters, HD Download और बिना Watermark के!
    </span>
    <a href='/pricing' class='btn btn-gold btn-xs'>Pro प्लान देखें</a>
  </div>
</div>

<header class='site-header'>
  <div class='container header-inner'>
    <!-- Brand -->
    <a href='/' class='brand'>
      <span class='brand-logo'>D</span>
      <span class='brand-text'>
        <span class='brand-name'>Daily<span class='grad-text'>PosterHub</span></span>
        <span class='brand-tag'>{site.tagline}</span>
      </span>
    </a>

    <!-- Desktop nav -->
    <nav class='nav-desktop'>
      <ul class='nav-list'>
        {nav.map((item) => (
          <li class={item.hasDropdown ? 'has-dropdown' : ''}>
            <a href={item.href}>
              {item.label}
              {item.hasDropdown && <Icon name='chevron-down' size={15} />}
            </a>
            {item.hasDropdown && (
              <div class='dropdown'>
                {categories.filter((c) => c.slug !== 'all').map((c) => (
                  <a href={'/categories/' + c.slug} class='dropdown-item'>
                    <span class='dd-icon' style={'color:' + c.color + ';background:' + c.bg}>
                      <Icon name={c.icon} size={16} />
                    </span>
                    {c.name}
                  </a>
                ))}
              </div>
            )}
          </li>
        ))}
      </ul>
    </nav>

    <!-- Right actions -->
    <div class='header-actions'>
      <button class='icon-btn' aria-label='खोजें' id='searchBtn'><Icon name='search' size={20} /></button>
      <a href='/login' class='btn btn-outline btn-sm hide-sm js-auth-link'>लॉगिन</a>
      <a href='/pricing' class='btn btn-primary btn-sm pro-btn hide-sm'>
        <Icon name='crown' size={16} /> Pro प्लान लें
      </a>
      <button class='hamburger' id='navToggle' aria-label='मेनू' aria-expanded='false'>
        <Icon name='menu' size={24} />
      </button>
    </div>
  </div>
</header>

<!-- Mobile drawer + backdrop -->
<div class='drawer-backdrop' id='drawerBackdrop'></div>
<aside class='drawer' id='drawer'>
  <div class='drawer-head'>
    <span class='brand-name'>Daily<span class='grad-text'>PosterHub</span></span>
    <button class='icon-btn' id='drawerClose' aria-label='बंद करें'><Icon name='close' size={22} /></button>
  </div>
  <nav class='drawer-nav'>
    {nav.map((item) => (
      <a href={item.href} class='drawer-link'>{item.label}</a>
    ))}
  </nav>
  <div class='drawer-cta'>
    <a href='/login' class='btn btn-outline btn-lg js-auth-link'>लॉगिन</a>
    <a href='/pricing' class='btn btn-primary btn-lg'><Icon name='crown' size={16} /> Pro प्लान लें</a>
  </div>
</aside>

<style>
  .promo { background: var(--dark); color: #fff; font-size: 13.5px; font-weight: 600; }
  .promo-inner { display: flex; align-items: center; justify-content: center; gap: 16px; padding: 9px 20px; text-align: center; flex-wrap: wrap; }
  .promo-text { display: inline-flex; align-items: center; gap: 8px; }
  .promo-text :global(.icon) { color: var(--gold); }
  .btn-xs { padding: 6px 14px; font-size: 12.5px; }

  .site-header { position: sticky; top: 0; z-index: 60; background: rgba(255,255,255,.92); backdrop-filter: blur(10px); border-bottom: 1px solid var(--line); }
  .header-inner { display: flex; align-items: center; justify-content: space-between; gap: 20px; height: 74px; }

  .brand { display: flex; align-items: center; gap: 11px; }
  .brand-logo { display: grid; place-items: center; width: 42px; height: 42px; background: var(--grad); border-radius: 12px; color: #fff; font-weight: 800; font-size: 22px; font-family: 'Poppins', sans-serif; }
  .brand-text { display: flex; flex-direction: column; line-height: 1.15; }
  .brand-name { font-weight: 800; font-size: 20px; font-family: 'Poppins', sans-serif; }
  .brand-tag { font-size: 11px; color: var(--muted); font-weight: 500; }

  .nav-desktop { flex: 1; display: flex; justify-content: center; }
  .nav-list { display: flex; align-items: center; gap: 28px; }
  .nav-list > li { position: relative; }
  .nav-list > li > a { display: inline-flex; align-items: center; gap: 4px; font-weight: 600; font-size: 15px; padding: 26px 0; color: var(--ink); transition: color .15s; }
  .nav-list > li > a:hover { color: var(--purple); }

  .has-dropdown:hover .dropdown { opacity: 1; visibility: visible; transform: translateY(0); }
  .dropdown { position: absolute; top: 100%; left: 50%; transform: translate(-50%, 8px); min-width: 230px; background: #fff; border: 1px solid var(--line); border-radius: 14px; box-shadow: var(--shadow); padding: 8px; opacity: 0; visibility: hidden; transition: .2s; }
  .dropdown-item { display: flex; align-items: center; gap: 10px; padding: 9px 12px; border-radius: 9px; font-size: 14px; font-weight: 600; }
  .dropdown-item:hover { background: var(--bg); }
  .dd-icon { display: grid; place-items: center; width: 30px; height: 30px; border-radius: 8px; }

  .header-actions { display: flex; align-items: center; gap: 10px; }
  .icon-btn { display: grid; place-items: center; width: 40px; height: 40px; border: 1px solid var(--line); border-radius: 10px; background: #fff; cursor: pointer; color: var(--ink); }
  .icon-btn:hover { border-color: var(--purple); color: var(--purple); }
  .pro-btn { gap: 6px; }

  .hamburger { display: none; align-items: center; justify-content: center; width: 42px; height: 42px; border: 1px solid var(--line); border-radius: 10px; background: #fff; cursor: pointer; color: var(--ink); }

  /* Drawer */
  .drawer-backdrop { position: fixed; inset: 0; background: rgba(23,20,42,.5); opacity: 0; visibility: hidden; transition: .25s; z-index: 70; }
  .drawer-backdrop.open { opacity: 1; visibility: visible; }
  .drawer { position: fixed; top: 0; right: 0; height: 100dvh; width: min(320px, 86vw); background: #fff; z-index: 80; display: flex; flex-direction: column; padding: 20px; box-shadow: -14px 0 40px rgba(0,0,0,.16); transform: translateX(100%); transition: transform .28s ease; overflow-y: auto; }
  .drawer.open { transform: translateX(0); }
  .drawer-head { display: flex; align-items: center; justify-content: space-between; padding-bottom: 16px; border-bottom: 1px solid var(--line); }
  .drawer-head .brand-name { font-size: 19px; }
  .drawer-nav { display: flex; flex-direction: column; padding: 8px 0; }
  .drawer-link { padding: 14px 4px; font-weight: 600; font-size: 16px; border-bottom: 1px solid var(--line); }
  .drawer-link:hover { color: var(--purple); }
  .drawer-cta { display: flex; flex-direction: column; gap: 10px; margin-top: 18px; }
  .drawer-cta .btn { width: 100%; }

  @media (max-width: 992px) {
    .nav-desktop { display: none; }
    .hamburger { display: flex; }
    .brand-tag { display: none; }
  }
  @media (max-width: 600px) {
    .hide-sm { display: none !important; }
    .header-inner { height: 64px; }
  }
</style>

<script>
  const toggle = document.getElementById('navToggle');
  const drawer = document.getElementById('drawer');
  const backdrop = document.getElementById('drawerBackdrop');
  const closeBtn = document.getElementById('drawerClose');

  const open = () => {
    drawer.classList.add('open');
    backdrop.classList.add('open');
    toggle.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  };
  const close = () => {
    drawer.classList.remove('open');
    backdrop.classList.remove('open');
    toggle.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  };

  toggle?.addEventListener('click', open);
  closeBtn?.addEventListener('click', close);
  backdrop?.addEventListener('click', close);
  drawer?.querySelectorAll('a').forEach((a) => a.addEventListener('click', close));
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') close(); });
</script>

<script>
  // Login state: agar logged-in hai to "लॉगिन" ko "मेरा खाता" bana do.
  fetch('/api/auth/me').then((r) => r.json()).then((d) => {
    if (d && d.user) {
      document.querySelectorAll('.js-auth-link').forEach((a) => {
        a.textContent = 'मेरा खाता';
        a.setAttribute('href', '/account');
      });
    }
  }).catch(() => {});
</script>
