---
<svg
  xmlns='http://www.w3.org/2000/svg'
  width={size}
  height={size}
  viewBox='0 0 24 24'
  fill='none'
  stroke='currentColor'
  stroke-width={stroke}
  stroke-linecap='round'
  stroke-linejoin='round'
  class={'icon ' + className}
  aria-hidden='true'
  set:html={inner}
></svg>
